---
type Category = "discovery" | "expedition" | "science" | "conservation" | "tragedy" | "milestone";

interface Event {
  year: number;
  yearLabel?: string;
  title: string;
  category: Category;
  description: string;
  speciesSlug?: string;
  location?: string;
  sourceUrl?: string;
  image?: {
    src: string;
    srcset?: string;
    alt: string;
    author: string;
    license: string;
    sourceUrl: string;
  };
}

interface Props {
  events: Event[];
}

const { events } = Astro.props;

// Klasifikace barev podle kategorie
const CATEGORY_COLOR: Record<Category, string> = {
  discovery: "bg-amber-500",
  expedition: "bg-blue-500",
  science: "bg-emerald-500",
  conservation: "bg-violet-500",
  tragedy: "bg-rose-500",
  milestone: "bg-slate-400",
};

const CATEGORY_LABEL: Record<Category, string> = {
  discovery: "Objev",
  expedition: "Expedice",
  science: "Věda",
  conservation: "Ochrana",
  tragedy: "Tragédie",
  milestone: "Milník",
};

const CATEGORY_ICON: Record<Category, string> = {
  discovery: "🔍",
  expedition: "🚢",
  science: "📊",
  conservation: "🛡️",
  tragedy: "⚠️",
  milestone: "★",
};

// Eventy seřazené chronologicky vzestupně.
const sorted = [...events].sort((a, b) => a.year - b.year);
---

<section class="px-4 sm:px-6 py-12 reveal" aria-labelledby="timeline-heading">
  <div class="mx-auto max-w-4xl">
    <h2 id="timeline-heading" class="sr-only">Časová osa</h2>

    <ol class="timeline" role="list">
      {sorted.map((e, i) => {
        const isRight = i % 2 === 0;
        const colorClass = CATEGORY_COLOR[e.category];
        return (
          <li class={`timeline-item ${isRight ? "timeline-item--right" : "timeline-item--left"}`} role="listitem">
            <div class="timeline-marker" aria-hidden="true">
              <span class={`timeline-dot ${colorClass}`}>{CATEGORY_ICON[e.category]}</span>
            </div>
            <article class="timeline-card bento-card p-5 md:p-6 reveal">
              <header class="flex items-baseline justify-between gap-3 mb-2 flex-wrap">
                <span class={`inline-flex items-center gap-1.5 rounded-full px-3 py-0.5 text-xs font-bold text-white ${colorClass}`}>
                  {CATEGORY_LABEL[e.category]}
                </span>
                <span class="text-2xl md:text-3xl font-black tracking-tight font-mono">{e.yearLabel ?? e.year}</span>
              </header>
              <h3 class="text-lg md:text-xl font-black leading-tight mb-2">{e.title}</h3>
              {e.image && (
                <figure class="mb-3 -mx-1 rounded-xl overflow-hidden border border-border bg-muted">
                  <img
                    src={e.image.src}
                    srcset={e.image.srcset}
                    sizes="(min-width: 768px) 360px, 90vw"
                    alt={e.image.alt}
                    loading="lazy"
                    decoding="async"
                    class="w-full h-auto block"
                  />
                  <figcaption class="px-3 py-2 text-[11px] text-muted-foreground">
                    Foto: <span class="font-medium text-foreground/80">{e.image.author}</span> · {e.image.license} ·
                    <a href={e.image.sourceUrl} target="_blank" rel="noopener noreferrer" class="ml-1 hover:text-primary underline decoration-dotted">zdroj</a>
                  </figcaption>
                </figure>
              )}
              <p class="text-sm md:text-base text-foreground/85 leading-relaxed">{e.description}</p>
              <footer class="mt-3 flex flex-wrap items-center gap-3 text-xs text-muted-foreground">
                {e.location && <span class="inline-flex items-center gap-1">📍 {e.location}</span>}
                {e.speciesSlug && (
                  <a
                    href={`/druhy/${e.speciesSlug}/`}
                    data-astro-prefetch="false"
                    class="inline-flex items-center gap-1 rounded-full border border-border bg-card px-2.5 py-0.5 hover:border-primary hover:text-primary transition-colors"
                  >
                    🐧 detail druhu
                  </a>
                )}
                {e.sourceUrl && (
                  <a
                    href={e.sourceUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1 hover:text-primary transition-colors"
                  >
                    zdroj ↗
                  </a>
                )}
              </footer>
            </article>
          </li>
        );
      })}
    </ol>
  </div>
</section>

<style>
  .timeline {
    position: relative;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  /* Centrální čára */
  .timeline::before {
    content: "";
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(180deg, transparent 0%, hsl(var(--border)) 5%, hsl(var(--border)) 95%, transparent 100%);
    transform: translateX(-1px);
  }
  .timeline-item {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    margin-bottom: 2.5rem;
  }
  .timeline-item:last-child { margin-bottom: 0; }
  .timeline-item--right .timeline-card { grid-column: 2; margin-left: 2rem; }
  .timeline-item--left  .timeline-card { grid-column: 1; margin-right: 2rem; }
  .timeline-marker {
    position: absolute;
    left: 50%;
    top: 1rem;
    transform: translate(-50%, 0);
    z-index: 2;
  }
  .timeline-dot {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 9999px;
    color: white;
    font-size: 1rem;
    box-shadow: 0 0 0 4px hsl(var(--background));
  }
  /* Mobil: jednosloupcová osa, čára vlevo */
  @media (max-width: 768px) {
    .timeline::before { left: 1rem; }
    .timeline-item { grid-template-columns: 1fr; }
    .timeline-item--right .timeline-card,
    .timeline-item--left  .timeline-card {
      grid-column: 1;
      margin-left: 3rem;
      margin-right: 0;
    }
    .timeline-marker { left: 1rem; }
  }
</style>
