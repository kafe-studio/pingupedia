---
const themes = [
  { id: "arctic", label: "Arctic — polární záře" },
  { id: "sunny", label: "Sunny — slunečné ráno" },
  { id: "ocean", label: "Ocean — pod hladinou" },
  { id: "candy", label: "Candy — duha a srdíčka" },
  { id: "midnight", label: "Midnight — hvězdopád" },
];
---

<div class="theme-switcher" data-theme-switcher>
  <button
    type="button"
    class="theme-switcher__trigger"
    data-theme-trigger
    aria-haspopup="true"
    aria-expanded="false"
    aria-controls="theme-switcher-panel"
  >
    <svg class="theme-switcher__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="9" />
      <circle cx="7.5" cy="10.5" r="1" fill="currentColor" />
      <circle cx="12" cy="7" r="1" fill="currentColor" />
      <circle cx="16.5" cy="10.5" r="1" fill="currentColor" />
      <circle cx="15" cy="15" r="1" fill="currentColor" />
    </svg>
    <span class="theme-switcher__label">Vyber si motiv</span>
  </button>
  <div
    id="theme-switcher-panel"
    class="theme-switcher__panel"
    role="group"
    aria-label="Přepínač designu"
    hidden
  >
    {themes.map((t) => (
      <button
        type="button"
        class="theme-switcher__btn"
        data-theme={t.id}
        aria-label={t.label}
        aria-pressed={t.id === "arctic" ? "true" : "false"}
        title={t.label}
      />
    ))}
  </div>
</div>

<script>
  const STORAGE_KEY = "pingupedia-theme";
  const VALID = ["arctic", "sunny", "ocean", "candy", "midnight"] as const;
  type Theme = (typeof VALID)[number];

  function isTheme(value: string): value is Theme {
    return (VALID as readonly string[]).includes(value);
  }

  function apply(theme: Theme): void {
    document.documentElement.setAttribute("data-variant", theme);
    document.querySelectorAll<HTMLButtonElement>("[data-theme]").forEach((btn) => {
      btn.setAttribute("aria-pressed", btn.dataset.theme === theme ? "true" : "false");
    });
    try {
      localStorage.setItem(STORAGE_KEY, theme);
    } catch {
      /* localStorage disabled — proceed in-memory */
    }
  }

  function wire(): void {
    document.querySelectorAll<HTMLButtonElement>("[data-theme-switcher] [data-theme]").forEach((btn) => {
      if (btn.dataset.wired) return;
      btn.dataset.wired = "1";
      btn.addEventListener("click", () => {
        const next = btn.dataset.theme;
        if (next && isTheme(next)) apply(next);
      });
    });
    const current = document.documentElement.getAttribute("data-variant");
    if (current && isTheme(current)) {
      document.querySelectorAll<HTMLButtonElement>("[data-theme]").forEach((btn) => {
        btn.setAttribute("aria-pressed", btn.dataset.theme === current ? "true" : "false");
      });
    }

    document.querySelectorAll<HTMLElement>("[data-theme-switcher]").forEach((root) => {
      if (root.dataset.wiredTrigger) return;
      root.dataset.wiredTrigger = "1";
      const trigger = root.querySelector<HTMLButtonElement>("[data-theme-trigger]");
      const panel = root.querySelector<HTMLElement>(".theme-switcher__panel");
      if (!trigger || !panel) return;

      const setOpen = (open: boolean): void => {
        trigger.setAttribute("aria-expanded", open ? "true" : "false");
        panel.hidden = !open;
        root.classList.toggle("is-open", open);
      };

      trigger.addEventListener("click", (e) => {
        e.stopPropagation();
        setOpen(trigger.getAttribute("aria-expanded") !== "true");
      });

      document.addEventListener("click", (e) => {
        if (!root.contains(e.target as Node)) setOpen(false);
      });

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && trigger.getAttribute("aria-expanded") === "true") {
          setOpen(false);
          trigger.focus();
        }
      });
    });
  }

  wire();
  document.addEventListener("astro:page-load", wire);
</script>
