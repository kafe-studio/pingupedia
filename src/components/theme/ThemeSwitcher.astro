---
// Jeden prvek "Nastav si styl" — po kliknutí přepne na další motiv v pořadí.
// 5 motivů: arctic → sunny → ocean → candy → midnight → arctic.
---

<div class="theme-switcher" data-theme-switcher>
  <button
    type="button"
    class="theme-switcher__trigger"
    data-theme-cycle
    aria-label="Nastav si styl — přepnout barevné schéma"
    title="Nastav si styl"
  >
    <svg class="theme-switcher__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="9" />
      <circle cx="7.5" cy="10.5" r="1" fill="currentColor" />
      <circle cx="12" cy="7" r="1" fill="currentColor" />
      <circle cx="16.5" cy="10.5" r="1" fill="currentColor" />
      <circle cx="15" cy="15" r="1" fill="currentColor" />
    </svg>
    <span class="theme-switcher__label">Nastav si styl</span>
  </button>
</div>

<script>
  const STORAGE_KEY = "pingupedia-theme";
  const VALID = ["arctic", "sunny", "ocean", "candy", "midnight"] as const;
  type Theme = (typeof VALID)[number];

  function isTheme(value: string): value is Theme {
    return (VALID as readonly string[]).includes(value);
  }

  function apply(theme: Theme): void {
    document.documentElement.setAttribute("data-variant", theme);
    try {
      localStorage.setItem(STORAGE_KEY, theme);
    } catch {
      /* localStorage disabled — proceed in-memory */
    }
  }

  function nextTheme(current: string | null): Theme {
    const idx = current && isTheme(current) ? VALID.indexOf(current as Theme) : -1;
    return VALID[(idx + 1) % VALID.length];
  }

  function wire(): void {
    document.querySelectorAll<HTMLButtonElement>("[data-theme-cycle]").forEach((btn) => {
      if (btn.dataset.wired) return;
      btn.dataset.wired = "1";
      btn.addEventListener("click", () => {
        const current = document.documentElement.getAttribute("data-variant");
        apply(nextTheme(current));
      });
    });
  }

  wire();
  document.addEventListener("astro:page-load", wire);
</script>
