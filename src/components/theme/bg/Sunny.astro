---
import { mulberry32, seedFromString } from "../../../lib/seeded-rng";
const rand = mulberry32(seedFromString("sunny"));
const clouds = [
  { top: 12, left: 8, scale: 1 },
  { top: 20, left: 68, scale: 1.3 },
  { top: 6, left: 45, scale: 0.8 },
];
const flakes = Array.from({ length: 18 }, () => ({
  left: rand() * 100,
  size: 4 + rand() * 4,
  duration: 18 + rand() * 12,
  delay: -rand() * 25,
}));
---

<div class="themed-bg" data-bg="sunny" aria-hidden="true">
  <div class="sun-sky"></div>

  <svg class="bg-sun anim-float" viewBox="0 0 200 200">
    <defs>
      <radialGradient id="sun-core" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#fef3c7" />
        <stop offset="60%" stop-color="#fbbf24" />
        <stop offset="100%" stop-color="#f59e0b" stop-opacity="0.6" />
      </radialGradient>
    </defs>
    <circle cx="100" cy="100" r="60" fill="url(#sun-core)" class="anim-float" />
    <g stroke="#fbbf24" stroke-width="4" stroke-linecap="round" opacity="0.7">
      <line x1="100" y1="10" x2="100" y2="30" />
      <line x1="100" y1="170" x2="100" y2="190" />
      <line x1="10" y1="100" x2="30" y2="100" />
      <line x1="170" y1="100" x2="190" y2="100" />
      <line x1="36" y1="36" x2="50" y2="50" />
      <line x1="150" y1="150" x2="164" y2="164" />
      <line x1="36" y1="164" x2="50" y2="150" />
      <line x1="150" y1="50" x2="164" y2="36" />
    </g>
  </svg>

  <svg class="bg-clouds" viewBox="0 0 1440 400" preserveAspectRatio="xMidYMid slice">
    {clouds.map((c, i) => (
      <g transform={`translate(${c.left * 14.4}, ${c.top * 4}) scale(${c.scale})`} class="anim-bob" style={`animation-delay: ${i * 0.8}s;`}>
        <ellipse cx="50" cy="40" rx="40" ry="22" fill="#ffffff" opacity="0.92" />
        <ellipse cx="85" cy="45" rx="30" ry="18" fill="#ffffff" opacity="0.92" />
        <ellipse cx="25" cy="48" rx="25" ry="15" fill="#ffffff" opacity="0.92" />
      </g>
    ))}
  </svg>

  <svg class="bg-bergs" viewBox="0 0 1440 260" preserveAspectRatio="xMidYMax slice">
    <defs>
      <linearGradient id="sun-berg" x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" stop-color="#ffffff" />
        <stop offset="100%" stop-color="#bae6fd" />
      </linearGradient>
    </defs>
    <path d="M-50 260 L-50 180 L200 130 L380 200 L560 150 L740 210 L920 160 L1100 200 L1280 150 L1490 190 L1490 260 Z" fill="url(#sun-berg)" opacity="0.85" />
  </svg>

  <div class="bg-particles">
    {flakes.map((f) => (
      <span class="snow-dot" style={`left: ${f.left}%; width: ${f.size}px; height: ${f.size}px; background: rgba(255,255,255,0.95); animation: snowfall ${f.duration}s linear ${f.delay}s infinite;`} />
    ))}
  </div>
</div>

<style>
  .sun-sky {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, #bae6fd 0%, #e0f2fe 55%, #ffffff 100%);
  }
  .bg-sun {
    position: absolute;
    top: 4%;
    right: 6%;
    width: 180px;
    height: 180px;
    filter: drop-shadow(0 0 40px rgba(251, 191, 36, 0.55));
  }
  .bg-clouds { position: absolute; inset: 0; width: 100%; height: 45%; }
  .bg-bergs { position: absolute; left: 0; right: 0; bottom: 0; width: 100%; height: 26vh; min-height: 160px; }
  .bg-particles { position: absolute; inset: 0; }
</style>
