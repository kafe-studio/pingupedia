---
import { mulberry32, seedFromString } from "../../../lib/seeded-rng";
const rand = mulberry32(seedFromString("dzungle"));
const leaves = Array.from({ length: 20 }, () => ({
  left: rand() * 100,
  size: 14 + rand() * 22,
  duration: 16 + rand() * 12,
  delay: -rand() * 22,
  rot: rand() * 360,
}));
const monkeys = Array.from({ length: 3 }, (_, i) => ({
  x: 250 + i * 480 + rand() * 80,
  delay: rand() * 3,
}));
---

<div class="themed-bg" data-bg="dzungle" aria-hidden="true">
  <svg class="bg-layer" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice">
    <defs>
      <linearGradient id="dz-sky" x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" stop-color="#0f3a1f" />
        <stop offset="50%" stop-color="#16532b" />
        <stop offset="100%" stop-color="#3d8348" />
      </linearGradient>
    </defs>
    <rect width="1440" height="900" fill="url(#dz-sky)" />
    {/* Velké palmové listy v rozích */}
    <g opacity="0.5">
      <path d="M0 0 Q 200 100 100 280 Q 50 200 0 200 Z" fill="#65a30d" />
      <path d="M1440 0 Q 1240 80 1340 260 Q 1390 180 1440 180 Z" fill="#65a30d" />
      <path d="M0 900 Q 180 800 80 640 Q 40 720 0 720 Z" fill="#4d7c0f" />
      <path d="M1440 900 Q 1260 820 1360 660 Q 1400 740 1440 740 Z" fill="#4d7c0f" />
    </g>
    {/* Liány */}
    <g opacity="0.4" stroke="#84cc16" stroke-width="3" fill="none">
      <path d="M200 0 Q 240 150 180 300 Q 220 450 160 600" />
      <path d="M1240 0 Q 1280 180 1220 360 Q 1260 540 1200 700" />
      <path d="M720 0 Q 700 200 740 400 Q 720 600 760 800" />
    </g>
    {monkeys.map((m) => (
      <g class="anim-bob" style={`animation-delay: ${m.delay}s; transform-origin: ${m.x}px 250px;`}>
        <circle cx={m.x} cy={240} r="22" fill="#92400e" />
        <circle cx={m.x} cy={258} r="14" fill="#fdba74" />
        <circle cx={m.x - 8} cy={236} r="3" fill="#1a1a1a" />
        <circle cx={m.x + 8} cy={236} r="3" fill="#1a1a1a" />
      </g>
    ))}
    {/* Tukan */}
    <g class="anim-float">
      <ellipse cx="1100" cy="180" rx="32" ry="22" fill="#1a1a1a" />
      <ellipse cx="1100" cy="186" rx="18" ry="12" fill="#ffd54a" />
      <path d="M1080 175 Q 1050 178 1058 188 Q 1070 184 1080 182 Z" fill="#f97316" />
    </g>
  </svg>
  <div class="bg-particles">
    {leaves.map((l) => (
      <span class="leaf" style={`left: ${l.left}%; width: ${l.size}px; height: ${l.size}px; transform: rotate(${l.rot}deg); animation: snowfall ${l.duration}s linear ${l.delay}s infinite;`} />
    ))}
  </div>
</div>

<style>
  .bg-layer { position: absolute; inset: 0; width: 100%; height: 100%; }
  .bg-particles { position: absolute; inset: 0; }
  .leaf {
    position: absolute;
    top: -40px;
    background: radial-gradient(ellipse at 30% 30%, #84cc16, #4d7c0f);
    clip-path: ellipse(50% 30% at 50% 50%);
    opacity: 0.7;
  }
</style>
