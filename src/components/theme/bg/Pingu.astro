---
import { mulberry32, seedFromString } from "../../../lib/seeded-rng";
const rand = mulberry32(seedFromString("pingu"));
const bubbles = Array.from({ length: 14 }, () => ({
  left: rand() * 100,
  size: 16 + rand() * 28,
  duration: 14 + rand() * 12,
  delay: -rand() * 18,
}));
const peng = Array.from({ length: 5 }, (_, i) => ({
  x: 90 + i * 260 + rand() * 80,
  delay: rand() * 4,
}));
---

<div class="themed-bg" data-bg="pingu" aria-hidden="true">
  <svg class="bg-layer" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice">
    <defs>
      <linearGradient id="pingu-sky" x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" stop-color="#1a4d8c" />
        <stop offset="60%" stop-color="#3b82c4" />
        <stop offset="100%" stop-color="#7dd3fc" />
      </linearGradient>
      <radialGradient id="pingu-sun" cx="20%" cy="18%" r="14%">
        <stop offset="0%" stop-color="#ffd54a" stop-opacity="0.85" />
        <stop offset="100%" stop-color="#ffd54a" stop-opacity="0" />
      </radialGradient>
    </defs>
    <rect width="1440" height="900" fill="url(#pingu-sky)" />
    <rect width="1440" height="900" fill="url(#pingu-sun)" />
    <circle cx="290" cy="160" r="60" fill="#ffd54a" class="anim-sparkle" />
  </svg>
  <svg class="bg-layer" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMax slice">
    {/* Iglu siluety na obzoru */}
    <ellipse cx="220" cy="720" rx="160" ry="60" fill="#fff8e7" opacity="0.85" />
    <ellipse cx="220" cy="720" rx="80" ry="38" fill="#1a4d8c" opacity="0.6" />
    <ellipse cx="980" cy="740" rx="180" ry="70" fill="#fff8e7" opacity="0.85" />
    <ellipse cx="980" cy="740" rx="90" ry="42" fill="#1a4d8c" opacity="0.6" />
    {peng.map((p) => (
      <g class="anim-bob" style={`animation-delay: ${p.delay}s; transform-origin: ${p.x}px 800px;`}>
        <ellipse cx={p.x} cy={830} rx="16" ry="22" fill="#1a1a1a" />
        <ellipse cx={p.x} cy={835} rx="10" ry="14" fill="#fff8e7" />
        <circle cx={p.x - 4} cy={815} r="2" fill="#fff" />
        <circle cx={p.x + 4} cy={815} r="2" fill="#fff" />
        <polygon points={`${p.x - 2},${820} ${p.x + 2},${820} ${p.x},${824}`} fill="#ffb000" />
      </g>
    ))}
  </svg>
  <div class="bg-particles">
    {bubbles.map((b) => (
      <span class="snow-dot" style={`left: ${b.left}%; width: ${b.size}px; height: ${b.size}px; background: rgba(255,213,74,0.4); border-radius: 50%; animation: snowfall ${b.duration}s linear ${b.delay}s infinite;`} />
    ))}
  </div>
</div>

<style>
  .bg-layer { position: absolute; inset: 0; width: 100%; height: 100%; }
  .bg-particles { position: absolute; inset: 0; }
</style>
