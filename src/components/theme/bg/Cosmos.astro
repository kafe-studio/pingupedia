---
import { mulberry32, seedFromString } from "../../../lib/seeded-rng";
const rand = mulberry32(seedFromString("cosmos"));
const stars = Array.from({ length: 140 }, () => ({
  top: rand() * 100,
  left: rand() * 100,
  size: 0.5 + Math.pow(rand(), 3) * 2.5,
  delay: rand() * 5,
  opacity: 0.4 + rand() * 0.6,
}));
const brightStars = Array.from({ length: 12 }, () => ({
  top: rand() * 90,
  left: rand() * 100,
  size: 1.5 + rand() * 1.5,
  hue: rand() < 0.5 ? "#cfe9ff" : (rand() < 0.5 ? "#ffe6c4" : "#ffd5cc"),
  delay: rand() * 6,
}));
---

<div class="themed-bg" data-bg="cosmos" aria-hidden="true">
  <div class="cosmos-void"></div>

  <svg class="bg-nebula" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice">
    <defs>
      <radialGradient id="nebula-pink" cx="20%" cy="35%" r="40%">
        <stop offset="0%" stop-color="#c084fc" stop-opacity="0.32" />
        <stop offset="60%" stop-color="#a855f7" stop-opacity="0.08" />
        <stop offset="100%" stop-color="#a855f7" stop-opacity="0" />
      </radialGradient>
      <radialGradient id="nebula-blue" cx="75%" cy="55%" r="42%">
        <stop offset="0%" stop-color="#60a5fa" stop-opacity="0.28" />
        <stop offset="55%" stop-color="#3b82f6" stop-opacity="0.06" />
        <stop offset="100%" stop-color="#3b82f6" stop-opacity="0" />
      </radialGradient>
      <radialGradient id="nebula-rose" cx="55%" cy="20%" r="35%">
        <stop offset="0%" stop-color="#fb7185" stop-opacity="0.16" />
        <stop offset="100%" stop-color="#fb7185" stop-opacity="0" />
      </radialGradient>
    </defs>
    <rect width="1440" height="900" fill="url(#nebula-blue)" />
    <rect width="1440" height="900" fill="url(#nebula-pink)" />
    <rect width="1440" height="900" fill="url(#nebula-rose)" />
  </svg>

  <svg class="bg-milkyway" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice">
    <defs>
      <linearGradient id="milky" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#cbd5e1" stop-opacity="0" />
        <stop offset="50%" stop-color="#e0e7ff" stop-opacity="0.18" />
        <stop offset="100%" stop-color="#cbd5e1" stop-opacity="0" />
      </linearGradient>
    </defs>
    <polygon points="0,300 1440,150 1440,330 0,520" fill="url(#milky)" />
  </svg>

  <svg class="bg-stars" viewBox="0 0 1440 900" preserveAspectRatio="none">
    {stars.map((s) => (
      <circle
        cx={s.left * 14.4}
        cy={s.top * 9}
        r={s.size}
        fill="#ffffff"
        opacity={s.opacity}
        class="anim-sparkle"
        style={`animation-delay: ${s.delay}s;`}
      />
    ))}
    {brightStars.map((s) => (
      <g style={`animation-delay: ${s.delay}s;`} class="anim-sparkle">
        <circle cx={s.left * 14.4} cy={s.top * 9} r={s.size * 2.5} fill={s.hue} opacity="0.18" />
        <circle cx={s.left * 14.4} cy={s.top * 9} r={s.size} fill={s.hue} />
      </g>
    ))}
  </svg>

  <svg class="bg-planet" viewBox="0 0 220 220" preserveAspectRatio="xMidYMid meet">
    <defs>
      <radialGradient id="planet-body" cx="38%" cy="38%" r="68%">
        <stop offset="0%" stop-color="#fcd34d" />
        <stop offset="45%" stop-color="#d97706" />
        <stop offset="80%" stop-color="#7c2d12" />
        <stop offset="100%" stop-color="#1c0900" />
      </radialGradient>
      <linearGradient id="planet-band" x1="0%" y1="50%" x2="100%" y2="50%">
        <stop offset="0%" stop-color="#fbbf24" stop-opacity="0" />
        <stop offset="50%" stop-color="#fde68a" stop-opacity="0.55" />
        <stop offset="100%" stop-color="#fbbf24" stop-opacity="0" />
      </linearGradient>
    </defs>
    <ellipse cx="110" cy="110" rx="105" ry="22" fill="none" stroke="#cbd5e1" stroke-width="1.5" opacity="0.45" transform="rotate(-18 110 110)" />
    <ellipse cx="110" cy="110" rx="98" ry="18" fill="none" stroke="#94a3b8" stroke-width="1" opacity="0.3" transform="rotate(-18 110 110)" />
    <circle cx="110" cy="110" r="62" fill="url(#planet-body)" />
    <ellipse cx="110" cy="98" rx="60" ry="6" fill="url(#planet-band)" />
    <ellipse cx="110" cy="120" rx="58" ry="4" fill="url(#planet-band)" opacity="0.7" />
    <ellipse cx="110" cy="110" rx="105" ry="22" fill="none" stroke="#e2e8f0" stroke-width="1" opacity="0.55" transform="rotate(-18 110 110) translate(0, 0)" stroke-dasharray="0 220 220 0" />
  </svg>

  <div class="bg-particles">
    <span class="comet"></span>
    <span class="comet comet-2"></span>
  </div>
</div>

<style>
  .cosmos-void {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 20%, #1a1538 0%, transparent 55%),
      radial-gradient(ellipse at 80% 70%, #0a1230 0%, transparent 50%),
      linear-gradient(180deg, #050516 0%, #02020a 60%, #000004 100%);
  }
  .bg-nebula { position: absolute; inset: 0; mix-blend-mode: screen; }
  .bg-milkyway { position: absolute; inset: 0; mix-blend-mode: screen; opacity: 0.7; }
  .bg-stars { position: absolute; inset: 0; }
  .bg-planet {
    position: absolute;
    top: 8%;
    right: 6%;
    width: 200px;
    height: 200px;
    filter: drop-shadow(0 0 25px rgba(252, 211, 77, 0.18));
  }
  .bg-particles { position: absolute; inset: 0; }
  .comet {
    position: absolute;
    top: 18%;
    left: 110%;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: #ffffff;
    box-shadow:
      0 0 8px 2px rgba(255, 255, 255, 0.95),
      -10px 6px 60px 1px rgba(186, 230, 253, 0.7),
      -22px 14px 100px 0 rgba(186, 230, 253, 0.35);
    will-change: transform;
    animation: comet-drift 9s ease-in 2s infinite;
  }
  .comet.comet-2 {
    top: 62%;
    animation-duration: 11s;
    animation-delay: 7s;
  }
  @keyframes comet-drift {
    0% { transform: translate3d(0, 0, 0); opacity: 0; }
    10% { opacity: 1; }
    100% { transform: translate3d(-130vw, 70vh, 0); opacity: 0; }
  }
</style>
