---
import { mulberry32, seedFromString } from "../../../lib/seeded-rng";
const rand = mulberry32(seedFromString("vesmir"));
const stars = Array.from({ length: 80 }, () => ({
  top: rand() * 100,
  left: rand() * 100,
  size: 0.5 + rand() * 2.5,
  delay: rand() * 5,
}));
const ufos = Array.from({ length: 3 }, (_, i) => ({
  y: 200 + i * 220,
  duration: 30 + rand() * 20,
  delay: -rand() * 25,
}));
---

<div class="themed-bg" data-bg="vesmir" aria-hidden="true">
  <svg class="bg-layer" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice">
    <defs>
      <radialGradient id="ves-bg" cx="50%" cy="50%" r="80%">
        <stop offset="0%" stop-color="#1e1b4b" />
        <stop offset="100%" stop-color="#050516" />
      </radialGradient>
      <radialGradient id="ves-planet1" cx="35%" cy="35%" r="60%">
        <stop offset="0%" stop-color="#f472b6" />
        <stop offset="100%" stop-color="#831843" />
      </radialGradient>
      <radialGradient id="ves-planet2" cx="40%" cy="40%" r="60%">
        <stop offset="0%" stop-color="#67e8f9" />
        <stop offset="100%" stop-color="#0891b2" />
      </radialGradient>
    </defs>
    <rect width="1440" height="900" fill="url(#ves-bg)" />
    {/* Mlhovina */}
    <ellipse cx="500" cy="300" rx="400" ry="180" fill="#6366f1" opacity="0.18" class="anim-aurora" />
    <ellipse cx="1000" cy="600" rx="350" ry="160" fill="#f472b6" opacity="0.15" />
    {/* Planety */}
    <circle cx="200" cy="200" r="60" fill="url(#ves-planet1)" />
    <circle cx="1240" cy="700" r="80" fill="url(#ves-planet2)" />
    <ellipse cx="1240" cy="700" rx="120" ry="20" fill="none" stroke="#67e8f9" stroke-width="2" opacity="0.6" />
    {/* Tučňák-astronaut */}
    <g class="anim-float" style="transform-origin: 720px 450px;">
      <circle cx="720" cy="450" r="44" fill="#1a1a1a" />
      <circle cx="720" cy="455" r="28" fill="#fff" />
      <circle cx="720" cy="445" r="22" fill="#67e8f9" opacity="0.5" />
      <circle cx="713" cy="442" r="3" fill="#fff" />
      <circle cx="725" cy="442" r="3" fill="#fff" />
      {/* Helma kruh */}
      <circle cx="720" cy="450" r="44" fill="none" stroke="#c7d2fe" stroke-width="2" opacity="0.6" />
      {/* Antény */}
      <line x1="700" y1="410" x2="695" y2="395" stroke="#c7d2fe" stroke-width="2" />
      <circle cx="695" cy="392" r="3" fill="#f472b6" class="anim-sparkle" />
    </g>
  </svg>
  <svg class="bg-layer" viewBox="0 0 1440 900" preserveAspectRatio="none">
    {stars.map((s) => (
      <circle cx={s.left * 14.4} cy={s.top * 9} r={s.size} fill="#ffffff" class="anim-sparkle" style={`animation-delay: ${s.delay}s;`} />
    ))}
  </svg>
  <div class="bg-particles">
    {ufos.map((u) => (
      <span class="ufo" style={`top: ${u.y}px; animation: ufo-cross ${u.duration}s linear ${u.delay}s infinite;`} />
    ))}
  </div>
</div>

<style>
  .bg-layer { position: absolute; inset: 0; width: 100%; height: 100%; }
  .bg-particles { position: absolute; inset: 0; }
  .ufo {
    position: absolute;
    left: -80px;
    width: 60px;
    height: 12px;
    background: linear-gradient(90deg, transparent, #c7d2fe, transparent);
    border-radius: 50%;
    opacity: 0.55;
    box-shadow: 0 0 8px #818cf8;
  }
  @keyframes ufo-cross {
    0% { left: -80px; }
    100% { left: 110%; }
  }
</style>
