---
import { mulberry32, seedFromString } from "../../../lib/seeded-rng";
const rand = mulberry32(seedFromString("savana"));
const sparks = Array.from({ length: 16 }, () => ({
  left: rand() * 100,
  top: rand() * 60,
  size: 2 + rand() * 4,
  delay: rand() * 4,
}));
---

<div class="themed-bg" data-bg="savana" aria-hidden="true">
  <svg class="bg-layer" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice">
    <defs>
      <linearGradient id="sv-sky" x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" stop-color="#7c2d12" />
        <stop offset="40%" stop-color="#c2410c" />
        <stop offset="80%" stop-color="#fbbf24" />
        <stop offset="100%" stop-color="#fef3c7" />
      </linearGradient>
      <radialGradient id="sv-sun" cx="50%" cy="55%" r="12%">
        <stop offset="0%" stop-color="#fef9c3" />
        <stop offset="100%" stop-color="#fbbf24" stop-opacity="0" />
      </radialGradient>
    </defs>
    <rect width="1440" height="900" fill="url(#sv-sky)" />
    <circle cx="720" cy="500" r="80" fill="#fef9c3" opacity="0.95" class="anim-sparkle" />
    <rect width="1440" height="900" fill="url(#sv-sun)" />
    {/* Akacie siluety na obzoru */}
    <g fill="#1a1a1a" opacity="0.85">
      <rect x="200" y="540" width="3" height="100" />
      <ellipse cx="201" cy="535" rx="40" ry="15" />
      <rect x="500" y="560" width="3" height="80" />
      <ellipse cx="501" cy="555" rx="35" ry="12" />
      <rect x="1100" y="530" width="3" height="110" />
      <ellipse cx="1101" cy="525" rx="50" ry="18" />
    </g>
    {/* Savana země */}
    <path d="M0 640 L1440 640 L1440 900 L0 900 Z" fill="#92400e" />
    {/* Žirafa silueta */}
    <g class="anim-bob" fill="#1a1a1a" opacity="0.9">
      <rect x="800" y="500" width="10" height="140" />
      <rect x="804" y="500" width="22" height="14" />
      <rect x="824" y="490" width="6" height="32" />
      <rect x="826" y="486" width="10" height="8" />
      <rect x="800" y="630" width="4" height="20" />
      <rect x="822" y="634" width="4" height="16" />
    </g>
    {/* Lev silueta */}
    <g fill="#1a1a1a" opacity="0.85">
      <ellipse cx="350" cy="660" rx="40" ry="20" />
      <circle cx="320" cy="650" r="20" />
      <rect x="312" y="660" width="6" height="20" />
      <rect x="328" y="660" width="6" height="20" />
      <rect x="378" y="660" width="6" height="20" />
      <rect x="370" y="660" width="6" height="20" />
    </g>
  </svg>
  <svg class="bg-layer" viewBox="0 0 1440 900" preserveAspectRatio="none">
    {sparks.map((s) => (
      <circle cx={s.left * 14.4} cy={s.top * 9} r={s.size} fill="#fef9c3" class="anim-sparkle" style={`animation-delay: ${s.delay}s;`} />
    ))}
  </svg>
</div>

<style>
  .bg-layer { position: absolute; inset: 0; width: 100%; height: 100%; }
</style>
