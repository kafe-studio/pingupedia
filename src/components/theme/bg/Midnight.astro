---
import { mulberry32, seedFromString } from "../../../lib/seeded-rng";
const rand = mulberry32(seedFromString("midnight"));
const stars = Array.from({ length: 60 }, () => ({
  top: rand() * 100,
  left: rand() * 100,
  size: 0.8 + rand() * 2,
  delay: rand() * 4,
}));
const shooters = Array.from({ length: 4 }, (_, i) => ({
  top: 5 + rand() * 30,
  left: 50 + rand() * 50,
  duration: 3 + rand() * 2,
  delay: i * 6 + rand() * 2,
}));
---

<div class="themed-bg" data-bg="midnight" aria-hidden="true">
  <div class="midnight-sky"></div>

  <svg class="bg-moon anim-float" viewBox="0 0 120 120">
    <defs>
      <radialGradient id="moon" cx="45%" cy="45%" r="55%">
        <stop offset="0%" stop-color="#fef9c3" />
        <stop offset="100%" stop-color="#eab308" stop-opacity="0.7" />
      </radialGradient>
      <radialGradient id="moon-glow" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#fde68a" stop-opacity="0.4" />
        <stop offset="100%" stop-color="#fde68a" stop-opacity="0" />
      </radialGradient>
    </defs>
    <circle cx="60" cy="60" r="55" fill="url(#moon-glow)" />
    <circle cx="60" cy="60" r="38" fill="url(#moon)" />
    <circle cx="72" cy="50" r="4" fill="#78350f" opacity="0.25" />
    <circle cx="55" cy="68" r="3" fill="#78350f" opacity="0.2" />
    <circle cx="48" cy="55" r="2.5" fill="#78350f" opacity="0.18" />
  </svg>

  <svg class="bg-aurora-faint anim-aurora" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice">
    <defs>
      <radialGradient id="mid-aurora" cx="40%" cy="60%" r="55%">
        <stop offset="0%" stop-color="#a78bfa" stop-opacity="0.25" />
        <stop offset="100%" stop-color="#a78bfa" stop-opacity="0" />
      </radialGradient>
    </defs>
    <rect width="1440" height="900" fill="url(#mid-aurora)" />
  </svg>

  <svg class="bg-stars" viewBox="0 0 1440 900" preserveAspectRatio="none">
    {stars.map((s) => (
      <circle cx={s.left * 14.4} cy={s.top * 9} r={s.size} fill="#ffffff" class="anim-sparkle" style={`animation-delay: ${s.delay}s;`} />
    ))}
  </svg>

  <div class="bg-particles">
    {shooters.map((s) => (
      <span
        class="shooting-star-dot"
        style={`top: ${s.top}%; left: ${s.left}%; animation: shooting-star ${s.duration}s ease-in ${s.delay}s infinite;`}
      />
    ))}
  </div>

  <svg class="bg-bergs" viewBox="0 0 1440 240" preserveAspectRatio="xMidYMax slice">
    <path d="M-50 240 L-50 180 L220 140 L420 190 L640 130 L860 190 L1080 140 L1280 200 L1490 150 L1490 240 Z" fill="#1e1b4b" opacity="0.7" />
  </svg>
</div>

<style>
  .midnight-sky {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 70% 20%, #312e81 0%, #0a0a1a 45%, #030308 100%);
  }
  .bg-moon {
    position: absolute;
    top: 6%;
    right: 10%;
    width: 140px;
    height: 140px;
    filter: drop-shadow(0 0 30px rgba(253, 230, 138, 0.35));
  }
  .bg-aurora-faint { position: absolute; inset: 0; mix-blend-mode: screen; }
  .bg-stars { position: absolute; inset: 0; }
  .bg-bergs { position: absolute; left: 0; right: 0; bottom: 0; width: 100%; height: 22vh; min-height: 140px; }
  .bg-particles { position: absolute; inset: 0; }
  .shooting-star-dot {
    position: absolute;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: #ffffff;
    box-shadow: 0 0 8px 2px rgba(255, 255, 255, 0.9),
      4px -4px 40px 0 rgba(255, 255, 255, 0.5);
    will-change: transform, opacity;
  }
</style>
