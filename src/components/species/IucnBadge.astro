---
type IucnStatus = "LC" | "NT" | "VU" | "EN" | "CR" | "DD" | "EX";

interface Props {
  status: IucnStatus;
  size?: "sm" | "md";
  class?: string;
}

const { status, size = "sm", class: className = "" } = Astro.props;

const labels: Record<IucnStatus, string> = {
  LC: "Málo dotčený",
  NT: "Téměř ohrožený",
  VU: "Zranitelný",
  EN: "Ohrožený",
  CR: "Kriticky ohrožený",
  DD: "Nedostatek dat",
  EX: "Vyhynulý",
};

const tone: Record<IucnStatus, string> = {
  LC: "bg-emerald-500/15 text-emerald-300 border-emerald-400/30",
  NT: "bg-lime-500/15 text-lime-200 border-lime-400/30",
  VU: "bg-amber-500/15 text-amber-200 border-amber-400/30",
  EN: "bg-orange-500/15 text-orange-200 border-orange-400/30",
  CR: "bg-red-500/15 text-red-200 border-red-400/30",
  DD: "bg-sky-500/15 text-sky-200 border-sky-400/30",
  EX: "bg-stone-500/15 text-stone-200 border-stone-400/30",
};

const sizeClass = size === "md"
  ? "px-3 py-1 text-sm"
  : "px-2.5 py-0.5 text-xs";

const title = `IUCN Red List: ${labels[status]}`;
---

<span
  class:list={["inline-flex items-center shrink-0 rounded-full border font-semibold", sizeClass, tone[status], className]}
  title={title}
  aria-label={`IUCN status: ${labels[status]}`}
>
  {status}
  {size === "md" && <span class="ml-1.5 font-normal opacity-80">· {labels[status]}</span>}
</span>
