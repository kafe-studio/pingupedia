---
import type { CollectionEntry } from "astro:content";

interface Props {
  species: CollectionEntry<"species">;
}

const { species } = Astro.props;
const { audio, video, nameCs } = species.data;

if (!audio && !video) return null;

function fmtDuration(sec: number | undefined): string | null {
  if (!sec) return null;
  const m = Math.floor(sec / 60);
  const s = sec % 60;
  return `${m}:${String(s).padStart(2, "0")}`;
}
---

<section class="px-6 py-12 bg-muted/50" aria-labelledby="media-heading">
  <div class="mx-auto max-w-5xl">
    <h2 id="media-heading" class="text-2xl md:text-3xl font-bold mb-6 reveal">Zvuk a video</h2>
    <div class="grid gap-6 md:grid-cols-2">
      {video && (
        <figure class="reveal rounded-2xl overflow-hidden border border-border bg-card">
          <video
            controls
            preload="metadata"
            poster={video.posterUrl}
            class="w-full aspect-video bg-black"
            aria-label={`Video: ${nameCs}`}
          >
            <source src={video.mediaUrl} type={video.mimeType} />
            Váš prohlížeč nepodporuje přehrávání videa.
          </video>
          <figcaption class="p-4 text-sm">
            <p class="text-foreground/90 mb-1">{video.caption}</p>
            <p class="text-xs text-muted-foreground">
              Video <strong class="font-semibold text-foreground/80">{video.author}</strong>, licence {video.license}.
              {video.durationSec && <span> · délka {fmtDuration(video.durationSec)}</span>}
              {" · "}
              <a
                href={video.sourceUrl}
                rel="noopener"
                target="_blank"
                class="underline decoration-dotted hover:text-primary"
              >
                Zdroj
              </a>
            </p>
          </figcaption>
        </figure>
      )}

      {audio && (
        <figure class="reveal rounded-2xl border border-border bg-card p-5 flex flex-col justify-between">
          <div>
            <div class="mb-4 flex items-center gap-3 text-muted-foreground">
              <svg class="h-6 w-6 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M9 18V5l12-2v13" />
                <circle cx="6" cy="18" r="3" />
                <circle cx="18" cy="16" r="3" />
              </svg>
              <span class="text-sm font-semibold uppercase tracking-wide">Hlas druhu</span>
            </div>
            <p class="text-foreground/90 mb-4">{audio.caption}</p>
          </div>
          <div>
            <audio
              controls
              preload="metadata"
              class="w-full"
              aria-label={`Zvuk druhu ${nameCs}`}
            >
              <source src={audio.mediaUrl} type={audio.mimeType} />
              Váš prohlížeč nepodporuje přehrávání zvuku.
            </audio>
            <p class="mt-3 text-xs text-muted-foreground">
              Nahrávka <strong class="font-semibold text-foreground/80">{audio.author}</strong>, licence {audio.license}.
              {audio.durationSec && <span> · délka {fmtDuration(audio.durationSec)}</span>}
              {" · "}
              <a
                href={audio.sourceUrl}
                rel="noopener"
                target="_blank"
                class="underline decoration-dotted hover:text-primary"
              >
                Zdroj
              </a>
            </p>
          </div>
        </figure>
      )}
    </div>
  </div>
</section>
