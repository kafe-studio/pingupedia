---
import type { CollectionEntry } from "astro:content";
import NoCropImage from "../media/NoCropImage.astro";

interface Props {
  species: CollectionEntry<"species">;
}

const { species } = Astro.props;
const { nameCs, nameLat, genus, iucnStatus, description, hero } = species.data;
const href = `/druhy/${species.id}/`;

const iucnLabels: Record<typeof iucnStatus, string> = {
  LC: "Málo dotčený",
  NT: "Téměř ohrožený",
  VU: "Zranitelný",
  EN: "Ohrožený",
  CR: "Kriticky ohrožený",
  DD: "Nedostatek dat",
  EX: "Vyhynulý",
};

const iucnTone: Record<typeof iucnStatus, string> = {
  LC: "bg-emerald-500/15 text-emerald-300 border-emerald-400/30",
  NT: "bg-lime-500/15 text-lime-200 border-lime-400/30",
  VU: "bg-amber-500/15 text-amber-200 border-amber-400/30",
  EN: "bg-orange-500/15 text-orange-200 border-orange-400/30",
  CR: "bg-red-500/15 text-red-200 border-red-400/30",
  DD: "bg-sky-500/15 text-sky-200 border-sky-400/30",
  EX: "bg-stone-500/15 text-stone-200 border-stone-400/30",
};
---

<a
  href={href}
  data-astro-prefetch
  class="group block overflow-hidden rounded-2xl border border-border bg-card transition-all hover:border-border-interactive hover:-translate-y-0.5"
>
  <NoCropImage
    src={hero.src}
    alt={hero.alt}
    ratio="4/3"
    sizes="(min-width: 1024px) 400px, (min-width: 640px) 50vw, 100vw"
    class="bg-muted"
  />
  <div class="p-5">
    <div class="flex items-start justify-between gap-3 mb-2">
      <div>
        <h3 class="text-xl font-bold text-foreground group-hover:text-primary transition-colors">
          {nameCs}
        </h3>
        <p class="text-sm italic text-muted-foreground mt-0.5">{nameLat}</p>
      </div>
      <span
        class:list={["shrink-0 rounded-full border px-2.5 py-0.5 text-xs font-semibold", iucnTone[iucnStatus]]}
        title={`IUCN Red List: ${iucnLabels[iucnStatus]}`}
        aria-label={`IUCN status: ${iucnLabels[iucnStatus]}`}
      >
        {iucnStatus}
      </span>
    </div>
    <p class="text-xs uppercase tracking-wide text-muted-foreground mb-3">
      Rod <span class="text-foreground/80">{genus}</span>
    </p>
    <p class="text-sm text-muted-foreground line-clamp-3">{description}</p>
  </div>
</a>
