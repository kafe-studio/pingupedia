---
import type { CollectionEntry } from "astro:content";
import NoCropImage from "../media/NoCropImage.astro";
import IucnBadge from "./IucnBadge.astro";

interface Props {
  species: CollectionEntry<"species">;
}

const { species } = Astro.props;
const { nameCs, nameLat, genus, iucnStatus, description, hero } = species.data;
const href = `/druhy/${species.id}/`;
---

<a
  href={href}
  data-astro-prefetch
  class="group block overflow-hidden rounded-2xl border border-border bg-card transition-all hover:border-border-interactive hover:-translate-y-0.5"
>
  <NoCropImage
    src={hero.src}
    alt={hero.alt}
    ratio="4/3"
    sizes="(min-width: 1024px) 400px, (min-width: 640px) 50vw, 100vw"
    widths={[400, 600, 800]}
    class="bg-muted"
  />
  <div class="p-5">
    <div class="flex items-start justify-between gap-3 mb-2">
      <div>
        <h3 class="text-xl font-bold text-foreground group-hover:text-primary transition-colors">
          {nameCs}
        </h3>
        <p class="text-sm italic text-muted-foreground mt-0.5" lang="la">{nameLat}</p>
      </div>
      <IucnBadge status={iucnStatus} />
    </div>
    <p class="text-xs uppercase tracking-wide text-muted-foreground mb-3">
      Rod <span class="text-foreground/80">{genus}</span>
    </p>
    <p class="text-sm text-muted-foreground line-clamp-3">{description}</p>
  </div>
</a>
