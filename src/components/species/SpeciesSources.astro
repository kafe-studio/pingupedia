---
import type { CollectionEntry } from "astro:content";

interface Props {
  species: CollectionEntry<"species">;
}

const { species } = Astro.props;
const { sources, updatedAt } = species.data;

const typeLabels = {
  Wikipedia: "Wikipedia",
  IUCN: "IUCN Red List",
  BirdLife: "BirdLife",
  Science: "Věda",
  Museum: "Muzeum",
  Other: "Jiné",
} as const;

const formatter = new Intl.DateTimeFormat("cs-CZ", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const updatedLabel = formatter.format(updatedAt);
---

<section class="px-6 py-12" aria-labelledby="sources-heading" data-pagefind-ignore>
  <div class="mx-auto max-w-5xl">
    <h2 id="sources-heading" class="text-2xl md:text-3xl font-bold mb-3 reveal">Zdroje</h2>
    <p class="text-sm text-muted-foreground mb-6 reveal">
      Ověřené prameny pro fakta na této stránce. Aktualizováno {updatedLabel}.
    </p>
    <ul class="space-y-3 reveal" role="list">
      {sources.map((source) => (
        <li class="flex items-start gap-3 rounded-xl border border-border bg-card p-4 transition-colors hover:border-border-interactive">
          <span class="shrink-0 text-xs font-semibold uppercase tracking-wide text-primary mt-0.5">
            {typeLabels[source.type]}
          </span>
          <div class="min-w-0 flex-1">
            <a
              href={source.url}
              rel="noopener noreferrer"
              target="_blank"
              class="font-medium text-foreground hover:text-primary transition-colors break-words"
            >
              {source.title}
            </a>
            {source.note && (
              <p class="text-sm text-muted-foreground mt-1">{source.note}</p>
            )}
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
