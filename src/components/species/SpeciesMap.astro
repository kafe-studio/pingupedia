---
import worldUrl from "../../assets/maps/world.svg?url";
import { project, MAP_WIDTH, MAP_HEIGHT } from "../../lib/maps/projection";

interface Colony {
  name: string;
  lat: number;
  lon: number;
  type?: "breeding" | "wintering" | "vagrant";
  description?: string;
}

interface Props {
  colonies: Colony[];
  speciesName: string;
}

const { colonies, speciesName } = Astro.props;

// Klasifikace barev podle typu kolonie.
const COLOR: Record<NonNullable<Colony["type"]> | "default", string> = {
  breeding: "#ef4444",   // červená — hnízdiště
  wintering: "#3b82f6",  // modrá — zimoviště
  vagrant: "#a855f7",    // fialová — zatoulanci
  default: "#ef4444",
};

const markers = colonies.map((c) => ({
  ...c,
  ...project(c.lat, c.lon),
  color: COLOR[c.type ?? "default"],
}));
---

<section class="px-6 py-12" aria-labelledby="map-heading">
  <div class="mx-auto max-w-5xl">
    <h2 id="map-heading" class="text-2xl md:text-3xl font-bold mb-3 reveal">Mapa výskytu</h2>
    <p class="text-sm text-muted-foreground mb-6 reveal">
      {colonies.length} {colonies.length === 1 ? "kolonie" : colonies.length < 5 ? "kolonie" : "kolonií"} druhu {speciesName}.
      Najeď myší na bod pro detail.
    </p>

    <div class="reveal rounded-xl border border-border bg-card p-2 md:p-4 overflow-hidden">
      <svg
        viewBox={`0 0 ${MAP_WIDTH} ${MAP_HEIGHT}`}
        xmlns="http://www.w3.org/2000/svg"
        class="w-full h-auto block"
        role="img"
        aria-label={`Mapa kolonií druhu ${speciesName}`}
        data-species-map
      >
        <image href={worldUrl} x="0" y="0" width={MAP_WIDTH} height={MAP_HEIGHT} preserveAspectRatio="xMidYMid meet" />
        {markers.map((m, i) => (
          <g class="map-marker" data-marker={i} role="button" tabindex="0" aria-label={`Kolonie ${m.name}`}>
            <circle cx={m.x} cy={m.y} r="14" fill={m.color} fill-opacity="0.18" />
            <circle cx={m.x} cy={m.y} r="6" fill={m.color} stroke="#ffffff" stroke-width="1.5">
              <title>{m.name}{m.description ? ` — ${m.description}` : ""}</title>
            </circle>
          </g>
        ))}
      </svg>
    </div>

    <ul class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-2 text-sm reveal" data-colony-list>
      {colonies.map((c, i) => (
        <li>
          <button
            type="button"
            data-colony-target={i}
            class="w-full text-left flex items-start gap-2 rounded-lg border border-border bg-card px-3 py-2 transition-colors hover:border-primary focus:outline-none focus:ring-2 focus:ring-primary"
          >
            <span
              class="shrink-0 w-3 h-3 rounded-full mt-1"
              style={`background:${COLOR[c.type ?? "default"]}`}
              aria-hidden="true"
            />
            <span class="min-w-0">
              <span class="font-semibold">{i + 1}. {c.name}</span>
              {c.description && <span class="text-muted-foreground"> · {c.description}</span>}
            </span>
          </button>
        </li>
      ))}
    </ul>

    <div class="mt-4 flex flex-wrap gap-4 text-xs text-muted-foreground reveal">
      <span class="inline-flex items-center gap-2"><span class="w-3 h-3 rounded-full" style="background:#ef4444"></span> hnízdiště</span>
      <span class="inline-flex items-center gap-2"><span class="w-3 h-3 rounded-full" style="background:#3b82f6"></span> zimoviště</span>
      <span class="inline-flex items-center gap-2"><span class="w-3 h-3 rounded-full" style="background:#a855f7"></span> zatoulanci</span>
    </div>
  </div>
</section>

<style>
  .map-marker { transition: transform 0.2s ease; transform-origin: center; transform-box: fill-box; cursor: pointer; }
  .map-marker:hover { transform: scale(1.4); }
  .map-marker:focus { outline: none; }
  .map-marker:focus-visible > circle:last-of-type { stroke: #facc15; stroke-width: 3; }
  .map-marker.flash { animation: marker-flash 1.4s ease-out; transform-origin: center; transform-box: fill-box; }
  @keyframes marker-flash {
    0%   { transform: scale(1);   filter: drop-shadow(0 0 0 #facc15); }
    25%  { transform: scale(2.4); filter: drop-shadow(0 0 12px #facc15); }
    50%  { transform: scale(1);   filter: drop-shadow(0 0 4px #facc15); }
    75%  { transform: scale(2.4); filter: drop-shadow(0 0 12px #facc15); }
    100% { transform: scale(1);   filter: drop-shadow(0 0 0 transparent); }
  }
  button[data-colony-target].flash {
    animation: colony-flash 1.4s ease-out;
  }
  @keyframes colony-flash {
    0%   { background: var(--card); box-shadow: 0 0 0 0 rgba(250,204,21,0); }
    25%  { background: rgba(250,204,21,0.35); box-shadow: 0 0 0 4px rgba(250,204,21,0.6); }
    50%  { background: var(--card); box-shadow: 0 0 0 0 rgba(250,204,21,0); }
    75%  { background: rgba(250,204,21,0.35); box-shadow: 0 0 0 4px rgba(250,204,21,0.6); }
    100% { background: var(--card); box-shadow: 0 0 0 0 rgba(250,204,21,0); }
  }
</style>

<script>
  function wireSpeciesMap(): void {
    document.querySelectorAll<SVGSVGElement>("[data-species-map]").forEach((svg) => {
      const section = svg.closest("section");
      const list = section?.querySelector<HTMLElement>("[data-colony-list]");
      if (!list || list.dataset.wired === "1") return;
      list.dataset.wired = "1";

      const flashMarker = (idx: string): void => {
        const marker = svg.querySelector<SVGGElement>(`g[data-marker="${idx}"]`);
        if (!marker) return;
        marker.classList.remove("flash");
        void marker.getBoundingClientRect();
        marker.classList.add("flash");
      };

      const flashColony = (idx: string): void => {
        const btn = list.querySelector<HTMLButtonElement>(`button[data-colony-target="${idx}"]`);
        if (!btn) return;
        btn.classList.remove("flash");
        void btn.getBoundingClientRect();
        btn.classList.add("flash");
      };

      // Klik na položku seznamu → blikne marker, scroll k mapě.
      list.querySelectorAll<HTMLButtonElement>("button[data-colony-target]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const idx = btn.dataset.colonyTarget;
          if (!idx) return;
          flashMarker(idx);
          svg.scrollIntoView({ behavior: "smooth", block: "center" });
        });
      });

      // Klik na marker na mapě → blikne odpovídající položka v seznamu, scroll k seznamu.
      svg.querySelectorAll<SVGGElement>("g[data-marker]").forEach((marker) => {
        const handle = (e: Event): void => {
          if (e instanceof KeyboardEvent && e.key !== "Enter" && e.key !== " ") return;
          if (e.type === "keydown") e.preventDefault();
          const idx = marker.getAttribute("data-marker");
          if (!idx) return;
          flashColony(idx);
          // Scroll k položce, aby user viděl, na co kliknul.
          const btn = list.querySelector<HTMLButtonElement>(`button[data-colony-target="${idx}"]`);
          btn?.scrollIntoView({ behavior: "smooth", block: "center" });
        };
        marker.addEventListener("click", handle);
        marker.addEventListener("keydown", handle);
      });
    });
  }
  wireSpeciesMap();
  document.addEventListener("astro:page-load", wireSpeciesMap);
</script>
