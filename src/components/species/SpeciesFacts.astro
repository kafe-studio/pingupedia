---
import type { CollectionEntry } from "astro:content";

interface Props {
  species: CollectionEntry<"species">;
}

const { species } = Astro.props;
const { genus, size, distribution, habitat, diet, lifespan, diving, population } = species.data;

const fmtRange = ([min, max]: readonly [number, number], unit: string) =>
  min === max ? `${min} ${unit}` : `${min}–${max} ${unit}`;

const fmtYears = (years: number) =>
  `${years} ${years === 1 ? "rok" : years >= 2 && years <= 4 ? "roky" : "let"}`;

const fmtDuration = (sec: number) => {
  if (sec < 60) return `${sec} s`;
  const m = Math.floor(sec / 60);
  const s = sec % 60;
  return s === 0 ? `${m} min` : `${m} min ${s} s`;
};

const heightLabel = fmtRange(size.heightCm, "cm");
const weightLabel = fmtRange(size.weightKg, "kg");
const wildLabel = fmtYears(lifespan.wildYears);
const captivityLabel = lifespan.captivityYears !== undefined
  ? fmtYears(lifespan.captivityYears)
  : null;

const depthTypical = diving?.typicalDepthM;
const depthMax = diving?.maxDepthM;
const depthLabel = depthTypical && depthMax
  ? `obvykle ${depthTypical} m, max ${depthMax} m`
  : depthMax
    ? `až ${depthMax} m`
    : depthTypical
      ? `obvykle ${depthTypical} m`
      : null;

const durTypical = diving?.typicalDurationSec;
const durMax = diving?.maxDurationSec;
const durationLabel = durTypical && durMax
  ? `obvykle ${fmtDuration(durTypical)}, max ${fmtDuration(durMax)}`
  : durMax
    ? `až ${fmtDuration(durMax)}`
    : durTypical
      ? `obvykle ${fmtDuration(durTypical)}`
      : null;
---

<section class="px-6 py-12 bg-muted/50" aria-labelledby="facts-heading">
  <div class="mx-auto max-w-5xl">
    <h2 id="facts-heading" class="text-2xl md:text-3xl font-bold mb-8 reveal">Fakta</h2>
    <dl class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="reveal">
        <dt class="text-xs uppercase tracking-wide text-muted-foreground mb-1">Rod</dt>
        <dd class="text-lg font-semibold italic">{genus}</dd>
      </div>
      <div class="reveal">
        <dt class="text-xs uppercase tracking-wide text-muted-foreground mb-1">Výška</dt>
        <dd class="text-lg font-semibold">{heightLabel}</dd>
      </div>
      <div class="reveal">
        <dt class="text-xs uppercase tracking-wide text-muted-foreground mb-1">Váha</dt>
        <dd class="text-lg font-semibold">{weightLabel}</dd>
      </div>
      <div class="reveal sm:col-span-2">
        <dt class="text-xs uppercase tracking-wide text-muted-foreground mb-1">Habitat</dt>
        <dd class="text-base text-foreground/90">{habitat}</dd>
      </div>
      <div class="reveal">
        <dt class="text-xs uppercase tracking-wide text-muted-foreground mb-1">Délka života</dt>
        <dd class="text-base">
          <span class="font-semibold">{wildLabel}</span>
          <span class="text-muted-foreground"> ve volné přírodě</span>
          {captivityLabel && (
            <>
              <br />
              <span class="font-semibold">{captivityLabel}</span>
              <span class="text-muted-foreground"> v péči lidí</span>
            </>
          )}
        </dd>
      </div>
      <div class="reveal sm:col-span-2 lg:col-span-1">
        <dt class="text-xs uppercase tracking-wide text-muted-foreground mb-1">Rozšíření</dt>
        <dd class="text-base">
          <ul class="list-disc list-inside space-y-0.5 marker:text-primary/60">
            {distribution.map((area) => <li>{area}</li>)}
          </ul>
        </dd>
      </div>
      <div class="reveal sm:col-span-2">
        <dt class="text-xs uppercase tracking-wide text-muted-foreground mb-1">Strava</dt>
        <dd class="text-base">
          <ul class="list-disc list-inside space-y-0.5 marker:text-primary/60">
            {diet.map((item) => <li>{item}</li>)}
          </ul>
        </dd>
      </div>
      {(depthLabel || durationLabel) && (
        <div class="reveal sm:col-span-2 lg:col-span-3">
          <dt class="text-xs uppercase tracking-wide text-muted-foreground mb-1">Potápění</dt>
          <dd class="text-base text-foreground/90">
            {depthLabel && (
              <>
                <span class="font-semibold">Hloubka:</span> <span>{depthLabel}</span>
              </>
            )}
            {depthLabel && durationLabel && <span class="mx-2 text-muted-foreground">·</span>}
            {durationLabel && (
              <>
                <span class="font-semibold">Délka ponoru:</span> <span>{durationLabel}</span>
              </>
            )}
            {diving?.note && (
              <>
                <br />
                <span class="text-sm text-muted-foreground">{diving.note}</span>
              </>
            )}
          </dd>
        </div>
      )}
      {population && (
        <div class="reveal sm:col-span-2 lg:col-span-3">
          <dt class="text-xs uppercase tracking-wide text-muted-foreground mb-1">Populace</dt>
          <dd class="text-base text-foreground/90">{population}</dd>
        </div>
      )}
    </dl>
  </div>
</section>
