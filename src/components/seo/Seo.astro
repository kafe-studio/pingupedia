---
import type { ImageMetadata } from "astro";
interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string | ImageMetadata;
  ignoreTitleTemplate?: boolean;
}

import { getImage } from "astro:assets";
import mascotIcon from "../../assets/mascot/ahoj.png";
import { getSiteConfig } from "../../lib/site";

const siteConfig = await getSiteConfig();
const favicon32 = await getImage({ src: mascotIcon, format: "png", width: 32, height: 32 });
const favicon192 = await getImage({ src: mascotIcon, format: "png", width: 192, height: 192 });
const favicon512 = await getImage({ src: mascotIcon, format: "png", width: 512, height: 512 });
const {
  title,
  description = siteConfig.description,
  canonical,
  ogImage = siteConfig.ogImage,
  ignoreTitleTemplate = false,
} = Astro.props;

const ogImageSrc = typeof ogImage === "string" ? ogImage : ogImage.src;

const fullTitle =
  title && !ignoreTitleTemplate
    ? `${title} | ${siteConfig.name}`
    : title || siteConfig.name;
const canonicalURL =
  canonical ?? new URL(Astro.url.pathname, siteConfig.url).toString();
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link rel="icon" type="image/png" sizes="32x32" href={favicon32.src} />
<link rel="icon" type="image/png" sizes="192x192" href={favicon192.src} />
<link rel="apple-touch-icon" sizes="180x180" href={favicon192.src} />
<link rel="icon" type="image/png" sizes="512x512" href={favicon512.src} />
<link rel="canonical" href={canonicalURL} />
<meta name="generator" content={Astro.generator} />

<title>{fullTitle}</title>
<meta name="title" content={fullTitle} />
<meta name="description" content={description} />
<meta name="author" content={siteConfig.author} />

<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(ogImageSrc, siteConfig.url)} />
<meta property="og:locale" content={siteConfig.locale} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={Astro.url} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL(ogImageSrc, siteConfig.url)} />
{
  siteConfig.twitter && (
    <meta name="twitter:creator" content={siteConfig.twitter} />
  )
}
