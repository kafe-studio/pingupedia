---
import type { CollectionEntry } from "astro:content";

interface Props {
  species: CollectionEntry<"species">[];
}

const { species } = Astro.props;

// Jen druhy s diving daty
const divers = species
  .filter((s) => s.data.diving?.maxDepthM)
  .sort((a, b) => (b.data.diving?.maxDepthM ?? 0) - (a.data.diving?.maxDepthM ?? 0));

const maxDepth = Math.max(...divers.map((s) => s.data.diving?.maxDepthM ?? 0));

function fmtDur(sec: number | undefined): string {
  if (!sec) return "—";
  if (sec < 60) return `${sec} s`;
  const m = Math.floor(sec / 60);
  const s = sec % 60;
  return s === 0 ? `${m} min` : `${m}m ${s}s`;
}
---

<section class="px-4 sm:px-6 py-12 reveal" aria-labelledby="diving-heading">
  <div class="mx-auto max-w-5xl">
    <header class="mb-8">
      <h2 id="diving-heading" class="text-2xl md:text-3xl font-bold mb-2">Hloubka potápění</h2>
      <p class="text-sm text-muted-foreground">
        Typická hloubka (světlejší část) a maximální zaznamenaný ponor (celý sloupec).
        Maximum {maxDepth} m drží <strong class="text-foreground">tučňák císařský</strong> (Wienecke 2007, Atka Bay).
      </p>
    </header>

    <div class="bento-card p-4 md:p-6">
      <ul class="space-y-3" role="list">
        {divers.map((s) => {
          const tDepth = s.data.diving?.typicalDepthM ?? 0;
          const mDepth = s.data.diving?.maxDepthM ?? 0;
          const tPct = (tDepth / maxDepth) * 100;
          const mPct = (mDepth / maxDepth) * 100;
          const dur = s.data.diving?.maxDurationSec;
          return (
            <li class="grid grid-cols-12 items-center gap-3 text-sm">
              <a
                href={`/druhy/${s.id}/`}
                data-astro-prefetch="false"
                class="col-span-12 sm:col-span-3 font-semibold hover:text-primary transition-colors truncate"
              >{s.data.nameCs}</a>
              <div class="col-span-12 sm:col-span-7">
                <div class="flex justify-between text-[11px] text-muted-foreground mb-1">
                  <span>{tDepth ? `obvykle ${tDepth} m` : "—"}</span>
                  <span class="font-mono">max {mDepth} m</span>
                </div>
                <div class="relative h-3 rounded-full bg-muted overflow-hidden">
                  <div class="absolute inset-y-0 left-0 rounded-full bg-cyan-700/60" style={`width:${mPct}%`}></div>
                  <div class="absolute inset-y-0 left-0 rounded-full bg-cyan-400" style={`width:${tPct}%`}></div>
                </div>
              </div>
              <span class="col-span-12 sm:col-span-2 text-right text-xs text-muted-foreground font-mono">{fmtDur(dur)}</span>
            </li>
          );
        })}
      </ul>
    </div>

    <p class="mt-3 text-xs text-muted-foreground flex flex-wrap gap-3">
      <span class="inline-flex items-center gap-1.5">
        <span class="w-3 h-3 rounded-full bg-cyan-400"></span> typická hloubka
      </span>
      <span class="inline-flex items-center gap-1.5">
        <span class="w-3 h-3 rounded-full bg-cyan-700/60"></span> maximální ponor
      </span>
      <span class="ml-auto">vpravo: max délka ponoru</span>
    </p>
  </div>
</section>
