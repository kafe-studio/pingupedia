---
import type { CollectionEntry } from "astro:content";

interface Props {
  species: CollectionEntry<"species">[];
}

const { species } = Astro.props;

// Pořadí kategorií od least concern po extinct (pro vizuální gradient).
const STATUS_ORDER = ["LC", "NT", "VU", "EN", "CR", "DD", "EX"] as const;
type Status = (typeof STATUS_ORDER)[number];

const STATUS_LABEL: Record<Status, string> = {
  LC: "Least Concern (málo dotčený)",
  NT: "Near Threatened (téměř ohrožený)",
  VU: "Vulnerable (zranitelný)",
  EN: "Endangered (ohrožený)",
  CR: "Critically Endangered (kriticky ohrožený)",
  DD: "Data Deficient (nedostatek dat)",
  EX: "Extinct (vyhynulý)",
};

// Barevná škála od zelené (LC) přes žlutou/oranžovou po červenou (CR/EX).
const STATUS_COLOR: Record<Status, string> = {
  LC: "#10b981",
  NT: "#84cc16",
  VU: "#eab308",
  EN: "#f97316",
  CR: "#ef4444",
  DD: "#94a3b8",
  EX: "#7f1d1d",
};

// Spočítej druhy per status + seznam jmen.
const buckets = STATUS_ORDER.map((status) => {
  const list = species.filter((s) => s.data.iucnStatus === status);
  return { status, count: list.length, names: list.map((s) => ({ id: s.id, name: s.data.nameCs })) };
}).filter((b) => b.count > 0);

const total = species.length;

// Donut chart — SVG circle se stroke-dasharray.
const SIZE = 200;
const RADIUS = 80;
const CIRC = 2 * Math.PI * RADIUS;
let cumulative = 0;
const slices = buckets.map((b) => {
  const fraction = b.count / total;
  const dash = fraction * CIRC;
  const offset = cumulative;
  cumulative += dash;
  return {
    ...b,
    dash,
    gap: CIRC - dash,
    offset: -offset,
    color: STATUS_COLOR[b.status],
  };
});
---

<section class="px-4 sm:px-6 py-12 reveal" aria-labelledby="iucn-heading">
  <div class="mx-auto max-w-5xl">
    <header class="mb-8">
      <h2 id="iucn-heading" class="text-2xl md:text-3xl font-bold mb-2">Status ohrožení</h2>
      <p class="text-sm text-muted-foreground">
        Z {total} druhů tučňáků je {buckets.find((b) => b.status === "EN" || b.status === "CR")?.count ?? 0} v kategorii ohrožený nebo kriticky ohrožený podle IUCN Red List.
      </p>
    </header>

    <div class="bento-card p-4 md:p-6 grid grid-cols-1 md:grid-cols-2 gap-6 items-center">
      <div class="flex justify-center">
        <svg viewBox={`0 0 ${SIZE} ${SIZE}`} width={SIZE} height={SIZE} aria-label="Donut chart IUCN statusů">
          <g transform={`translate(${SIZE / 2}, ${SIZE / 2}) rotate(-90)`}>
            {slices.map((s) => (
              <circle
                cx="0"
                cy="0"
                r={RADIUS}
                fill="none"
                stroke={s.color}
                stroke-width="28"
                stroke-dasharray={`${s.dash} ${s.gap}`}
                stroke-dashoffset={s.offset}
              >
                <title>{STATUS_LABEL[s.status]}: {s.count} druhů</title>
              </circle>
            ))}
          </g>
          <text x={SIZE / 2} y={SIZE / 2 - 4} text-anchor="middle" class="fill-foreground" style="font-size: 32px; font-weight: 900;">{total}</text>
          <text x={SIZE / 2} y={SIZE / 2 + 18} text-anchor="middle" class="fill-muted-foreground" style="font-size: 11px;">druhů celkem</text>
        </svg>
      </div>

      <ul class="space-y-2" role="list">
        {buckets.map((b) => (
          <li class="flex items-start gap-3 text-sm">
            <span
              class="shrink-0 mt-1 inline-block w-3 h-3 rounded-sm"
              style={`background:${STATUS_COLOR[b.status]}`}
              aria-hidden="true"
            />
            <div class="min-w-0 flex-1">
              <div class="flex items-baseline justify-between gap-2 flex-wrap">
                <span class="font-semibold">{STATUS_LABEL[b.status]}</span>
                <span class="font-mono text-xs text-muted-foreground">{b.count} / {total}</span>
              </div>
              <div class="text-xs text-muted-foreground mt-0.5">
                {b.names.map((n, i) => (
                  <>
                    {i > 0 && <span>, </span>}
                    <a href={`/druhy/${n.id}/`} data-astro-prefetch="false" class="hover:text-primary transition-colors">{n.name}</a>
                  </>
                ))}
              </div>
            </div>
          </li>
        ))}
      </ul>
    </div>

    <p class="mt-3 text-xs text-muted-foreground">
      Zdroj: IUCN Red List (status z frontmatteru). Kategorie: LC málo dotčený · NT téměř ohrožený · VU zranitelný · EN ohrožený · CR kriticky ohrožený.
    </p>
  </div>
</section>
