---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  alt: string;
  ratio?: string;
  class?: string;
  sizes?: string;
  loading?: "eager" | "lazy";
}

const {
  src,
  alt,
  ratio = "4/3",
  class: className = "",
  sizes,
  loading = "lazy",
} = Astro.props;
---

<div class:list={["nocrop-wrapper", className]} style={`aspect-ratio: ${ratio};`}>
  <Image src={src} alt={alt} sizes={sizes} loading={loading} class="img-nocrop" />
</div>

<style>
  .nocrop-wrapper {
    width: 100%;
    display: block;
  }
</style>
