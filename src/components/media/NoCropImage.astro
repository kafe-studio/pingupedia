---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  alt: string;
  ratio?: string;
  class?: string;
  sizes?: string;
  widths?: number[];
  loading?: "eager" | "lazy";
  fetchpriority?: "high" | "low" | "auto";
}

const {
  src,
  alt,
  ratio = "4/3",
  class: className = "",
  sizes,
  widths = [400, 800],
  loading = "lazy",
  fetchpriority,
} = Astro.props;
---

<div class:list={["nocrop-wrapper", className]} style={`aspect-ratio: ${ratio};`}>
  <Image
    src={src}
    alt={alt}
    sizes={sizes}
    widths={widths}
    loading={loading}
    fetchpriority={fetchpriority}
    format="webp"
    quality={75}
    class="img-nocrop"
  />
</div>

<style>
  .nocrop-wrapper {
    width: 100%;
    display: block;
  }
</style>
