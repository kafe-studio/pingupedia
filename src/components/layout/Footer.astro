---
import { getSiteConfig } from "../../lib/site";
const siteConfig = await getSiteConfig();

const socials = [
  {
    name: "Instagram",
    href: "https://instagram.com/georgeduckling/",
    icon: "M7.5 2h9A5.5 5.5 0 0 1 22 7.5v9a5.5 5.5 0 0 1-5.5 5.5h-9A5.5 5.5 0 0 1 2 16.5v-9A5.5 5.5 0 0 1 7.5 2zm0 2A3.5 3.5 0 0 0 4 7.5v9A3.5 3.5 0 0 0 7.5 20h9a3.5 3.5 0 0 0 3.5-3.5v-9A3.5 3.5 0 0 0 16.5 4h-9zm9.25 1.5a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5zM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10zm0 2a3 3 0 1 0 0 6 3 3 0 0 0 0-6z",
  },
  {
    name: "Facebook",
    href: "https://facebook.com/jirikacirekzhostomic",
    icon: "M13.5 22v-8h2.7l.4-3.1h-3.1V8.9c0-.9.3-1.5 1.6-1.5h1.7V4.6c-.3 0-1.3-.1-2.4-.1-2.4 0-4 1.5-4 4.1v2.3H7.6V14h2.7v8h3.2z",
  },
  {
    name: "LinkedIn",
    href: "https://www.linkedin.com/in/ji%C5%99%C3%AD-ka%C4%8D%C3%ADrek-75073216/",
    icon: "M6.5 8a2 2 0 1 1 0-4 2 2 0 0 1 0 4zM4.5 9.5h4V21h-4V9.5zm6 0h3.8v1.6h.1c.5-1 1.9-2 3.9-2 4.1 0 4.9 2.7 4.9 6.2V21h-4v-5.6c0-1.3 0-3.1-1.9-3.1s-2.2 1.5-2.2 3v5.7h-4V9.5z",
  },
];
---

<footer class="border-t border-border mt-32">
  <div class="mx-auto max-w-7xl px-6 py-12 md:py-16 lg:px-8">
    <div class="grid grid-cols-1 gap-10 md:grid-cols-2">
      <div>
        <p class="text-lg font-bold mb-4">{siteConfig.name}</p>
        <p class="text-sm text-muted-foreground max-w-sm leading-relaxed mb-6">{siteConfig.description}</p>
        <div class="mb-6">
          <h3 class="text-xs font-bold uppercase tracking-widest text-muted-foreground mb-3">Autor</h3>
          <p class="text-sm text-foreground font-semibold">Jiří Kačírek</p>
          <p class="text-sm text-muted-foreground mb-2">studio KaFe</p>
          <ul class="space-y-1.5 text-sm">
            <li>
              <a href="mailto:kacirek.jiri@gmail.com" class="text-foreground/70 hover:text-primary transition-colors">
                kacirek.jiri@gmail.com
              </a>
            </li>
            <li>
              <a href="tel:+420739238874" class="text-foreground/70 hover:text-primary transition-colors">
                +420 739 238 874
              </a>
            </li>
          </ul>
          <p class="mt-4 text-sm font-semibold text-primary">
            Nech to na nás ve Studiu KaFe.
          </p>
        </div>
        <div>
          <h3 class="text-xs font-bold uppercase tracking-widest text-muted-foreground mb-3">Sleduj autora</h3>
          <ul class="flex items-center gap-3">
            {socials.map((s) => (
              <li>
                <a
                  href={s.href}
                  target="_blank"
                  rel="noopener noreferrer me"
                  aria-label={s.name}
                  title={s.name}
                  class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-border text-foreground/70 hover:text-primary hover:border-primary transition-colors"
                >
                  <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true"><path d={s.icon} /></svg>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
      <nav aria-label="Navigace v paticce">
        <h3 class="text-xs font-bold uppercase tracking-widest text-muted-foreground mb-4">Navigace</h3>
        <ul class="space-y-3">
          {siteConfig.navLinks
            .filter((link) => link.href !== "/hledat/")
            .map((link) => (
            <li><a href={link.href} data-astro-prefetch="false" class="text-sm text-foreground/70 hover:text-primary transition-colors">{link.text}</a></li>
          ))}
        </ul>
      </nav>
    </div>
    <div class="mt-12 border-t border-border pt-8 text-center text-xs text-muted-foreground">
      &copy; {new Date().getFullYear()} {siteConfig.author}
    </div>
  </div>
</footer>
