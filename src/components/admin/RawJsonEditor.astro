---
// Sdílený layout pro raw-JSON admin editor (filmy, chovy, timeline).
// Astro page jenom poskytne contentId + popisek + ho mountuje.

interface Props {
  contentId: string;          // např. "page/filmy"
  title: string;              // např. "Filmy"
  description: string;        // krátký popis co se edituje
  schemaHint: string;         // 1 věta o struktuře JSONu (kde najít schema)
  defaultMessagePrefix: string; // commit message default
}

const { contentId, title, description, schemaHint, defaultMessagePrefix } = Astro.props;

const inputCls =
  "w-full rounded-lg border border-border-interactive bg-background px-3 py-2 text-sm focus:outline-none focus:border-primary";
const labelCls = "block text-sm font-semibold mb-1.5";
const sectionCls = "rounded-2xl border border-border bg-card p-6 space-y-4";
const sectionTitleCls = "text-xs uppercase tracking-widest text-primary font-semibold mb-3";
const hintCls = "text-xs text-muted-foreground";
---

<nav class="mb-4 text-sm" aria-label="Drobečková navigace">
  <a href="/admin/texty/" class="text-muted-foreground hover:text-primary transition-colors">← Všechny texty</a>
</nav>

<header class="mb-6">
  <p class="text-xs uppercase tracking-widest text-primary font-semibold mb-2">Raw JSON editor</p>
  <h1 class="text-3xl md:text-4xl font-black tracking-tight">{title}</h1>
  <p class="mt-2 text-muted-foreground max-w-2xl">{description}</p>
  <p class="mt-2 text-xs text-muted-foreground/80">{schemaHint}</p>
</header>

<section id="loading" class="rounded-2xl border border-border bg-card p-10 text-center text-muted-foreground">
  Načítám obsah z GitHub…
</section>

<section id="error" class="hidden rounded-2xl border border-red-400/40 bg-red-500/10 p-6">
  <p class="font-semibold text-red-200">Chyba</p>
  <p id="error-message" class="mt-1 text-sm text-red-100"></p>
</section>

<form id="edit-form" class="hidden space-y-6" data-id={contentId}>
  <input type="hidden" id="file-sha" />

  <section class={sectionCls}>
    <div class="flex items-center justify-between gap-3">
      <p class={sectionTitleCls}>JSON obsah</p>
      <button type="button" id="format-btn" class="btn-outline px-3 py-1 text-xs">Naformátovat</button>
    </div>
    <p class={hintCls}>
      Po Save se klient ujistí, že JSON parsuje, a server zvaliduje proti Zod schématu z <code>src/lib/content-schemas.ts</code>. Při chybě dostaneš detail.
    </p>
    <textarea
      id="json-content"
      required
      rows="30"
      spellcheck="false"
      class={`${inputCls} font-mono text-xs leading-relaxed`}
    ></textarea>
    <div id="inline-error" class="hidden rounded-lg border border-red-400/40 bg-red-500/10 p-3 text-sm">
      <p class="font-semibold text-red-200">Chyba</p>
      <p id="inline-error-message" class="mt-1 text-red-100 font-mono text-xs whitespace-pre-wrap"></p>
    </div>
  </section>

  <section class={sectionCls}>
    <p class={sectionTitleCls}>Commit</p>
    <div>
      <label class={labelCls} for="message">Commit message</label>
      <input
        id="message"
        type="text"
        required
        minlength="5"
        maxlength="100"
        value={defaultMessagePrefix}
        class={inputCls}
      />
    </div>
    <div class="flex items-center justify-between gap-4 pt-2">
      <a href="/admin/texty/" class="btn-outline px-4 py-2 text-sm">Zrušit</a>
      <button type="submit" id="submit-btn" class="btn-primary px-6 py-2.5">Uložit a commit</button>
    </div>
    <div
      id="commit-result"
      class="hidden rounded-lg border border-emerald-400/40 bg-emerald-500/10 p-4 text-sm"
    >
      <p class="font-semibold text-emerald-200">✓ Uloženo</p>
      <p class="mt-1 text-emerald-100">
        Commit: <a id="commit-link" href="#" rel="noopener noreferrer" target="_blank" class="underline"></a>
      </p>
      <p class="mt-1 text-xs text-emerald-100/70">Deploy proběhne automaticky po denním rebuildu (02:30 UTC) nebo po <code>pnpm ship</code>.</p>
    </div>
  </section>
</form>
