---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import Mascot from "../components/mascot/Mascot.astro";
const metadata = {
  title: "Tučňáci odplouli jinam",
  description: "Stránka nenalezena.",
  ignoreTitleTemplate: true,
};
---

<BaseLayout {metadata}>
  <section class="min-h-[70vh] flex items-center justify-center text-center px-6">
    <div class="max-w-xl">
      <div class="anim-float mb-4 inline-block">
        <Mascot pose="otazka" size={160} loading="eager" />
      </div>
      <p class="text-7xl md:text-8xl font-extrabold text-primary mb-6">404</p>
      <p class="text-2xl md:text-3xl font-bold mb-3">Tučňáci odplouli jinam</p>
      <p class="text-muted-foreground mb-10">
        Tuhle stránku jsme nenašli. Možná ji odnesl proud, možná nikdy neexistovala.
      </p>
      <a href="/" class="btn-primary py-3 px-8">Zpět na pevninu</a>
    </div>
  </section>
</BaseLayout>
