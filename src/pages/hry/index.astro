---
export const prerender = true;
import type { ImageMetadata } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Mascot from "../../components/mascot/Mascot.astro";
import NoCropImage from "../../components/media/NoCropImage.astro";
import { getHryPage } from "../../lib/pages";

const page = await getHryPage();

const previews = import.meta.glob("../../assets/games/*.png", {
  eager: true,
  import: "default",
}) as Record<string, ImageMetadata>;
function previewBySlug(slug: string): ImageMetadata | undefined {
  return previews[`../../assets/games/${slug}.png`];
}

const surfaceClass: Record<(typeof page.games)[number]["surface"], string> = {
  aurora: "bento-surface-aurora",
  ocean: "bento-surface-ocean",
  ice: "bento-surface-ice",
  sun: "bento-surface-sun",
  candy: "bento-surface-candy",
  midnight: "bento-surface-midnight",
};

const metadata = {
  title: page.meta.title,
  description: page.meta.description,
};
---

<BaseLayout {metadata}>
  <section class="px-4 sm:px-6 pt-28 pb-16">
    <div class="mx-auto max-w-6xl">
      <header class="mb-8 md:mb-12 max-w-3xl reveal">
        <p class="text-sm uppercase tracking-[0.2em] text-primary/80 mb-4">{page.hero.eyebrow}</p>
        <h1 class="text-5xl md:text-7xl font-black tracking-tight leading-[0.95] mb-4">
          <Fragment set:html={page.hero.titleHtml} />
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground">{page.hero.subtitle}</p>
      </header>

      <div class="grid grid-cols-12 auto-rows-[minmax(220px,auto)] gap-4 md:gap-5">
        {page.games.map((g) => {
          const preview = previewBySlug(g.slug);
          return (
          <article class={`bento-card ${surfaceClass[g.surface]} col-span-12 md:col-span-4 overflow-hidden flex flex-col justify-between text-white min-h-[280px] reveal`}>
            {preview && (
              <a
                href={`/hry/${g.slug}/`}
                data-astro-prefetch
                class="block aspect-video bg-black/30 overflow-hidden"
                aria-label={`Náhled hry ${g.title}`}
              >
                <NoCropImage
                  src={preview}
                  alt={`Náhled hry ${g.title}`}
                  ratio="16/9"
                  sizes="(min-width: 1024px) 360px, (min-width: 768px) 50vw, 100vw"
                  widths={[400, 600, 800]}
                />
              </a>
            )}
            <div class="p-6 flex-1 flex flex-col">
              <div class="flex items-center gap-3 mb-4">
                <Mascot pose={g.mascotPose} size={56} class="shrink-0" />
                <span class="rounded-full bg-white/10 px-3 py-1 text-xs font-semibold text-white/90 backdrop-blur-sm">
                  {g.tag}
                </span>
              </div>
              <h2 class="text-3xl md:text-4xl font-black leading-tight mb-3">{g.title}</h2>
              <p class="text-white/85 text-base leading-relaxed max-w-md flex-1">{g.description}</p>
              <div class="mt-6 flex flex-wrap gap-3">
                <a
                  href={`/hry/${g.slug}/`}
                  class="inline-flex items-center gap-2 rounded-full bg-white text-slate-900 px-5 py-2.5 font-bold hover:bg-white/90 transition-colors"
                  data-astro-prefetch
                >
                  ▶ Spustit hru
                </a>
                <a
                  href={`/hry/${g.slug}/`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 rounded-full border border-white/40 bg-white/10 px-5 py-2.5 font-semibold text-white hover:bg-white/20 transition-colors"
                >
                  Nový panel ↗
                </a>
              </div>
            </div>
          </article>
          );
        })}

        <div class="bento-card col-span-12 p-6 md:p-8 flex flex-col md:flex-row items-center justify-between gap-6 reveal">
          <div class="max-w-xl">
            <p class="text-xs uppercase tracking-widest text-primary font-semibold">{page.cta.eyebrow}</p>
            <h3 class="mt-2 text-2xl md:text-3xl font-black leading-tight">{page.cta.title}</h3>
            <p class="mt-3 text-muted-foreground">{page.cta.description}</p>
          </div>
          <div class="shrink-0 anim-float">
            <Mascot pose="radost" size={130} />
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
