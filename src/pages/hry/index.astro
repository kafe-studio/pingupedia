---
export const prerender = true;
import BaseLayout from "../../layouts/BaseLayout.astro";
import PenguinMascot from "../../components/theme/PenguinMascot.astro";

const games = [
  {
    slug: "kviz",
    title: "Kvíz o tučňácích",
    tag: "5 otázek · 2 min",
    description:
      "Otestuj si, kolik toho víš — od největšího druhu po tajemství císařských samců. Nic nebudeš potřebovat, jen zvědavost.",
    surface: "bento-surface-aurora",
    emoji: "🧠",
  },
  {
    slug: "pexeso",
    title: "Pexeso s tučňáky",
    tag: "8 párů · 16 karet",
    description:
      "Klasické pexeso, ale s fotkami druhů. Přiřaď páry, sleduj čas a tahové skóre. Čím méně tahů, tím lepší paměť.",
    surface: "bento-surface-ocean",
    emoji: "🎴",
  },
  {
    slug: "platformovka",
    title: "Ledová výprava",
    tag: "3 levely · plošinovka",
    description:
      "Plošinovka ve stylu Donkey Kong. Dostaň tučňáka po ledových krách až k opuštěnému mláděti a uhni padajícím ledovým blokům.",
    surface: "bento-surface-ice",
    emoji: "🧗",
  },
  {
    slug: "obrana",
    title: "Ledová obrana",
    tag: "5 vln · upgrady",
    description:
      "Space Invaders styl: tučňák dole střílí sněhové koule na chaluny, tulně a kosatky. Každý level up = volba vylepšení — silnější koule, více střel, rychlejší tempo.",
    surface: "bento-surface-sun",
    emoji: "🎯",
  },
];

const metadata = {
  title: "Hry s tučňáky",
  description:
    "Herna pingupedia — mini-hry o tučňácích. Kvíz, pexeso a další přibývají.",
};
---

<BaseLayout {metadata}>
  <section class="px-4 sm:px-6 pt-28 pb-16">
    <div class="mx-auto max-w-6xl">
      <header class="mb-8 md:mb-12 max-w-3xl reveal">
        <p class="text-sm uppercase tracking-[0.2em] text-primary/80 mb-4">Herna</p>
        <h1 class="text-5xl md:text-7xl font-black tracking-tight leading-[0.95] mb-4">
          Hry<br />s <span class="text-accent">tučňáky</span>
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground">
          Malé on-line hry, které si můžeš pustit rovnou v okně na stránce nebo v novém panelu. Žádné stahování, žádné reklamy.
        </p>
      </header>

      <div class="grid grid-cols-12 auto-rows-[minmax(220px,auto)] gap-4 md:gap-5">
        {games.map((g) => (
          <article class={`bento-card ${g.surface} col-span-12 md:col-span-4 p-6 flex flex-col justify-between text-white min-h-[280px] reveal`}>
            <div>
              <div class="flex items-center gap-3 mb-4">
                <span class="text-4xl" aria-hidden="true">{g.emoji}</span>
                <span class="rounded-full bg-white/10 px-3 py-1 text-xs font-semibold text-white/90 backdrop-blur-sm">
                  {g.tag}
                </span>
              </div>
              <h2 class="text-3xl md:text-4xl font-black leading-tight mb-3">{g.title}</h2>
              <p class="text-white/85 text-base leading-relaxed max-w-md">{g.description}</p>
            </div>
            <div class="mt-6 flex flex-wrap gap-3">
              <button
                type="button"
                data-launch={g.slug}
                data-launch-title={g.title}
                class="inline-flex items-center gap-2 rounded-full bg-white text-slate-900 px-5 py-2.5 font-bold hover:bg-white/90 transition-colors"
              >
                ▶ Spustit v okně
              </button>
              <a
                href={`/hry/${g.slug}/`}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-2 rounded-full border border-white/40 bg-white/10 px-5 py-2.5 font-semibold text-white hover:bg-white/20 transition-colors"
              >
                Otevřít na novém panelu ↗
              </a>
            </div>
          </article>
        ))}

        <div class="bento-card col-span-12 p-6 md:p-8 flex flex-col md:flex-row items-center justify-between gap-6 reveal">
          <div class="max-w-xl">
            <p class="text-xs uppercase tracking-widest text-primary font-semibold">Další hry v přípravě</p>
            <h3 class="mt-2 text-2xl md:text-3xl font-black leading-tight">
              Máš nápad na hru s tučňáky?
            </h3>
            <p class="mt-3 text-muted-foreground">
              Omalovánky, puzzle s mapou kolonií nebo uhodni druh podle siluety — přidávají se postupně.
            </p>
          </div>
          <div class="shrink-0 anim-float">
            <PenguinMascot size={130} />
          </div>
        </div>
      </div>
    </div>
  </section>

  <dialog
    id="game-launcher"
    class="game-launcher"
    aria-label="Herní okno"
  >
    <div class="game-launcher__bar">
      <span class="game-launcher__title" data-launcher-title>Hra</span>
      <div class="game-launcher__actions">
        <a
          data-launcher-external
          href="/hry/"
          target="_blank"
          rel="noopener"
          class="game-launcher__btn"
          title="Otevřít na novém panelu"
        >↗</a>
        <button
          type="button"
          data-launcher-close
          class="game-launcher__btn"
          aria-label="Zavřít hru"
        >×</button>
      </div>
    </div>
    <iframe
      data-launcher-frame
      title="Herní okno"
      class="game-launcher__frame"
      loading="lazy"
    ></iframe>
  </dialog>
</BaseLayout>

<style>
  .game-launcher {
    max-width: 100vw;
    max-height: 100vh;
    width: min(100vw, 1100px);
    height: min(100vh, 800px);
    padding: 0;
    margin: auto;
    border: none;
    border-radius: 1.25rem;
    background: var(--background);
    color: var(--foreground);
    overflow: hidden;
  }
  .game-launcher::backdrop {
    background: rgba(6, 17, 31, 0.85);
    backdrop-filter: blur(8px);
  }
  .game-launcher__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
    background: var(--muted);
  }
  .game-launcher__title {
    font-weight: 700;
    font-size: 0.95rem;
  }
  .game-launcher__actions { display: flex; gap: 0.5rem; }
  .game-launcher__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 9999px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--foreground);
    font-size: 1.1rem;
    line-height: 1;
    cursor: pointer;
    text-decoration: none;
  }
  .game-launcher__btn:hover {
    border-color: var(--primary);
    color: var(--primary);
  }
  .game-launcher__frame {
    width: 100%;
    height: calc(100% - 3.25rem);
    border: none;
    background: var(--background);
  }
</style>

<script>
  const dialog = document.getElementById("game-launcher") as HTMLDialogElement | null;
  if (dialog) {
    const frame = dialog.querySelector<HTMLIFrameElement>("[data-launcher-frame]")!;
    const titleEl = dialog.querySelector<HTMLElement>("[data-launcher-title]")!;
    const external = dialog.querySelector<HTMLAnchorElement>("[data-launcher-external]")!;
    const closeBtn = dialog.querySelector<HTMLButtonElement>("[data-launcher-close]")!;

    document.querySelectorAll<HTMLButtonElement>("[data-launch]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const slug = btn.dataset.launch;
        const title = btn.dataset.launchTitle || "Hra";
        if (!slug) return;
        const url = `/hry/${slug}/`;
        frame.src = url;
        external.href = url;
        titleEl.textContent = title;
        dialog.showModal();
      });
    });

    closeBtn.addEventListener("click", () => {
      dialog.close();
    });

    dialog.addEventListener("close", () => {
      frame.src = "about:blank";
    });

    dialog.addEventListener("click", (e) => {
      if (e.target === dialog) dialog.close();
    });
  }
</script>
