---
export const prerender = true;
import GameLayout from "../../layouts/GameLayout.astro";
import HallOfFame from "../../components/games/HallOfFame.astro";
import HofPrompt from "../../components/games/HofPrompt.astro";
import { getImage } from "astro:assets";
import { getCollection } from "astro:content";
import type { PuzzleImage } from "../../lib/games/puzzle/types";

const species = await getCollection("species");

// Build manifest: every gallery photo across every species, optimized to webp 1280w.
const manifest: PuzzleImage[] = [];
for (const entry of species) {
  const gallery = entry.data.gallery ?? [];
  for (const g of gallery) {
    try {
      const opt = await getImage({ src: g.src, width: 1280, format: "webp" });
      manifest.push({
        src: opt.src,
        alt: g.alt,
        speciesName: entry.data.nameCs,
        speciesSlug: entry.id,
        author: g.author,
        license: g.license,
      });
    } catch {
      // skip broken image
    }
  }
}

const manifestJson = JSON.stringify(manifest);
---

<GameLayout title="Puzzle" description="Skládačka z náhodné fotky tučňáků. 50+ dílků, přes celou obrazovku.">
  <div id="puzzle-hud" class="fixed top-0 inset-x-0 z-40 h-[60px] px-4 flex items-center justify-between gap-3 bg-card/80 backdrop-blur-md border-b border-border">
    <div class="flex items-center gap-3 text-sm">
      <span class="hidden sm:inline text-muted-foreground">Puzzle:</span>
      <span data-hud-species class="font-bold truncate max-w-[180px] sm:max-w-[260px]">—</span>
      <span class="text-xs text-muted-foreground truncate max-w-[140px] hidden md:inline" data-hud-credit></span>
    </div>
    <div class="flex items-center gap-2 text-xs">
      <label class="flex items-center gap-1.5">
        <span class="hidden md:inline text-muted-foreground">Obtížnost:</span>
        <select data-select-difficulty class="rounded-full border border-border bg-background px-2.5 py-1.5 text-[11px] font-medium focus:outline-none focus:border-primary">
          <option value="easy">Lehká (~36)</option>
          <option value="medium">Střední (~56)</option>
          <option value="hard">Těžká (~96)</option>
        </select>
      </label>
      <span class="hidden sm:inline text-muted-foreground">Hotovo:</span>
      <span><strong data-hud-placed class="text-foreground">0</strong> / <strong data-hud-total>—</strong></span>
      <button data-btn-peek type="button" class="rounded-full border border-border px-3 py-1.5 text-[11px] font-medium hover:border-border-interactive">👁 Náhled</button>
      <button data-btn-scatter type="button" class="rounded-full border border-border px-3 py-1.5 text-[11px] font-medium hover:border-border-interactive">🔀 Rozstrkat</button>
      <button data-btn-music type="button" class="rounded-full border border-border px-3 py-1.5 text-[11px] font-medium hover:border-border-interactive" aria-pressed="false" title="Relaxační hudba">🔇 Hudba</button>
      <button data-btn-new type="button" class="rounded-full bg-primary text-primary-foreground px-3 py-1.5 text-[11px] font-bold">🎲 Nová hra</button>
    </div>
  </div>

  <canvas id="puzzle-canvas" class="fixed inset-0 w-full h-full touch-none" style="touch-action:none;"></canvas>

  <div
    id="puzzle-done"
    class="fixed inset-0 z-50 hidden flex-col items-center justify-center gap-4 overflow-y-auto bg-black/70 backdrop-blur-sm p-6 text-center"
  >
    <h2 class="text-3xl md:text-5xl font-black text-white">🎉 Složeno!</h2>
    <p class="text-white/80" data-done-msg></p>
    <div class="flex gap-3 mt-2">
      <button data-done-again type="button" class="rounded-full bg-white text-slate-900 px-5 py-2.5 text-sm font-bold">Jiný obrázek</button>
      <a href="/hry/" class="rounded-full border border-white/40 text-white px-5 py-2.5 text-sm font-bold">Zpět do herny</a>
    </div>
    <div class="w-full max-w-md text-left">
      <HallOfFame gameId="puzzle" valueLabel="Čas" valueFormat="time" sort="asc" />
    </div>
  </div>
  <HofPrompt />

  <script is:inline define:vars={{ manifestJson }}>
    window.__PUZZLE_MANIFEST__ = JSON.parse(manifestJson);
  </script>
  <script>
    import { PuzzleGame } from "../../lib/games/puzzle/engine";
    import type { Difficulty, PuzzleImage } from "../../lib/games/puzzle/types";

    const manifest: PuzzleImage[] = (window as unknown as { __PUZZLE_MANIFEST__: PuzzleImage[] }).__PUZZLE_MANIFEST__ ?? [];
    if (manifest.length === 0) throw new Error("puzzle manifest empty");

    const canvas = document.getElementById("puzzle-canvas") as HTMLCanvasElement;
    const hudSpecies = document.querySelector<HTMLElement>("[data-hud-species]")!;
    const hudCredit = document.querySelector<HTMLElement>("[data-hud-credit]")!;
    const hudPlaced = document.querySelector<HTMLElement>("[data-hud-placed]")!;
    const hudTotal = document.querySelector<HTMLElement>("[data-hud-total]")!;
    const btnPeek = document.querySelector<HTMLButtonElement>("[data-btn-peek]")!;
    const btnScatter = document.querySelector<HTMLButtonElement>("[data-btn-scatter]")!;
    const btnNew = document.querySelector<HTMLButtonElement>("[data-btn-new]")!;
    const selDifficulty = document.querySelector("[data-select-difficulty]") as unknown as HTMLSelectElement;
    const doneBox = document.getElementById("puzzle-done")!;
    const doneMsg = doneBox.querySelector<HTMLElement>("[data-done-msg]")!;
    const doneAgain = doneBox.querySelector<HTMLButtonElement>("[data-done-again]")!;

    const STORAGE_KEY = "pingupedia-puzzle-difficulty";
    const VALID: Difficulty[] = ["easy", "medium", "hard"];

    function loadDifficulty(): Difficulty {
      try {
        const saved = localStorage.getItem(STORAGE_KEY);
        if (saved && VALID.includes(saved as Difficulty)) return saved as Difficulty;
      } catch { /* ignore */ }
      return "medium";
    }

    function saveDifficulty(d: Difficulty): void {
      try { localStorage.setItem(STORAGE_KEY, d); } catch { /* ignore */ }
    }

    let currentDifficulty: Difficulty = loadDifficulty();
    selDifficulty.value = currentDifficulty;

    let game: PuzzleGame | null = null;

    function showDone(show: boolean): void {
      doneBox.classList.toggle("hidden", !show);
      doneBox.classList.toggle("flex", show);
    }

    async function loadImage(src: string): Promise<HTMLImageElement> {
      return new Promise((resolve, reject) => {
        const img = new Image();
        img.onload = () => resolve(img);
        img.onerror = reject;
        img.src = src;
      });
    }

    async function start(): Promise<void> {
      if (game) game.destroy();
      showDone(false);
      const meta = manifest[Math.floor(Math.random() * manifest.length)];
      const image = await loadImage(meta.src);
      game = new PuzzleGame(canvas, image, meta, {
        onProgress(placed, total) {
          hudPlaced.textContent = String(placed);
          hudTotal.textContent = String(total);
        },
        onImage(m) {
          hudSpecies.textContent = m.speciesName;
          hudCredit.textContent = `Foto: ${m.author} · ${m.license}`;
        },
        onComplete(elapsed) {
          const mm = Math.floor(elapsed / 60).toString().padStart(2, "0");
          const ss = (elapsed % 60).toString().padStart(2, "0");
          doneMsg.textContent = `Čas: ${mm}:${ss}  ·  ${meta.speciesName}  ·  ${currentDifficulty}`;
          showDone(true);
          window.openHofPrompt?.({
            gameId: "puzzle",
            value: elapsed,
            meta: `${meta.speciesName} · ${currentDifficulty}`,
            valueLabel: "Čas",
            valueFormat: "time",
            sort: "asc",
          });
        },
      }, currentDifficulty);
    }

    btnPeek.addEventListener("click", () => game?.peek(1500));
    btnScatter.addEventListener("click", () => game?.reshuffleUnplaced());
    btnNew.addEventListener("click", () => { void start(); });

    const btnMusic = document.querySelector<HTMLButtonElement>("[data-btn-music]");
    if (btnMusic) {
      const { RelaxingMusic } = await import("../../lib/games/relaxing-music");
      const music = new RelaxingMusic();
      btnMusic.addEventListener("click", () => {
        if (music.isPlaying()) {
          music.stop();
          btnMusic.textContent = "🔇 Hudba";
          btnMusic.setAttribute("aria-pressed", "false");
        } else {
          const ok = music.start();
          if (ok) {
            btnMusic.textContent = "🔊 Hudba";
            btnMusic.setAttribute("aria-pressed", "true");
          }
        }
      });
      window.addEventListener("beforeunload", () => music.destroy());
    }
    doneAgain.addEventListener("click", () => { void start(); });
    selDifficulty.addEventListener("change", () => {
      const v = selDifficulty.value as Difficulty;
      if (!VALID.includes(v)) return;
      currentDifficulty = v;
      saveDifficulty(v);
      void start();
    });

    void start();
  </script>
</GameLayout>
