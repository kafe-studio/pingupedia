---
export const prerender = true;
import GameLayout from "../../layouts/GameLayout.astro";
---

<GameLayout title="Ledová výprava" description="Jet Set Willy v Antarktidě — 40 místností, sbírej ryby, vejce, medaile, vlajky a krystaly.">
  <div class="mx-auto max-w-3xl px-4 pt-14 pb-8">
    <header class="mb-4 text-center">
      <p class="text-[11px] uppercase tracking-[0.2em] text-primary mb-1.5">Mini-hra · Jet Set Pingu</p>
      <h1 class="text-2xl md:text-3xl font-black mb-1.5">Ledová výprava</h1>
      <p class="text-sm text-muted-foreground max-w-xl mx-auto">
        40 propojených místností. Seber všechno (rybky, vejce, medaile, vlajky, krystaly) a vrať se do iglú.
      </p>
    </header>

    <div class="bento-card p-3 md:p-4">
      <div class="mb-3 flex flex-wrap items-center justify-between gap-3 text-xs">
        <div class="flex flex-wrap gap-4 text-muted-foreground">
          <span>Místnost: <strong data-hud-room class="text-foreground">—</strong></span>
          <span>Životy: <strong data-hud-lives class="text-foreground">♥♥♥</strong></span>
          <span>Sebráno: <strong data-hud-items class="text-foreground">0 / 0</strong></span>
          <span>Mláďata: <strong data-hud-chicks class="text-foreground">0 → 0</strong></span>
          <span>Skóre: <strong data-hud-score class="text-foreground">0</strong></span>
        </div>
        <div class="flex gap-2">
          <button data-music type="button" class="rounded-full border border-border px-3 py-1 text-[11px] hover:border-border-interactive" aria-pressed="false" title="8-bit hudba (Korobeiniki)">
            🔇 Hudba
          </button>
          <button data-restart type="button" class="rounded-full border border-border px-3 py-1 text-[11px] hover:border-border-interactive">
            Restart
          </button>
        </div>
      </div>

      <div
        class="relative mx-auto aspect-[20/14] bg-[#06111f] rounded-xl border border-border overflow-hidden"
      >
        <canvas
          id="platform-canvas"
          class="block w-full h-full"
          tabindex="0"
          aria-label="Ledová výprava — Jet Set Pingu"
        ></canvas>
        <div
          id="platform-hint"
          class="absolute left-1/2 bottom-3 -translate-x-1/2 hidden max-w-[90%] text-center text-[11px] md:text-xs px-3 py-1.5 rounded-full bg-black/70 text-white backdrop-blur-sm"
        ></div>
        <div
          id="platform-overlay"
          class="absolute inset-0 hidden flex-col items-center justify-center gap-3 rounded-xl bg-black/75 text-white backdrop-blur-sm p-4 text-center"
        >
          <h2 data-overlay-title class="text-2xl md:text-3xl font-black"></h2>
          <p data-overlay-msg class="text-sm text-white/80"></p>
          <button
            data-overlay-btn
            type="button"
            class="rounded-full bg-white text-slate-900 px-5 py-2 text-sm font-bold"
          >
            Pokračovat
          </button>
        </div>

        <!-- Mini-game overlay (ski / hockey / jump / dive) -->
        <div
          id="minigame-overlay"
          class="absolute inset-0 hidden flex-col items-stretch bg-slate-950/95 rounded-xl"
        >
          <div class="flex items-center justify-between gap-3 px-3 py-2 bg-slate-900/80 border-b border-white/10">
            <h3 data-mg-title class="text-sm md:text-base font-black text-white">Mini-hra</h3>
            <button data-mg-close type="button" class="rounded-full border border-white/30 text-white px-3 py-1 text-[11px] font-medium hover:bg-white/10">
              Ukončit
            </button>
          </div>
          <div class="flex-1 relative">
            <canvas id="minigame-canvas" class="absolute inset-0 w-full h-full block" tabindex="0"></canvas>
          </div>
          <div data-mg-result class="hidden flex-col items-center justify-center gap-2 absolute inset-0 bg-black/70 backdrop-blur-sm p-4 text-center text-white">
            <p data-mg-result-icon class="text-4xl">🏆</p>
            <p data-mg-result-text class="text-base md:text-lg font-bold"></p>
            <p data-mg-result-reward class="text-sm text-amber-300"></p>
            <button data-mg-result-btn type="button" class="mt-2 rounded-full bg-white text-slate-900 px-5 py-2 text-sm font-bold">
              Vrátit se do hry
            </button>
          </div>
        </div>
      </div>

      <div class="mt-3 grid grid-cols-2 gap-2 text-[11px] text-muted-foreground">
        <div>← → pohyb</div>
        <div>↑ ↓ žebřík</div>
        <div>mezera = skok</div>
        <div>CTRL = mega-skok</div>
        <div>↓ = seskok z plošiny</div>
        <div>X = klovnout pod sebou</div>
        <div>R = restart</div>
      </div>

      <div class="mt-4 grid grid-cols-3 gap-2 md:hidden">
        <button data-mobile="left" type="button" class="rounded-lg border border-border bg-muted/30 py-3 font-bold">←</button>
        <button data-mobile="jump" type="button" class="rounded-lg border border-border bg-muted/30 py-3 font-bold">↑ skok</button>
        <button data-mobile="right" type="button" class="rounded-lg border border-border bg-muted/30 py-3 font-bold">→</button>
        <button data-mobile="up" type="button" class="rounded-lg border border-border bg-muted/30 py-3 font-bold">↑ žebřík</button>
        <button data-mobile-peck type="button" class="rounded-lg border border-border bg-muted/30 py-3 font-bold">⛏ klovnout</button>
        <button data-mobile="down" type="button" class="rounded-lg border border-border bg-muted/30 py-3 font-bold">↓ žebřík</button>
      </div>
    </div>
  </div>
</GameLayout>

<script>
  import { PlatformGame } from "../../lib/games/platform/engine";
  import { ChiptuneMusic } from "../../lib/games/platform/music";
  import { SfxPlayer } from "../../lib/games/platform/sfx";
  import { startMinigame, type MinigameInstance } from "../../lib/games/platform/minigames";
  import { MINIGAME_TITLE, type GameHud, type MinigameKind } from "../../lib/games/platform/types";

  const canvas = document.getElementById("platform-canvas") as HTMLCanvasElement | null;
  if (!canvas) throw new Error("platform canvas missing");

  const overlay = document.getElementById("platform-overlay")!;
  const overlayTitle = overlay.querySelector<HTMLElement>("[data-overlay-title]")!;
  const overlayMsg = overlay.querySelector<HTMLElement>("[data-overlay-msg]")!;
  const overlayBtn = overlay.querySelector<HTMLButtonElement>("[data-overlay-btn]")!;
  const hintBox = document.getElementById("platform-hint")!;
  const hudRoom = document.querySelector<HTMLElement>("[data-hud-room]")!;
  const hudLives = document.querySelector<HTMLElement>("[data-hud-lives]")!;
  const hudItems = document.querySelector<HTMLElement>("[data-hud-items]")!;
  const hudChicks = document.querySelector<HTMLElement>("[data-hud-chicks]")!;
  const hudScore = document.querySelector<HTMLElement>("[data-hud-score]")!;
  const restartBtn = document.querySelector<HTMLButtonElement>("[data-restart]")!;

  let game: PlatformGame | null = null;

  function showOverlay(title: string, msg: string, btn: string, onClick: () => void): void {
    overlayTitle.textContent = title;
    overlayMsg.textContent = msg;
    overlayBtn.textContent = btn;
    overlay.classList.remove("hidden");
    overlay.classList.add("flex");
    overlayBtn.onclick = () => {
      overlay.classList.add("hidden");
      overlay.classList.remove("flex");
      onClick();
    };
  }

  function renderHud(h: GameHud): void {
    const keyChar: Record<string, string> = { blue: "🔵", red: "🔴", yellow: "🟡", green: "🟢" };
    const keys = h.keys.map((k) => keyChar[k] ?? "🔑").join("");
    hudRoom.textContent = `${h.roomIndex}/${h.totalRooms} · ${h.roomName}${keys ? "  " + keys : ""}`;
    hudLives.textContent = "♥".repeat(Math.max(0, h.lives)) || "—";
    hudItems.textContent = `${h.collected} / ${h.total}`;
    hudChicks.textContent = `${h.chicksFollowing} → ${h.chicksDelivered}`;
    hudScore.textContent = String(h.score);
    if (h.hint) {
      hintBox.textContent = h.hint;
      hintBox.classList.remove("hidden");
    } else {
      hintBox.classList.add("hidden");
    }
  }

  restartBtn.addEventListener("click", () => game?.restart());

  const musicBtn = document.querySelector<HTMLButtonElement>("[data-music]")!;
  const music = new ChiptuneMusic();
  musicBtn.addEventListener("click", () => {
    if (music.isPlaying()) {
      music.stop();
      musicBtn.textContent = "🔇 Hudba";
      musicBtn.setAttribute("aria-pressed", "false");
    } else {
      const ok = music.start();
      if (ok) {
        musicBtn.textContent = "🔊 Hudba";
        musicBtn.setAttribute("aria-pressed", "true");
      }
    }
  });

  const peckBtn = document.querySelector<HTMLButtonElement>("[data-mobile-peck]");
  if (peckBtn) {
    const fire = (e: Event) => { e.preventDefault(); game?.peck(); };
    peckBtn.addEventListener("touchstart", fire, { passive: false });
    peckBtn.addEventListener("mousedown", fire);
  }

  document.querySelectorAll<HTMLButtonElement>("[data-mobile]").forEach((btn) => {
    const dir = btn.dataset.mobile;
    const map: Record<string, "left" | "right" | "up" | "down" | "jump"> = {
      left: "left", right: "right", up: "up", down: "down", jump: "jump",
    };
    const key = dir && map[dir];
    if (!key) return;
    const start = (e: Event) => {
      e.preventDefault();
      game?.setKey(key, true);
    };
    const end = () => game?.setKey(key, false);
    btn.addEventListener("touchstart", start, { passive: false });
    btn.addEventListener("touchend", end);
    btn.addEventListener("mousedown", start);
    btn.addEventListener("mouseup", end);
    btn.addEventListener("mouseleave", end);
  });

  window.addEventListener("keydown", (e) => {
    if (e.key === "r" || e.key === "R") game?.restart();
  });

  const sfx = new SfxPlayer();

  // Mini-game overlay
  const mgOverlay = document.getElementById("minigame-overlay")!;
  const mgCanvas = document.getElementById("minigame-canvas") as HTMLCanvasElement;
  const mgTitle = mgOverlay.querySelector<HTMLElement>("[data-mg-title]")!;
  const mgClose = mgOverlay.querySelector<HTMLButtonElement>("[data-mg-close]")!;
  const mgResult = mgOverlay.querySelector<HTMLElement>("[data-mg-result]")!;
  const mgResultIcon = mgOverlay.querySelector<HTMLElement>("[data-mg-result-icon]")!;
  const mgResultText = mgOverlay.querySelector<HTMLElement>("[data-mg-result-text]")!;
  const mgResultReward = mgOverlay.querySelector<HTMLElement>("[data-mg-result-reward]")!;
  const mgResultBtn = mgOverlay.querySelector<HTMLButtonElement>("[data-mg-result-btn]")!;
  let mgInstance: MinigameInstance | null = null;
  let mgDoorId: string | null = null;

  function endMinigame(): void {
    if (mgInstance) { mgInstance.destroy(); mgInstance = null; }
    mgOverlay.classList.add("hidden");
    mgOverlay.classList.remove("flex");
    mgResult.classList.add("hidden");
    mgResult.classList.remove("flex");
    if (game && mgDoorId) game.resumeAfterMinigame(mgDoorId);
    mgDoorId = null;
  }

  function startMinigameOverlay(kind: MinigameKind, doorId: string): void {
    mgDoorId = doorId;
    mgOverlay.classList.remove("hidden");
    mgOverlay.classList.add("flex");
    mgTitle.textContent = MINIGAME_TITLE[kind];
    mgResult.classList.add("hidden");
    mgResult.classList.remove("flex");
    mgInstance = startMinigame({
      canvas: mgCanvas,
      kind,
      onFinish(score, label) {
        mgResultIcon.textContent = score > 0 ? "🏆" : "🎯";
        mgResultText.textContent = label;
        mgResultReward.textContent = `+${score} bodů (a klíč otevřel dveře)`;
        mgResult.classList.remove("hidden");
        mgResult.classList.add("flex");
      },
      onClose() { endMinigame(); },
    });
    mgCanvas.focus();
  }

  mgClose.addEventListener("click", () => endMinigame());
  mgResultBtn.addEventListener("click", () => endMinigame());

  game = new PlatformGame(canvas, {
    onHud: renderHud,
    onSfx: (kind) => sfx.play(kind),
    onMinigame: (kind, doorId) => startMinigameOverlay(kind, doorId),
    onWin(timeSec) {
      const mm = Math.floor(timeSec / 60).toString().padStart(2, "0");
      const ss = (timeSec % 60).toString().padStart(2, "0");
      showOverlay("🎉 Výprava hotová!", `Všech sbírek doneseno do iglú. Čas: ${mm}:${ss}.`, "Hrát znovu", () => game?.restart());
    },
    onGameover() {
      showOverlay("Game over", "Doletěla jsi až na konec — ale bez životů. Znovu?", "Restart", () => game?.restart());
    },
  });
  canvas.focus();
</script>
