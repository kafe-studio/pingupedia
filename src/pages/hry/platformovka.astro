---
export const prerender = true;
import GameLayout from "../../layouts/GameLayout.astro";
---

<GameLayout title="Ledová výprava" description="Plošinovka s tučňákem ve stylu Donkey Kong.">
  <div class="mx-auto max-w-xl px-4 pt-14 pb-8">
    <header class="mb-4 text-center">
      <p class="text-[11px] uppercase tracking-[0.2em] text-primary mb-1.5">Mini-hra</p>
      <h1 class="text-2xl md:text-3xl font-black mb-1.5">Ledová výprava</h1>
      <p class="text-sm text-muted-foreground">
        Dostaň tučňáka nahoru k opuštěnému mláděti. Uhni padajícím ledovým krám.
      </p>
    </header>

    <div class="bento-card p-3 md:p-4">
      <div class="mb-3 flex items-center justify-between gap-3 text-xs">
        <div class="flex gap-4 text-muted-foreground">
          <span>Level <strong data-hud-level class="text-foreground">1</strong></span>
          <span>Životy <strong data-hud-lives class="text-foreground">♥♥♥</strong></span>
          <span>Skóre <strong data-hud-score class="text-foreground">0</strong></span>
        </div>
        <button data-restart type="button" class="rounded-full border border-border px-3 py-1 text-[11px] hover:border-border-interactive">
          Restart
        </button>
      </div>
      <div class="relative mx-auto" style="width: 400px; max-width: 100%;">
        <canvas
          id="platform-canvas"
          width="400"
          height="600"
          class="block w-full rounded-xl border border-border bg-[#06111f]"
          style="max-width: 100%; height: auto; image-rendering: pixelated;"
          tabindex="0"
          aria-label="Herní plocha plošinovky"
        ></canvas>
        <div
          id="platform-overlay"
          class="absolute inset-0 hidden flex-col items-center justify-center gap-3 rounded-xl bg-black/70 text-white backdrop-blur-sm"
        >
          <h2 data-overlay-title class="text-2xl font-black"></h2>
          <p data-overlay-msg class="text-sm text-white/80 text-center px-4"></p>
          <button
            data-overlay-btn
            type="button"
            class="rounded-full bg-white text-slate-900 px-5 py-2 text-sm font-bold"
          >
            Pokračovat
          </button>
        </div>
      </div>
      <div class="mt-3 grid grid-cols-2 gap-2 text-[11px] text-muted-foreground">
        <div>← → pohyb</div>
        <div>↑ ↓ žebřík</div>
        <div>mezera = skok</div>
        <div>R = restart</div>
      </div>

      <div class="mt-4 grid grid-cols-3 gap-2 md:hidden">
        <button data-mobile="left" type="button" class="rounded-lg border border-border bg-muted/30 py-3 font-bold">←</button>
        <button data-mobile="jump" type="button" class="rounded-lg border border-border bg-muted/30 py-3 font-bold">↑ skok</button>
        <button data-mobile="right" type="button" class="rounded-lg border border-border bg-muted/30 py-3 font-bold">→</button>
        <button data-mobile="up" type="button" class="rounded-lg border border-border bg-muted/30 py-3 font-bold">↑ žebřík</button>
        <span></span>
        <button data-mobile="down" type="button" class="rounded-lg border border-border bg-muted/30 py-3 font-bold">↓ žebřík</button>
      </div>
    </div>
  </div>
</GameLayout>

<script>
  import { Game, type GameStatus } from "../../lib/games/platform/engine";

  const canvas = document.getElementById("platform-canvas") as HTMLCanvasElement | null;
  const overlay = document.getElementById("platform-overlay")!;
  const overlayTitle = overlay.querySelector<HTMLElement>("[data-overlay-title]")!;
  const overlayMsg = overlay.querySelector<HTMLElement>("[data-overlay-msg]")!;
  const overlayBtn = overlay.querySelector<HTMLButtonElement>("[data-overlay-btn]")!;
  const hudLevel = document.querySelector<HTMLElement>("[data-hud-level]")!;
  const hudLives = document.querySelector<HTMLElement>("[data-hud-lives]")!;
  const hudScore = document.querySelector<HTMLElement>("[data-hud-score]")!;
  const restartBtn = document.querySelector<HTMLButtonElement>("[data-restart]")!;

  if (!canvas) throw new Error("platform canvas missing");

  let game: Game | null = null;

  function showOverlay(title: string, msg: string, btn: string): void {
    overlayTitle.textContent = title;
    overlayMsg.textContent = msg;
    overlayBtn.textContent = btn;
    overlay.classList.remove("hidden");
    overlay.classList.add("flex");
  }

  function hideOverlay(): void {
    overlay.classList.add("hidden");
    overlay.classList.remove("flex");
  }

  function handleStatus(status: GameStatus): void {
    if (status === "playing") hideOverlay();
    else if (status === "levelDone") {
      showOverlay("Mládě zachráněno! 🎉", "Další level je rychlejší. Připraven?", "Další level →");
    } else if (status === "win") {
      showOverlay("Všechny levely hotové!", "Tučňák zachránil všechna ztracená mláďata. Gratuluji!", "Hrát od začátku");
    } else if (status === "gameover") {
      showOverlay("Game over", "Ledový blok tě trefil moc často. Zkusíš to znovu?", "Znovu");
    }
  }

  overlayBtn.addEventListener("click", () => {
    if (!game) return;
    if (overlayTitle.textContent?.includes("Mládě")) game.nextLevel();
    else game.restart();
  });

  restartBtn.addEventListener("click", () => game?.restart());

  function emitKey(key: string, type: "keydown" | "keyup"): void {
    window.dispatchEvent(new KeyboardEvent(type, { key }));
  }

  document.querySelectorAll<HTMLButtonElement>("[data-mobile]").forEach((btn) => {
    const dir = btn.dataset.mobile;
    const map: Record<string, string> = {
      left: "ArrowLeft",
      right: "ArrowRight",
      up: "ArrowUp",
      down: "ArrowDown",
      jump: " ",
    };
    const key = dir && map[dir];
    if (!key) return;
    const start = (e: Event) => {
      e.preventDefault();
      emitKey(key, "keydown");
    };
    const end = () => emitKey(key, "keyup");
    btn.addEventListener("touchstart", start, { passive: false });
    btn.addEventListener("touchend", end);
    btn.addEventListener("mousedown", start);
    btn.addEventListener("mouseup", end);
    btn.addEventListener("mouseleave", end);
  });

  window.addEventListener("keydown", (e) => {
    if (e.key === "r" || e.key === "R") game?.restart();
  });

  game = new Game(canvas, {
    onStatus: handleStatus,
    onHud: ({ level, lives, score }) => {
      hudLevel.textContent = String(level);
      hudLives.textContent = "♥".repeat(Math.max(0, lives)) || "—";
      hudScore.textContent = String(score);
    },
  });
  canvas.focus();
</script>
