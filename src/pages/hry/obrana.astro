---
export const prerender = true;
import GameLayout from "../../layouts/GameLayout.astro";
---

<GameLayout title="Ledová obrana" description="Tučňák střílí sněhové koule na blížící se nepřátele — Space Invaders styl.">
  <div class="mx-auto max-w-xl px-4 pt-14 pb-8">
    <header class="mb-4 text-center">
      <p class="text-[11px] uppercase tracking-[0.2em] text-primary mb-1.5">Mini-hra</p>
      <h1 class="text-2xl md:text-3xl font-black mb-1.5">Ledová obrana</h1>
      <p class="text-sm text-muted-foreground">
        Chraň kolonii před chalunami, tuleni a kosatkami. Za zabité nepřátele získáváš XP a vylepšení.
      </p>
    </header>

    <div class="bento-card p-3 md:p-4">
      <div class="mb-2 flex items-center justify-between gap-3 text-xs">
        <div class="flex flex-wrap gap-3 text-muted-foreground">
          <span>Vlna <strong data-hud-wave class="text-foreground">1</strong>/<strong data-hud-max>5</strong></span>
          <span>Level <strong data-hud-level class="text-foreground">1</strong></span>
          <span>Skóre <strong data-hud-score class="text-foreground">0</strong></span>
        </div>
        <button data-restart type="button" class="rounded-full border border-border px-3 py-1 text-[11px] hover:border-border-interactive">
          Restart
        </button>
      </div>

      <div class="mb-2 grid grid-cols-2 gap-2">
        <div>
          <p class="text-[10px] uppercase tracking-widest text-muted-foreground mb-1">Zdraví</p>
          <div class="h-2 rounded-full bg-muted overflow-hidden">
            <div data-hud-hp class="h-full bg-emerald-500 transition-[width]" style="width:100%"></div>
          </div>
        </div>
        <div>
          <p class="text-[10px] uppercase tracking-widest text-muted-foreground mb-1">XP do dalšího levelu</p>
          <div class="h-2 rounded-full bg-muted overflow-hidden">
            <div data-hud-xp class="h-full bg-primary transition-[width]" style="width:0%"></div>
          </div>
        </div>
      </div>

      <div class="relative mx-auto" style="width: 400px; max-width: 100%;">
        <canvas
          id="shooter-canvas"
          width="400"
          height="600"
          class="block w-full rounded-xl border border-border bg-[#020617]"
          style="max-width: 100%; height: auto; image-rendering: pixelated;"
          tabindex="0"
        ></canvas>

        <div
          id="shooter-overlay"
          class="absolute inset-0 hidden flex-col items-center justify-center gap-3 rounded-xl bg-black/80 text-white backdrop-blur-sm p-4 text-center"
        >
          <h2 data-ov-title class="text-2xl font-black"></h2>
          <p data-ov-msg class="text-sm text-white/80"></p>
          <div data-ov-options class="grid gap-2 w-full max-w-sm"></div>
          <button data-ov-btn type="button" class="hidden rounded-full bg-white text-slate-900 px-5 py-2 text-sm font-bold">
            Pokračovat
          </button>
        </div>
      </div>

      <div class="mt-3 grid grid-cols-2 gap-2 text-[11px] text-muted-foreground">
        <div>← → pohyb</div>
        <div>mezera = střelba (držet)</div>
      </div>

      <div class="mt-4 grid grid-cols-3 gap-2 md:hidden">
        <button data-mobile="left" type="button" class="rounded-lg border border-border bg-muted/30 py-3 font-bold">←</button>
        <button data-mobile="fire" type="button" class="rounded-lg border border-border bg-muted/30 py-3 font-bold">🔫</button>
        <button data-mobile="right" type="button" class="rounded-lg border border-border bg-muted/30 py-3 font-bold">→</button>
      </div>
    </div>
  </div>
</GameLayout>

<script>
  import { Game, type GameHud } from "../../lib/games/shooter/engine";
  import type { GameStatus, UpgradeOption } from "../../lib/games/shooter/types";

  const canvas = document.getElementById("shooter-canvas") as HTMLCanvasElement | null;
  if (!canvas) throw new Error("canvas missing");

  const overlay = document.getElementById("shooter-overlay")!;
  const ovTitle = overlay.querySelector<HTMLElement>("[data-ov-title]")!;
  const ovMsg = overlay.querySelector<HTMLElement>("[data-ov-msg]")!;
  const ovOptions = overlay.querySelector<HTMLElement>("[data-ov-options]")!;
  const ovBtn = overlay.querySelector<HTMLButtonElement>("[data-ov-btn]")!;

  const hudWave = document.querySelector<HTMLElement>("[data-hud-wave]")!;
  const hudMax = document.querySelector<HTMLElement>("[data-hud-max]")!;
  const hudLevel = document.querySelector<HTMLElement>("[data-hud-level]")!;
  const hudScore = document.querySelector<HTMLElement>("[data-hud-score]")!;
  const hudHp = document.querySelector<HTMLElement>("[data-hud-hp]")!;
  const hudXp = document.querySelector<HTMLElement>("[data-hud-xp]")!;

  function showOverlay(): void {
    overlay.classList.remove("hidden");
    overlay.classList.add("flex");
  }
  function hideOverlay(): void {
    overlay.classList.add("hidden");
    overlay.classList.remove("flex");
    ovOptions.innerHTML = "";
    ovBtn.classList.add("hidden");
  }

  function showUpgrades(options: UpgradeOption[]): void {
    ovTitle.textContent = "Level up! Vyber si vylepšení";
    ovMsg.textContent = "Jedno zvolené upgrade zůstává po celou hru.";
    ovOptions.innerHTML = "";
    options.forEach((opt) => {
      const btn = document.createElement("button");
      btn.type = "button";
      btn.className =
        "rounded-xl border border-white/30 bg-white/5 hover:bg-white/15 p-3 text-left text-sm transition-colors";
      btn.innerHTML = `<div class="text-lg mb-0.5">${opt.icon} <strong class="font-bold">${opt.title}</strong></div><div class="text-white/75 text-xs">${opt.description}</div>`;
      btn.addEventListener("click", () => {
        game?.applyUpgrade(opt);
        hideOverlay();
      });
      ovOptions.appendChild(btn);
    });
    showOverlay();
  }

  function showSimple(title: string, msg: string, btnLabel: string, onClick: () => void): void {
    ovTitle.textContent = title;
    ovMsg.textContent = msg;
    ovOptions.innerHTML = "";
    ovBtn.textContent = btnLabel;
    ovBtn.classList.remove("hidden");
    ovBtn.onclick = () => {
      onClick();
      hideOverlay();
    };
    showOverlay();
  }

  function handleStatus(status: GameStatus, options?: UpgradeOption[]): void {
    if (status === "playing") hideOverlay();
    else if (status === "levelUp" && options) showUpgrades(options);
    else if (status === "waveDone")
      showSimple("Vlna odražena 🎉", "Další vlna bude větší a rychlejší.", "Další vlna →", () => game?.startNextWave());
    else if (status === "win")
      showSimple("Kolonie zachráněna!", "Všech 5 vln poraženo. Jsi legenda.", "Hrát znovu", () => game?.restart());
    else if (status === "gameover")
      showSimple("Game over", "Ledovce padly. Zkusíš to znovu?", "Znovu", () => game?.restart());
  }

  function renderHud(h: GameHud): void {
    hudWave.textContent = String(h.wave);
    hudMax.textContent = String(h.maxWave);
    hudLevel.textContent = String(h.level);
    hudScore.textContent = String(h.score);
    (hudHp as HTMLElement).style.width = `${(h.hp / h.maxHp) * 100}%`;
    (hudHp as HTMLElement).style.background =
      h.hp / h.maxHp > 0.5 ? "#10b981" : h.hp / h.maxHp > 0.25 ? "#fbbf24" : "#ef4444";
    (hudXp as HTMLElement).style.width = `${(h.xp / h.xpToLevel) * 100}%`;
  }

  document.querySelector<HTMLButtonElement>("[data-restart]")!.addEventListener("click", () => game?.restart());

  function emitKey(key: string, type: "keydown" | "keyup"): void {
    window.dispatchEvent(new KeyboardEvent(type, { key }));
  }
  document.querySelectorAll<HTMLButtonElement>("[data-mobile]").forEach((btn) => {
    const map: Record<string, string> = { left: "ArrowLeft", right: "ArrowRight", fire: " " };
    const key = btn.dataset.mobile && map[btn.dataset.mobile];
    if (!key) return;
    const down = (e: Event) => {
      e.preventDefault();
      emitKey(key, "keydown");
    };
    const up = () => emitKey(key, "keyup");
    btn.addEventListener("touchstart", down, { passive: false });
    btn.addEventListener("touchend", up);
    btn.addEventListener("mousedown", down);
    btn.addEventListener("mouseup", up);
    btn.addEventListener("mouseleave", up);
  });

  const game: Game | null = new Game(canvas, { onStatus: handleStatus, onHud: renderHud });
  canvas.focus();
</script>
