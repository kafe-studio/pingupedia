---
export const prerender = true;
import GameLayout from "../../layouts/GameLayout.astro";
import HallOfFame from "../../components/games/HallOfFame.astro";
import HofPrompt from "../../components/games/HofPrompt.astro";
import { getImage } from "astro:assets";
import cisarsky from "../../assets/penguins/cisarsky/hero.jpg";
import patagonsky from "../../assets/penguins/patagonsky/hero.jpg";
import krouzkovy from "../../assets/penguins/krouzkovy/hero.jpg";
import osli from "../../assets/penguins/osli/hero.jpg";
import zlutooky from "../../assets/penguins/zlutooky/hero.jpg";
import nejmensi from "../../assets/penguins/nejmensi/hero.jpg";
import skalniJizni from "../../assets/penguins/skalni-jizni/hero.jpg";
import galapazsky from "../../assets/penguins/galapazsky/hero.jpg";

const sources = [
  { src: cisarsky, label: "Císařský" },
  { src: patagonsky, label: "Patagonský" },
  { src: krouzkovy, label: "Kroužkový" },
  { src: osli, label: "Oslí" },
  { src: zlutooky, label: "Žlutooký" },
  { src: nejmensi, label: "Nejmenší" },
  { src: skalniJizni, label: "Rockhopper" },
  { src: galapazsky, label: "Galapážský" },
];

const cards = await Promise.all(
  sources.map(async (p, idx) => {
    const opt = await getImage({ src: p.src, width: 300, format: "webp" });
    return { id: idx, label: p.label, url: opt.src };
  }),
);

const data = JSON.stringify(cards);
---

<GameLayout title="Pexeso" description="Pexeso s fotkami tučňáků pro 1 nebo 2 hráče.">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 pt-14 pb-8">
    <header class="mb-4 text-center">
      <p class="text-[11px] uppercase tracking-[0.2em] text-primary mb-1.5">Mini-hra</p>
      <h1 class="text-2xl md:text-3xl font-black mb-1.5">Pexeso s tučňáky</h1>
      <p class="text-sm text-muted-foreground">8 druhů, 16 karet. Najdi všechny páry.</p>
    </header>

    <div class="bento-card p-3 md:p-4 mb-3 flex flex-wrap items-center justify-center gap-2">
      <span class="text-[11px] uppercase tracking-[0.18em] text-muted-foreground font-semibold mr-1">Režim:</span>
      <button data-mode="1" type="button" class="rounded-full border border-border bg-muted/30 px-3.5 py-1.5 text-xs font-bold hover:border-border-interactive" aria-pressed="false">1 hráč</button>
      <button data-mode="2" type="button" class="rounded-full border border-border bg-muted/30 px-3.5 py-1.5 text-xs font-bold hover:border-border-interactive" aria-pressed="false">2 hráči</button>
    </div>

    <div data-players-setup class="bento-card p-4 mb-3 hidden">
      <p class="text-xs uppercase tracking-widest text-muted-foreground font-semibold mb-3 text-center">Jména hráčů</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 max-w-md mx-auto">
        <input data-name-1 type="text" maxlength="16" placeholder="Hráč 1" class="rounded-xl border border-border bg-muted/30 px-3 py-2 text-sm font-medium focus:outline-none focus:border-primary" />
        <input data-name-2 type="text" maxlength="16" placeholder="Hráč 2" class="rounded-xl border border-border bg-muted/30 px-3 py-2 text-sm font-medium focus:outline-none focus:border-primary" />
      </div>
    </div>

    <div data-versus class="hidden mb-3 space-y-3">
      <div class="bento-card bento-surface-aurora p-4 md:p-5 text-white text-center">
        <p class="text-[10px] uppercase tracking-[0.25em] font-bold text-white/70 mb-1">Na tahu</p>
        <p class="text-3xl md:text-4xl font-black leading-tight" data-versus-active>—</p>
      </div>
      <div class="bento-card p-3">
        <div class="grid grid-cols-2 gap-3">
          <div data-side-1 class="relative rounded-xl border-2 border-transparent bg-muted/30 p-3 text-center transition-all">
            <span data-side-arrow-1 class="absolute -top-2 left-1/2 -translate-x-1/2 inline-flex items-center justify-center w-7 h-7 rounded-full bg-primary text-primary-foreground text-sm font-black shadow opacity-0 transition-opacity" aria-hidden="true">▼</span>
            <p class="text-[10px] uppercase tracking-widest text-muted-foreground font-semibold" data-versus-name-1>Hráč 1</p>
            <p class="text-2xl font-black tabular-nums" data-versus-score-1>0</p>
            <p class="text-[10px] font-bold uppercase tracking-widest" data-versus-status-1>—</p>
          </div>
          <div data-side-2 class="relative rounded-xl border-2 border-transparent bg-muted/30 p-3 text-center transition-all">
            <span data-side-arrow-2 class="absolute -top-2 left-1/2 -translate-x-1/2 inline-flex items-center justify-center w-7 h-7 rounded-full bg-primary text-primary-foreground text-sm font-black shadow opacity-0 transition-opacity" aria-hidden="true">▼</span>
            <p class="text-[10px] uppercase tracking-widest text-muted-foreground font-semibold" data-versus-name-2>Hráč 2</p>
            <p class="text-2xl font-black tabular-nums" data-versus-score-2>0</p>
            <p class="text-[10px] font-bold uppercase tracking-widest" data-versus-status-2>—</p>
          </div>
        </div>
      </div>
    </div>

    <div class="bento-card p-3 md:p-4" id="pexeso-root" data-cards={data}>
      <div class="mb-3 flex flex-wrap items-center justify-between gap-3 text-xs text-muted-foreground">
        <div class="flex items-center gap-4">
          <span>Tahy: <strong data-moves class="text-foreground font-bold">0</strong></span>
          <span>Páry: <strong data-pairs class="text-foreground font-bold">0 / 8</strong></span>
        </div>
        <div class="flex items-center gap-3">
          <span data-time-wrap>Čas: <strong data-time class="text-foreground font-bold">0:00</strong></span>
          <button data-music type="button" class="rounded-full border border-border px-3 py-1.5 text-[11px] font-medium hover:border-border-interactive" aria-pressed="false" title="Relaxační hudba">🔇 Hudba</button>
          <button data-reset type="button" class="rounded-full border border-border px-3 py-1.5 text-[11px] font-medium hover:border-border-interactive">Začít znovu</button>
        </div>
      </div>
      <ul data-grid class="pexeso-grid grid grid-cols-4 md:grid-cols-8 gap-2 md:gap-3" role="list"></ul>
    </div>

    <div
      id="pexeso-finish"
      class="bento-card bento-surface-aurora p-6 text-center text-white hidden mt-6"
    >
      <p class="text-xs uppercase tracking-widest text-accent font-semibold mb-2" data-finish-eyebrow>Gratulujeme!</p>
      <h2 class="text-2xl font-black mb-1" data-finish-title>Všechny páry nalezeny</h2>
      <p class="text-sm text-white/85 mb-4" data-finish-detail>
        Dokončeno za <strong data-final-time>0:00</strong> a <strong data-final-moves>0</strong> tahů.
      </p>
      <button data-finish-reset type="button" class="btn-primary">Hrát znovu</button>
    </div>

    <HallOfFame gameId="pexeso" title="Síň slávy (1 hráč)" valueLabel="Čas" valueFormat="time" sort="asc" />
    <HallOfFame gameId="pexeso-2p" title="Síň slávy (2 hráči)" valueLabel="Páry" valueFormat="number" sort="desc" />
  </div>

  <HofPrompt />
</GameLayout>

<script>
  interface Card {
    id: number;
    label: string;
    url: string;
  }

  const STORAGE_MODE = "pingupedia-pexeso-mode";
  const STORAGE_NAMES = "pingupedia-pexeso-names";

  const root = document.getElementById("pexeso-root")!;
  const finish = document.getElementById("pexeso-finish")!;

  const base: Card[] = JSON.parse(root.dataset.cards || "[]");
  const $grid = root.querySelector<HTMLUListElement>("[data-grid]")!;
  const $moves = root.querySelector<HTMLElement>("[data-moves]")!;
  const $pairs = root.querySelector<HTMLElement>("[data-pairs]")!;
  const $time = root.querySelector<HTMLElement>("[data-time]")!;
  const $timeWrap = root.querySelector<HTMLElement>("[data-time-wrap]")!;
  const $reset = root.querySelector<HTMLButtonElement>("[data-reset]")!;
  const $finishEyebrow = finish.querySelector<HTMLElement>("[data-finish-eyebrow]")!;
  const $finishTitle = finish.querySelector<HTMLElement>("[data-finish-title]")!;
  const $finishDetail = finish.querySelector<HTMLElement>("[data-finish-detail]")!;
  const $finishTime = finish.querySelector<HTMLElement>("[data-final-time]")!;
  const $finishMoves = finish.querySelector<HTMLElement>("[data-final-moves]")!;
  const $finishReset = finish.querySelector<HTMLButtonElement>("[data-finish-reset]")!;

  // 2P UI
  const $modeBtns = document.querySelectorAll<HTMLButtonElement>("[data-mode]");
  const $playersSetup = document.querySelector<HTMLElement>("[data-players-setup]")!;
  const $name1 = document.querySelector<HTMLInputElement>("[data-name-1]")!;
  const $name2 = document.querySelector<HTMLInputElement>("[data-name-2]")!;
  const $versus = document.querySelector<HTMLElement>("[data-versus]")!;
  const $side1 = document.querySelector<HTMLElement>("[data-side-1]")!;
  const $side2 = document.querySelector<HTMLElement>("[data-side-2]")!;
  const $vName1 = document.querySelector<HTMLElement>("[data-versus-name-1]")!;
  const $vName2 = document.querySelector<HTMLElement>("[data-versus-name-2]")!;
  const $vScore1 = document.querySelector<HTMLElement>("[data-versus-score-1]")!;
  const $vScore2 = document.querySelector<HTMLElement>("[data-versus-score-2]")!;
  const $vStatus1 = document.querySelector<HTMLElement>("[data-versus-status-1]")!;
  const $vStatus2 = document.querySelector<HTMLElement>("[data-versus-status-2]")!;
  const $vActive = document.querySelector<HTMLElement>("[data-versus-active]")!;
  const $arrow1 = document.querySelector<HTMLElement>("[data-side-arrow-1]")!;
  const $arrow2 = document.querySelector<HTMLElement>("[data-side-arrow-2]")!;

  type Mode = 1 | 2;
  let mode: Mode = loadMode();

  let moves = 0;
  let pairs = 0;
  let startedAt = 0;
  let timer: number | null = null;
  let first: HTMLButtonElement | null = null;
  let lock = false;
  // 2P state
  let currentPlayer: 1 | 2 = 1;
  let p1Score = 0;
  let p2Score = 0;
  let p1Name = "";
  let p2Name = "";

  function loadMode(): Mode {
    try {
      const v = localStorage.getItem(STORAGE_MODE);
      if (v === "2") return 2;
    } catch { /* ignore */ }
    return 1;
  }
  function saveMode(m: Mode): void {
    try { localStorage.setItem(STORAGE_MODE, String(m)); } catch { /* ignore */ }
  }
  function loadNames(): { n1: string; n2: string } {
    try {
      const raw = localStorage.getItem(STORAGE_NAMES);
      if (raw) return JSON.parse(raw) as { n1: string; n2: string };
    } catch { /* ignore */ }
    return { n1: "", n2: "" };
  }
  function saveNames(): void {
    try {
      localStorage.setItem(STORAGE_NAMES, JSON.stringify({
        n1: $name1.value,
        n2: $name2.value,
      }));
    } catch { /* ignore */ }
  }
  function effectiveName(slot: 1 | 2): string {
    const raw = (slot === 1 ? $name1.value : $name2.value).trim();
    return raw || `Hráč ${slot}`;
  }

  function escapeHtml(s: string): string {
    return s.replace(/[&<>"']/g, (c) => (
      c === "&" ? "&amp;" : c === "<" ? "&lt;" : c === ">" ? "&gt;" : c === "\"" ? "&quot;" : "&#39;"
    ));
  }

  function shuffle<T>(arr: T[]): T[] {
    return arr
      .map((v) => [Math.random(), v] as const)
      .sort((a, b) => a[0] - b[0])
      .map((t) => t[1]);
  }

  function fmt(sec: number): string {
    const m = Math.floor(sec / 60);
    const s = sec % 60;
    return `${m}:${String(s).padStart(2, "0")}`;
  }

  function startTimer(): void {
    startedAt = Date.now();
    if (timer) clearInterval(timer);
    timer = window.setInterval(() => {
      $time.textContent = fmt(Math.floor((Date.now() - startedAt) / 1000));
    }, 500);
  }

  function stopTimer(): number {
    if (timer) {
      clearInterval(timer);
      timer = null;
    }
    return Math.floor((Date.now() - startedAt) / 1000);
  }

  function flip(btn: HTMLButtonElement): void {
    btn.setAttribute("aria-pressed", "true");
    btn.classList.add("is-flipped");
  }

  function unflipPair(a: HTMLButtonElement, b: HTMLButtonElement): void {
    a.setAttribute("aria-pressed", "false");
    b.setAttribute("aria-pressed", "false");
    a.classList.remove("is-flipped");
    b.classList.remove("is-flipped");
  }

  function matchPair(a: HTMLButtonElement, b: HTMLButtonElement): void {
    a.classList.add("is-matched");
    b.classList.add("is-matched");
    a.disabled = true;
    b.disabled = true;
  }

  function onFlip(btn: HTMLButtonElement): void {
    if (lock || btn.classList.contains("is-flipped")) return;
    if (moves === 0 && pairs === 0 && mode === 1) startTimer();
    flip(btn);

    if (!first) {
      first = btn;
      return;
    }
    moves++;
    $moves.textContent = String(moves);
    lock = true;

    if (first.dataset.cardId === btn.dataset.cardId) {
      matchPair(first, btn);
      pairs++;
      $pairs.textContent = `${pairs} / ${base.length}`;
      if (mode === 2) {
        if (currentPlayer === 1) p1Score++;
        else p2Score++;
        renderVersus();
      }
      first = null;
      lock = false;
      if (pairs === base.length) endGame();
      return;
    }

    const a = first;
    const b = btn;
    window.setTimeout(() => {
      unflipPair(a, b);
      first = null;
      lock = false;
      if (mode === 2) {
        currentPlayer = currentPlayer === 1 ? 2 : 1;
        renderVersus();
      }
    }, 900);
  }

  function renderVersus(): void {
    $vName1.textContent = p1Name;
    $vName2.textContent = p2Name;
    $vScore1.textContent = String(p1Score);
    $vScore2.textContent = String(p2Score);
    const active1 = currentPlayer === 1;
    $vActive.textContent = active1 ? p1Name : p2Name;
    // Side highlight
    $side1.classList.toggle("border-primary", active1);
    $side1.classList.toggle("bg-primary/10", active1);
    $side1.classList.toggle("scale-105", active1);
    $side2.classList.toggle("border-primary", !active1);
    $side2.classList.toggle("bg-primary/10", !active1);
    $side2.classList.toggle("scale-105", !active1);
    // Arrow indicator
    $arrow1.classList.toggle("opacity-100", active1);
    $arrow1.classList.toggle("opacity-0", !active1);
    $arrow1.classList.toggle("animate-bounce", active1);
    $arrow2.classList.toggle("opacity-100", !active1);
    $arrow2.classList.toggle("opacity-0", active1);
    $arrow2.classList.toggle("animate-bounce", !active1);
    // Status text
    $vStatus1.textContent = active1 ? "▶ na tahu" : "čeká";
    $vStatus2.textContent = active1 ? "čeká" : "▶ na tahu";
    $vStatus1.classList.toggle("text-primary", active1);
    $vStatus1.classList.toggle("text-muted-foreground", !active1);
    $vStatus2.classList.toggle("text-primary", !active1);
    $vStatus2.classList.toggle("text-muted-foreground", active1);
  }

  function endGame(): void {
    if (mode === 1) {
      const total = stopTimer();
      $finishEyebrow.textContent = "Gratulujeme!";
      $finishTitle.textContent = "Všechny páry nalezeny";
      $finishTime.textContent = fmt(total);
      $finishMoves.textContent = String(moves);
      $finishDetail.innerHTML = `Dokončeno za <strong>${fmt(total)}</strong> a <strong>${moves}</strong> tahů.`;
      root.classList.add("hidden");
      finish.classList.remove("hidden");
      window.openHofPrompt?.({
        gameId: "pexeso",
        value: total,
        meta: `${moves} tahů`,
        valueLabel: "Čas",
        valueFormat: "time",
        sort: "asc",
      });
      return;
    }
    // mode === 2
    let title: string;
    let winnerName = "";
    let winnerScore = 0;
    if (p1Score > p2Score) {
      title = `🥇 Vítězí ${p1Name}!`;
      winnerName = p1Name;
      winnerScore = p1Score;
    } else if (p2Score > p1Score) {
      title = `🥇 Vítězí ${p2Name}!`;
      winnerName = p2Name;
      winnerScore = p2Score;
    } else {
      title = "🤝 Remíza!";
      winnerName = `${p1Name} & ${p2Name}`;
      winnerScore = p1Score;
    }
    $finishEyebrow.textContent = "Konec hry";
    $finishTitle.textContent = title;
    // Hráčská jména jsou z input fieldu — escape proti XSS před vložením do innerHTML.
    $finishDetail.innerHTML = `${escapeHtml(p1Name)}: <strong>${p1Score}</strong> · ${escapeHtml(p2Name)}: <strong>${p2Score}</strong> · ${moves} tahů`;
    root.classList.add("hidden");
    finish.classList.remove("hidden");
    window.openHofPrompt?.({
      gameId: "pexeso-2p",
      value: winnerScore,
      meta: `${winnerName} · ${p1Score}:${p2Score} · ${moves} tahů`,
      valueLabel: "Páry vítěze",
      valueFormat: "number",
      sort: "desc",
    });
  }

  function applyMode(): void {
    moves = 0;
    pairs = 0;
    first = null;
    lock = false;
    p1Score = 0;
    p2Score = 0;
    currentPlayer = 1;
    p1Name = effectiveName(1);
    p2Name = effectiveName(2);
    $modeBtns.forEach((b) => {
      const m = Number(b.dataset.mode) as Mode;
      const active = m === mode;
      b.setAttribute("aria-pressed", active ? "true" : "false");
      b.classList.toggle("!bg-primary", active);
      b.classList.toggle("!text-primary-foreground", active);
      b.classList.toggle("!border-primary", active);
    });
    $playersSetup.classList.toggle("hidden", mode !== 2);
    $versus.classList.toggle("hidden", mode !== 2);
    $timeWrap.classList.toggle("hidden", mode === 2);
    if (mode === 2) renderVersus();
  }

  function render(): void {
    applyMode();
    stopTimer();
    $time.textContent = "0:00";
    $moves.textContent = "0";
    $pairs.textContent = `0 / ${base.length}`;
    root.classList.remove("hidden");
    finish.classList.add("hidden");
    $grid.innerHTML = "";

    const deck = shuffle([...base, ...base]);
    deck.forEach((card, i) => {
      const li = document.createElement("li");
      const btn = document.createElement("button");
      btn.type = "button";
      btn.className = "pexeso-card";
      btn.dataset.cardId = String(card.id);
      btn.setAttribute("aria-label", `Karta ${i + 1}: skrytá`);
      btn.setAttribute("aria-pressed", "false");
      btn.innerHTML = `
        <span class="pexeso-inner">
          <span class="pexeso-face pexeso-back">🐧</span>
          <span class="pexeso-face pexeso-front">
            <img src="${card.url}" alt="Tučňák ${card.label}" loading="lazy" />
            <span class="pexeso-label">${card.label}</span>
          </span>
        </span>
      `;
      btn.addEventListener("click", () => onFlip(btn));
      li.appendChild(btn);
      $grid.appendChild(li);
    });
  }

  $reset.addEventListener("click", render);
  $finishReset.addEventListener("click", render);

  // Mode toggle wiring
  const savedNames = loadNames();
  $name1.value = savedNames.n1;
  $name2.value = savedNames.n2;
  $name1.addEventListener("change", saveNames);
  $name2.addEventListener("change", saveNames);
  $modeBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const m = Number(btn.dataset.mode) as Mode;
      if (m === mode) return;
      mode = m;
      saveMode(m);
      render();
    });
  });

  render();

  // Relaxační hudba — toggle.
  import("../../lib/games/relaxing-music").then(({ RelaxingMusic }) => {
    const music = new RelaxingMusic();
    const btn = document.querySelector<HTMLButtonElement>("[data-music]");
    btn?.addEventListener("click", () => {
      if (music.isPlaying()) {
        music.stop();
        btn.textContent = "🔇 Hudba";
        btn.setAttribute("aria-pressed", "false");
      } else {
        const ok = music.start();
        if (ok) {
          btn.textContent = "🔊 Hudba";
          btn.setAttribute("aria-pressed", "true");
        }
      }
    });
    window.addEventListener("beforeunload", () => music.destroy());
  });
</script>

<style is:global>
  .pexeso-grid { perspective: 1200px; }
  .pexeso-card {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    border: none;
    padding: 0;
    background: transparent;
    cursor: pointer;
  }
  .pexeso-inner {
    display: block;
    position: absolute;
    inset: 0;
    transform-style: preserve-3d;
    transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .pexeso-card.is-flipped .pexeso-inner {
    transform: rotateY(180deg);
  }
  .pexeso-face {
    position: absolute;
    inset: 0;
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }
  .pexeso-back {
    background: linear-gradient(135deg, var(--bento-aurora-1) 0%, var(--bento-aurora-2) 100%);
    font-size: 2rem;
    border: 2px solid var(--border-interactive);
  }
  .pexeso-front {
    background: #ffffff;
    border: 2px solid var(--border);
    transform: rotateY(180deg);
    flex-direction: column;
    padding: 0.25rem;
  }
  .pexeso-front img {
    width: 100%;
    flex: 1 1 auto;
    min-height: 0;
    object-fit: contain;
  }
  .pexeso-label {
    flex: 0 0 auto;
    font-size: 0.65rem;
    font-weight: 700;
    padding: 0.25rem 0.25rem 0;
    text-align: center;
    color: #0c1929;
    line-height: 1.2;
  }
  .pexeso-card:hover:not(.is-flipped):not(.is-matched) .pexeso-inner {
    transform: scale(1.04);
  }
  .pexeso-card.is-matched .pexeso-front {
    border-color: #10b981;
    box-shadow: 0 0 0 2px rgba(16, 185, 129, 0.5);
  }
</style>
