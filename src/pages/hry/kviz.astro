---
export const prerender = true;
import GameLayout from "../../layouts/GameLayout.astro";
import HallOfFame from "../../components/games/HallOfFame.astro";
import HofPrompt from "../../components/games/HofPrompt.astro";
import { getQuiz } from "../../lib/pages";
import { getCollection } from "astro:content";
import { getImage } from "astro:assets";

const quiz = await getQuiz();
const QUESTIONS_PER_ROUND = 15;

// Optimalizované hero fotky pro otázky se speciesSlug.
const species = await getCollection("species");
const speciesPhotos: Record<string, string> = {};
for (const s of species) {
  const opt = await getImage({ src: s.data.hero.src, width: 480, format: "webp" });
  speciesPhotos[s.id] = opt.src;
}

const questionsData = JSON.stringify(quiz.questions);
const photosData = JSON.stringify(speciesPhotos);
---

<GameLayout title="Kvíz" description="Otestuj si, co víš o tučňácích — 15 otázek, 5 obtížností, fotky.">
  <div class="mx-auto max-w-2xl px-4 sm:px-6 pt-14 pb-10">
    <header class="mb-5 text-center">
      <p class="text-[11px] uppercase tracking-[0.2em] text-primary mb-1.5">Mini-hra</p>
      <h1 class="text-2xl md:text-3xl font-black mb-1.5">Kvíz o tučňácích</h1>
      <p class="text-sm text-muted-foreground">{QUESTIONS_PER_ROUND} otázek z databáze {quiz.questions.length}. Vyber obtížnost 1–5.</p>
    </header>

    <div class="bento-card p-4 mb-4 flex flex-wrap items-center gap-2 justify-center">
      <span class="text-[11px] uppercase tracking-[0.18em] text-muted-foreground font-semibold mr-1">Obtížnost:</span>
      {[1, 2, 3, 4, 5].map((n) => (
        <button
          type="button"
          data-difficulty={n}
          class="rounded-full border border-border bg-muted/30 px-3.5 py-1.5 text-xs font-bold tabular-nums hover:border-border-interactive transition-colors"
          aria-pressed="false"
        >
          {n} {n === 1 ? "★" : n === 2 ? "★★" : n === 3 ? "★★★" : n === 4 ? "★★★★" : "★★★★★"}
        </button>
      ))}
    </div>

    <div
      id="quiz-root"
      class="bento-card p-4 md:p-5"
      data-questions={questionsData}
      data-photos={photosData}
      data-round-size={QUESTIONS_PER_ROUND}
    >
      <div class="mb-2 flex items-center justify-between text-xs text-muted-foreground">
        <span data-progress>Otázka 1 z {QUESTIONS_PER_ROUND}</span>
        <span data-score>Skóre: 0</span>
      </div>
      <div class="h-1.5 rounded-full bg-muted overflow-hidden mb-4">
        <div data-bar class="h-full bg-primary transition-[width] duration-300" style="width: 0%;"></div>
      </div>
      <div data-photo-wrap class="mb-4 hidden">
        <div class="aspect-[4/3] rounded-xl overflow-hidden bg-muted/40">
          <img data-photo src="" alt="" loading="eager" class="w-full h-full object-contain" />
        </div>
      </div>
      <h2 data-question class="text-lg md:text-xl font-bold mb-4 leading-snug"></h2>
      <ul data-options class="grid gap-2"></ul>
      <p data-feedback class="mt-3 text-xs text-muted-foreground" hidden></p>
      <div class="mt-4 flex justify-end">
        <button
          data-next
          type="button"
          class="btn-primary"
          disabled
        >
          Další otázka →
        </button>
      </div>
    </div>

    <div id="quiz-finish" class="bento-card bento-surface-aurora p-6 text-center text-white hidden">
      <p class="text-xs uppercase tracking-widest text-accent font-semibold mb-2">Hotovo!</p>
      <h2 class="text-2xl font-black mb-1">Tvůj výsledek</h2>
      <p data-final class="text-5xl font-black my-4">0 / {QUESTIONS_PER_ROUND}</p>
      <p data-final-msg class="text-sm text-white/85 mb-4"></p>
      <div class="flex flex-wrap justify-center gap-3">
        <button data-retry type="button" class="btn-primary">Zkusit jiný test</button>
        <a href="/druhy/" class="btn-outline text-white border-white/40">Prozkoumat druhy →</a>
      </div>
    </div>

    <HallOfFame gameId="kviz" valueLabel="Skóre" valueFormat="number" sort="desc" />
  </div>

  <HofPrompt />
</GameLayout>

<script>
  interface Question {
    question: string;
    options: string[];
    correct: number;
    explanation: string;
    difficulty?: number;
    speciesSlug?: string;
  }

  const STORAGE_DIFFICULTY = "pingupedia-quiz-difficulty";

  const root = document.getElementById("quiz-root")!;
  const finish = document.getElementById("quiz-finish")!;

  const allQuestions: Question[] = JSON.parse(root.dataset.questions || "[]");
  const photos: Record<string, string> = JSON.parse(root.dataset.photos || "{}");
  const roundSize = Math.min(
    Number(root.dataset.roundSize) || 15,
    allQuestions.length,
  );

  let currentDifficulty: number = loadDifficulty();
  let questions: Question[] = [];
  let currentIndex = 0;
  let score = 0;
  let answered = false;

  const $question = root.querySelector<HTMLElement>("[data-question]")!;
  const $options = root.querySelector<HTMLElement>("[data-options]")!;
  const $feedback = root.querySelector<HTMLParagraphElement>("[data-feedback]")!;
  const $next = root.querySelector<HTMLButtonElement>("[data-next]")!;
  const $progress = root.querySelector<HTMLElement>("[data-progress]")!;
  const $score = root.querySelector<HTMLElement>("[data-score]")!;
  const $bar = root.querySelector<HTMLElement>("[data-bar]")!;
  const $photoWrap = root.querySelector<HTMLElement>("[data-photo-wrap]")!;
  const $photo = root.querySelector<HTMLImageElement>("[data-photo]")!;
  const $final = finish.querySelector<HTMLElement>("[data-final]")!;
  const $finalMsg = finish.querySelector<HTMLElement>("[data-final-msg]")!;
  const $retry = finish.querySelector<HTMLButtonElement>("[data-retry]")!;

  function loadDifficulty(): number {
    try {
      const v = Number(localStorage.getItem(STORAGE_DIFFICULTY));
      if (Number.isInteger(v) && v >= 1 && v <= 5) return v;
    } catch { /* ignore */ }
    return 3;
  }

  function saveDifficulty(d: number): void {
    try { localStorage.setItem(STORAGE_DIFFICULTY, String(d)); } catch { /* ignore */ }
  }

  function shuffle<T>(arr: T[]): T[] {
    const out = arr.slice();
    for (let i = out.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [out[i], out[j]] = [out[j], out[i]];
    }
    return out;
  }

  function pickRound(): Question[] {
    // Filtruj na vybranou obtížnost; pokud má míň než roundSize, doplň náhodně z ostatních.
    const matching = allQuestions.filter((q) => q.difficulty === currentDifficulty);
    let pool: Question[];
    if (matching.length >= roundSize) {
      pool = shuffle(matching).slice(0, roundSize);
    } else {
      const fill = shuffle(allQuestions.filter((q) => q.difficulty !== currentDifficulty));
      pool = [...shuffle(matching), ...fill].slice(0, roundSize);
    }
    return pool.map((q) => {
      const indexed = q.options.map((text, i) => ({ text, i }));
      const shuffled = shuffle(indexed);
      return {
        question: q.question,
        options: shuffled.map((o) => o.text),
        correct: shuffled.findIndex((o) => o.i === q.correct),
        explanation: q.explanation,
        difficulty: q.difficulty,
        speciesSlug: q.speciesSlug,
      };
    });
  }

  function render(): void {
    const q = questions[currentIndex];
    answered = false;
    $question.textContent = q.question;
    $options.innerHTML = "";
    $feedback.hidden = true;
    $next.disabled = true;
    $next.textContent =
      currentIndex === questions.length - 1 ? "Ukončit kvíz" : "Další otázka →";
    $progress.textContent = `Otázka ${currentIndex + 1} z ${questions.length}`;
    $score.textContent = `Skóre: ${score}`;
    $bar.style.width = `${((currentIndex + 1) / questions.length) * 100}%`;

    if (q.speciesSlug && photos[q.speciesSlug]) {
      $photo.src = photos[q.speciesSlug];
      $photo.alt = `Fotka tučňáka — ${q.speciesSlug}`;
      $photoWrap.classList.remove("hidden");
    } else {
      $photo.src = "";
      $photoWrap.classList.add("hidden");
    }

    q.options.forEach((text, i) => {
      const li = document.createElement("li");
      const btn = document.createElement("button");
      btn.type = "button";
      btn.className =
        "w-full text-left rounded-xl border border-border bg-muted/30 px-3 py-2.5 text-sm font-medium hover:border-border-interactive transition-colors cursor-pointer";
      btn.textContent = text;
      btn.addEventListener("click", () => selectAnswer(i));
      li.appendChild(btn);
      $options.appendChild(li);
    });
  }

  function selectAnswer(index: number): void {
    if (answered) return;
    answered = true;
    const q = questions[currentIndex];
    const buttons = Array.from($options.querySelectorAll("button"));
    buttons.forEach((b, i) => {
      b.disabled = true;
      if (i === q.correct) b.classList.add("!border-emerald-500", "!bg-emerald-500/10", "!text-emerald-200");
      if (i === index && i !== q.correct) b.classList.add("!border-rose-500", "!bg-rose-500/10", "!text-rose-200");
    });
    if (index === q.correct) score++;
    $score.textContent = `Skóre: ${score}`;
    $feedback.textContent = q.explanation;
    $feedback.hidden = false;
    $next.disabled = false;
  }

  function finishQuiz(): void {
    root.classList.add("hidden");
    finish.classList.remove("hidden");
    $final.textContent = `${score} / ${questions.length}`;
    const pct = score / questions.length;
    const msg =
      pct === 1
        ? "Perfektní! Jsi opravdový znalec tučňáků."
        : pct >= 0.6
          ? "Dobrá práce! Většinu tučňáčích záhad máš pod palcem."
          : "Projdi si pár druhů a zkus to znovu — brzy budeš expert.";
    $finalMsg.textContent = msg;
    window.openHofPrompt?.({
      gameId: "kviz",
      value: score,
      meta: `z ${questions.length} otázek · obtížnost ${currentDifficulty}/5`,
      valueLabel: "Skóre",
      valueFormat: "number",
      sort: "desc",
    });
  }

  function startNewRound(): void {
    questions = pickRound();
    currentIndex = 0;
    score = 0;
    finish.classList.add("hidden");
    root.classList.remove("hidden");
    render();
  }

  function syncDifficultyButtons(): void {
    document.querySelectorAll<HTMLButtonElement>("[data-difficulty]").forEach((btn) => {
      const n = Number(btn.dataset.difficulty);
      const active = n === currentDifficulty;
      btn.setAttribute("aria-pressed", active ? "true" : "false");
      btn.classList.toggle("!bg-primary", active);
      btn.classList.toggle("!text-primary-foreground", active);
      btn.classList.toggle("!border-primary", active);
    });
  }

  document.querySelectorAll<HTMLButtonElement>("[data-difficulty]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const n = Number(btn.dataset.difficulty);
      if (!Number.isInteger(n) || n < 1 || n > 5) return;
      if (n === currentDifficulty) return;
      currentDifficulty = n;
      saveDifficulty(n);
      syncDifficultyButtons();
      startNewRound();
    });
  });

  $next.addEventListener("click", () => {
    if (currentIndex < questions.length - 1) {
      currentIndex++;
      render();
    } else {
      finishQuiz();
    }
  });

  $retry.addEventListener("click", startNewRound);

  syncDifficultyButtons();
  startNewRound();
</script>
