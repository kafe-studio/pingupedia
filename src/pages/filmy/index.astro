---
export const prerender = true;
import BaseLayout from "../../layouts/BaseLayout.astro";
import Mascot from "../../components/mascot/Mascot.astro";
import { getFilmyPage } from "../../lib/pages";

const page = await getFilmyPage();

const surfaceClass: Record<(typeof page.sections)[number]["surface"], string> = {
  aurora: "bento-surface-aurora",
  ocean: "bento-surface-ocean",
  ice: "bento-surface-ice",
  sun: "bento-surface-sun",
  candy: "bento-surface-candy",
  midnight: "bento-surface-midnight",
};

const typeLabel: Record<(typeof page.sections)[number]["items"][number]["type"], string> = {
  animovany: "animovaný",
  hrany: "hraný",
  dokument: "dokument",
  serial: "seriál",
};

const metadata = {
  title: page.meta.title,
  description: page.meta.description,
};
---

<BaseLayout {metadata}>
  <section class="px-4 sm:px-6 pt-28 pb-16">
    <div class="mx-auto max-w-6xl">
      <header class="mb-10 md:mb-14 max-w-3xl reveal">
        <p class="text-sm uppercase tracking-[0.2em] text-primary/80 mb-4" data-i18n="filmy.eyebrow">{page.hero.eyebrow}</p>
        <h1 class="text-5xl md:text-7xl font-black tracking-tight leading-[0.95] mb-4">
          <Fragment set:html={page.hero.titleHtml} />
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground">{page.hero.subtitle}</p>
      </header>

      {page.sections.map((section) => (
        <div class="mb-10 md:mb-14">
          <header class={`bento-card ${surfaceClass[section.surface]} p-6 md:p-7 mb-5 text-white flex items-center gap-4`}>
            <span class="text-4xl shrink-0" aria-hidden="true">{section.emoji}</span>
            <div class="flex-1 min-w-0">
              <h2 class="text-2xl md:text-3xl font-black leading-tight">{section.title}</h2>
              <p class="text-white/80 text-sm md:text-base mt-1">{section.subtitle}</p>
            </div>
          </header>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-5">
            {section.items.map((item) => (
              <article class="bento-card p-6 md:p-7 flex flex-col">
                <div class="flex items-start justify-between gap-3 mb-3">
                  <div class="flex-1 min-w-0">
                    <p class="text-xs uppercase tracking-widest text-muted-foreground font-semibold">
                      {typeLabel[item.type]}
                      {item.year && <span class="ml-2">· {item.year}</span>}
                      {item.yearLabel && <span class="ml-2">· {item.yearLabel}</span>}
                    </p>
                    <h3 class="mt-1.5 text-xl md:text-2xl font-black leading-tight">{item.title}</h3>
                    {item.titleOrig && item.titleOrig !== item.title && (
                      <p class="text-sm text-muted-foreground italic mt-0.5">{item.titleOrig}</p>
                    )}
                    {item.director && (
                      <p class="text-xs text-muted-foreground mt-1">režie: {item.director}</p>
                    )}
                  </div>
                  {item.badge && (
                    <span class="shrink-0 inline-flex items-center gap-1 rounded-full bg-amber-100 dark:bg-amber-500/20 text-amber-800 dark:text-amber-200 px-3 py-1 text-xs font-bold">
                      🏆 {item.badge}
                    </span>
                  )}
                </div>
                <p class="text-sm text-foreground/85 leading-relaxed mb-4 flex-1">{item.description}</p>
                <div class="flex flex-wrap gap-2 mt-auto">
                  {item.links.map((link) => (
                    <a
                      href={link.url}
                      target="_blank"
                      rel="noopener"
                      class="inline-flex items-center gap-1.5 rounded-full border border-border bg-muted/50 px-3.5 py-1.5 text-xs font-semibold text-foreground/80 hover:border-primary hover:text-primary transition-colors"
                    >
                      {link.label} ↗
                    </a>
                  ))}
                </div>
              </article>
            ))}
          </div>
        </div>
      ))}

      <div class="bento-card p-6 md:p-8 flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="max-w-xl">
          <p class="text-xs uppercase tracking-widest text-primary font-semibold" data-i18n="filmy.note.eyebrow">{page.note.eyebrow}</p>
          <h3 class="mt-2 text-2xl md:text-3xl font-black leading-tight">{page.note.title}</h3>
          <p class="mt-3 text-muted-foreground">{page.note.body}</p>
        </div>
        <div class="shrink-0 anim-float">
          <Mascot pose="cte" size={130} />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
