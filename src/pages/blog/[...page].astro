---
export const prerender = true;
import type { GetStaticPathsOptions } from "astro";
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = (await getCollection("blog"))
    .filter((post) => post.data && post.data.pubDate)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  return paginate(posts, { pageSize: 10 });
}

const { page } = Astro.props;
const metadata = { title: "Blog", description: "Vsechny clanky." };
---

<BaseLayout {metadata}>
  <section class="pt-32 pb-16 px-6">
    <div class="mx-auto max-w-4xl">
      <h1 class="text-4xl font-extrabold mb-12 reveal">Blog</h1>
      {page.data.length === 0 && (
        <p class="text-muted-foreground">Zatim zadne clanky.</p>
      )}
      <div class="space-y-8">
        {page.data.map((post) => (
          <article class="reveal border-b border-border pb-8">
            <a href={`/blog/${post.id}/`} class="group">
              <h2 class="text-xl font-bold group-hover:text-primary transition-colors">{post.data.title}</h2>
              <p class="text-sm text-muted-foreground mt-1">
                <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString("cs")}</time>
              </p>
              <p class="text-foreground/70 mt-2">{post.data.description}</p>
            </a>
          </article>
        ))}
      </div>
      {(page.url.prev || page.url.next) && (
        <nav class="flex justify-between mt-12" aria-label="Strankovani">
          {page.url.prev ? <a href={page.url.prev} class="btn-outline py-2 px-6 text-sm">Novejsi</a> : <span />}
          {page.url.next ? <a href={page.url.next} class="btn-outline py-2 px-6 text-sm">Starsi</a> : <span />}
        </nav>
      )}
    </div>
  </section>
</BaseLayout>
