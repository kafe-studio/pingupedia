---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import Mascot from "../components/mascot/Mascot.astro";
import Timeline from "../components/timeline/Timeline.astro";
import { getTimelinePage } from "../lib/pages";
import type { ImageMetadata } from "astro";
import { getCollection } from "astro:content";
import { getImage } from "astro:assets";

const page = await getTimelinePage();

// Pro každou událost s `speciesSlug` napárujeme hero fotku druhu jako historickou ilustraci.
// Pro události bez slugu, ale s `image` polem v JSON, načteme historickou fotografii
// z `src/assets/timeline/<file>` přes import.meta.glob.
const species = await getCollection("species");
const speciesById = new Map(species.map((s) => [s.id, s]));

const timelineImages = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/timeline/*.{jpg,jpeg,png,webp}",
  { eager: true },
);
function findTimelineImage(file: string): ImageMetadata | undefined {
  const entry = Object.entries(timelineImages).find(([path]) => path.endsWith("/" + file));
  return entry?.[1].default;
}

type RenderEvent = Omit<typeof page.events[number], "image"> & {
  image?: { src: string; srcset?: string; alt: string; author: string; license: string; sourceUrl: string };
};

// Counter pro slug → kolikátá událost daného druhu už byla zpracována.
// Při >= 2 použijeme rotaci přes gallery, aby se neopakovala stejná hero fotka.
const slugCounter = new Map<string, number>();

const enrichedEvents: RenderEvent[] = await Promise.all(page.events.map(async (e): Promise<RenderEvent> => {
  // Priorita 1: speciesSlug → species hero (1. výskyt) nebo gallery rotace (další výskyty).
  if (e.speciesSlug) {
    const sp = speciesById.get(e.speciesSlug);
    if (sp) {
      const idx = slugCounter.get(e.speciesSlug) ?? 0;
      slugCounter.set(e.speciesSlug, idx + 1);
      const gallery = sp.data.gallery ?? [];
      const photo = idx === 0 ? sp.data.hero : (gallery[idx - 1] ?? sp.data.hero);
      const opt = await getImage({ src: photo.src, format: "webp", widths: [320, 480, 720], sizes: "(min-width: 768px) 360px, 90vw" });
      return {
        ...e,
        image: {
          src: opt.src,
          srcset: opt.srcSet?.attribute,
          alt: photo.alt,
          author: photo.author,
          license: photo.license,
          sourceUrl: photo.sourceUrl,
        },
      };
    }
  }
  // Priorita 2: explicit JSON image (historic photo z Commons)
  if (e.image) {
    const asset = findTimelineImage(e.image.file);
    if (asset) {
      const opt = await getImage({ src: asset, format: "webp", widths: [320, 480, 720], sizes: "(min-width: 768px) 360px, 90vw" });
      return {
        ...e,
        image: {
          src: opt.src,
          srcset: opt.srcSet?.attribute,
          alt: e.image.alt,
          author: e.image.author,
          license: e.image.license,
          sourceUrl: e.image.sourceUrl,
        },
      };
    }
  }
  // No image match (no slug, no JSON image, or asset not found) — strip raw image field.
  const { image: _drop, ...rest } = e;
  void _drop;
  return rest;
}));

const metadata = {
  title: page.meta.title,
  description: page.meta.description,
};

// Stručná statistika pro hero — kategorie zastoupené v ose.
const categoryCounts = page.events.reduce<Record<string, number>>((acc, e) => {
  acc[e.category] = (acc[e.category] || 0) + 1;
  return acc;
}, {});
const totalYears = Math.max(...page.events.map((e) => e.year)) - Math.min(...page.events.map((e) => e.year));
---

<BaseLayout {metadata}>
  <section class="px-4 sm:px-6 pt-28 pb-16">
    <div class="mx-auto max-w-5xl">
      <header class="mb-10 md:mb-14 flex flex-col md:flex-row md:items-end md:justify-between gap-6 reveal">
        <div class="max-w-2xl">
          <p class="text-sm uppercase tracking-[0.2em] text-primary/80 mb-4">{page.hero.eyebrow}</p>
          <h1 class="text-5xl md:text-7xl font-black tracking-tight leading-[0.95] mb-4">
            <Fragment set:html={page.hero.titleHtml} />
          </h1>
          <p class="text-lg md:text-xl text-muted-foreground">{page.hero.subtitle}</p>
        </div>
        <div class="shrink-0 anim-float hidden md:block">
          <Mascot pose="cte" size={140} />
        </div>
      </header>

      <div class="mb-8 grid grid-cols-2 sm:grid-cols-4 gap-3 reveal">
        <div class="bento-card p-4 text-center">
          <p class="text-3xl font-black text-primary">{page.events.length}</p>
          <p class="text-xs text-muted-foreground mt-1">milníků</p>
        </div>
        <div class="bento-card p-4 text-center">
          <p class="text-3xl font-black text-accent">{totalYears}</p>
          <p class="text-xs text-muted-foreground mt-1">let historie</p>
        </div>
        <div class="bento-card p-4 text-center">
          <p class="text-3xl font-black text-emerald-500">{categoryCounts.science ?? 0}</p>
          <p class="text-xs text-muted-foreground mt-1">vědeckých objevů</p>
        </div>
        <div class="bento-card p-4 text-center">
          <p class="text-3xl font-black text-violet-500">{categoryCounts.conservation ?? 0}</p>
          <p class="text-xs text-muted-foreground mt-1">ochranářských kroků</p>
        </div>
      </div>
    </div>
  </section>

  <Timeline events={enrichedEvents} />
</BaseLayout>
