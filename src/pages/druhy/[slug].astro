---
export const prerender = true;
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SpeciesHero from "../../components/species/SpeciesHero.astro";
import SpeciesFacts from "../../components/species/SpeciesFacts.astro";
import SpeciesSources from "../../components/species/SpeciesSources.astro";
import SpeciesGallery from "../../components/species/SpeciesGallery.astro";
import SpeciesMap from "../../components/species/SpeciesMap.astro";
import SpeciesMedia from "../../components/species/SpeciesMedia.astro";
import SpeciesRelated from "../../components/species/SpeciesRelated.astro";
import SpeciesNav from "../../components/species/SpeciesNav.astro";
import Schema from "../../components/seo/Schema.astro";
import { getImage } from "astro:assets";
import { sortedSpecies } from "../../lib/species-of-day";
import { getRelatedSpecies } from "../../lib/species-related";

export const getStaticPaths = (async () => {
  const species = sortedSpecies(await getCollection("species"));
  return species.map((entry, i) => {
    const prev = species[(i - 1 + species.length) % species.length];
    const next = species[(i + 1) % species.length];
    return {
      params: { slug: entry.id },
      props: {
        entry,
        prev: { slug: prev.id, name: prev.data.nameCs },
        next: { slug: next.id, name: next.data.nameCs },
      },
    };
  });
}) satisfies GetStaticPaths;

const { entry, prev, next } = Astro.props;

let Content: Awaited<ReturnType<typeof render>>["Content"] | null = null;
try {
  ({ Content } = await render(entry));
} catch (err) {
  // Markdown body se nepodařilo zrenderovat — místo crashe stránku necháme s fallbackem.
  console.error(`render() failed for species ${entry.id}:`, err);
}

const allSpecies = await getCollection("species");
const relatedSpecies = getRelatedSpecies(entry, allSpecies, 4);

const { nameCs, nameLat, description, historicalNotes, gallery, hero, colonies, audio, video } = entry.data;
void audio; void video; // používají se v <SpeciesMedia /> přes entry, lokální vars zůstávají kvůli původnímu API

const heroImage = await getImage({ src: hero.src, format: "jpeg", width: 1200 });
const heroAbsoluteUrl = new URL(heroImage.src, Astro.site ?? "https://pingupedia.kafe.studio").toString();
const canonicalUrl = new URL(`/druhy/${entry.id}/`, Astro.site ?? "https://pingupedia.kafe.studio").toString();

const metadata = {
  title: `${nameCs} (${nameLat})`,
  description,
  ogImage: hero.src,
  canonical: canonicalUrl,
};

// Stejné menu jako v přehledu druhů — proklik přímo na detail jiného druhu.
const allSpeciesSorted = [...allSpecies].sort((a, b) =>
  a.data.nameCs.localeCompare(b.data.nameCs, "cs"),
);
const navSections = allSpeciesSorted.map((s) => ({
  id: `species-${s.id}`,
  title: s.data.nameCs,
  href: `/druhy/${s.id}/`,
}));
---

<BaseLayout {metadata}>
  <Schema
    slot="head"
    type="BlogPosting"
    data={{
      title: nameCs,
      description,
      image: heroAbsoluteUrl,
      pubDate: entry.data.updatedAt,
      author: "pingupedia",
      url: canonicalUrl,
    }}
  />
  <SpeciesNav sections={navSections} backHref="/druhy/" backLabel="Zpět na všechny druhy" panelLabel="Druhy" />
  <article
    data-pagefind-body
    data-pagefind-meta={`title:${nameCs}, lat:${nameLat}, image[content]:${entry.data.hero.alt}`}
    data-pagefind-filter={`Rod:${entry.data.genus}, IUCN:${entry.data.iucnStatus}`}
  >
    <SpeciesHero species={entry} />

    <section class="px-6 py-12" aria-labelledby="about-heading">
      <div class="mx-auto max-w-3xl">
        <h2 id="about-heading" class="sr-only">O druhu</h2>
        <div class="prose prose-invert prose-lg max-w-none reveal prose-headings:font-bold prose-a:text-primary prose-strong:text-foreground">
          {Content ? <Content /> : <p>{description}</p>}
        </div>
      </div>
    </section>

    <SpeciesFacts species={entry} />

    {colonies && colonies.length > 0 && (
      <SpeciesMap colonies={colonies} speciesName={nameCs} />
    )}

    {historicalNotes && (
      <section class="px-6 py-12" aria-labelledby="history-heading">
        <div class="mx-auto max-w-3xl">
          <h2 id="history-heading" class="text-2xl md:text-3xl font-bold mb-4 reveal">Historie</h2>
          <p class="text-base md:text-lg text-foreground/90 leading-relaxed reveal">
            {historicalNotes}
          </p>
        </div>
      </section>
    )}

    {gallery && gallery.length > 0 && (
      <SpeciesGallery photos={gallery} hero={hero} galleryId={`gallery-${entry.id}`} />
    )}

    <SpeciesMedia species={entry} />

    <SpeciesRelated species={relatedSpecies} currentGenus={entry.data.genus} />

    <SpeciesSources species={entry} />

    <nav class="px-6 pb-20 reveal" aria-label="Navigace mezi druhy">
      <div class="mx-auto max-w-5xl">
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4">
          <a
            href={`/druhy/${prev.slug}/`}
            data-astro-prefetch
            data-nav-prev
            class="group rounded-2xl border border-border bg-card hover:border-border-interactive transition-all p-4 md:p-5 flex items-center gap-3"
          >
            <span class="shrink-0 flex h-10 w-10 items-center justify-center rounded-full bg-muted group-hover:bg-primary/15 group-hover:text-primary text-lg transition-colors">←</span>
            <span class="min-w-0">
              <span class="block text-[10px] uppercase tracking-widest text-muted-foreground">Předchozí</span>
              <span class="block text-sm md:text-base font-bold truncate">{prev.name}</span>
            </span>
          </a>
          <a
            href="/druhy/"
            data-astro-prefetch
            class="hidden md:flex rounded-2xl border border-dashed border-border hover:border-border-interactive transition-colors p-4 md:p-5 items-center justify-center text-sm font-medium text-muted-foreground hover:text-primary"
          >
            ⌂ Všechny druhy
          </a>
          <a
            href={`/druhy/${next.slug}/`}
            data-astro-prefetch
            data-nav-next
            class="group rounded-2xl border border-border bg-card hover:border-border-interactive transition-all p-4 md:p-5 flex items-center gap-3 justify-end text-right"
          >
            <span class="min-w-0">
              <span class="block text-[10px] uppercase tracking-widest text-muted-foreground">Další</span>
              <span class="block text-sm md:text-base font-bold truncate">{next.name}</span>
            </span>
            <span class="shrink-0 flex h-10 w-10 items-center justify-center rounded-full bg-muted group-hover:bg-primary/15 group-hover:text-primary text-lg transition-colors">→</span>
          </a>
        </div>
        <a
          href="/druhy/"
          data-astro-prefetch
          class="md:hidden mt-4 block text-center text-sm font-medium text-muted-foreground hover:text-primary transition-colors"
        >
          ⌂ Všechny druhy
        </a>
      </div>
    </nav>
  </article>
  <script is:inline define:vars={{ prevHref: `/druhy/${prev.slug}/`, nextHref: `/druhy/${next.slug}/` }}>
    // Klavesove sipky + swipe gesta pro navigaci mezi druhy.
    (function () {
      const onKey = (e) => {
        if (e.target && ["INPUT", "TEXTAREA", "SELECT"].includes(e.target.tagName)) return;
        if (e.metaKey || e.ctrlKey || e.altKey) return;
        if (e.key === "ArrowLeft") { e.preventDefault(); window.location.href = prevHref; }
        else if (e.key === "ArrowRight") { e.preventDefault(); window.location.href = nextHref; }
      };
      document.addEventListener("keydown", onKey);

      let startX = 0, startY = 0, startT = 0;
      const onStart = (e) => {
        const t = e.changedTouches[0];
        startX = t.clientX; startY = t.clientY; startT = Date.now();
      };
      const onEnd = (e) => {
        const t = e.changedTouches[0];
        const dx = t.clientX - startX;
        const dy = t.clientY - startY;
        const dt = Date.now() - startT;
        if (dt > 600) return;
        if (Math.abs(dx) < 60 || Math.abs(dx) < Math.abs(dy) * 2) return;
        if (dx < 0) window.location.href = nextHref;
        else window.location.href = prevHref;
      };
      document.addEventListener("touchstart", onStart, { passive: true });
      document.addEventListener("touchend", onEnd, { passive: true });
    })();
  </script>
</BaseLayout>
