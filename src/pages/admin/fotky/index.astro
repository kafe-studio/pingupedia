---
export const prerender = false;
import AdminLayout from "../../../layouts/AdminLayout.astro";
---

<AdminLayout title="Fotky" section="fotky">
  <header class="mb-8">
    <h1 class="text-3xl md:text-4xl font-black tracking-tight">Fotky</h1>
    <p class="mt-2 text-muted-foreground">Hero a galerie druhů &mdash; nahrávání do R2 s licenčními metadaty.</p>
  </header>
  <div class="rounded-2xl border border-dashed border-border bg-card/50 p-10 text-center">
    <p class="text-lg font-semibold mb-2">Skafold připravený</p>
    <p class="text-sm text-muted-foreground max-w-md mx-auto">
      Přijde v Runu&nbsp;014 spolu s R2 bindingem a TipTap editorem pro body text.
    </p>
  </div>
</AdminLayout>
