---
export const prerender = false;
import AdminLayout from "../../../layouts/AdminLayout.astro";
import SpeciesForm from "../../../components/admin/SpeciesForm.astro";

const { slug } = Astro.params;
if (!slug || !/^[a-z0-9-]+$/.test(slug)) {
  return new Response("Invalid slug", { status: 400 });
}
---

<AdminLayout title={`Editace: ${slug}`} section="druhy">
  <nav class="mb-4 text-sm" aria-label="Drobečková navigace">
    <a href="/admin/druhy/" class="text-muted-foreground hover:text-primary transition-colors">← Všechny druhy</a>
  </nav>

  <header class="mb-6 flex items-end justify-between gap-4">
    <div>
      <p class="text-xs uppercase tracking-widest text-primary font-semibold mb-2">Strukturovaný editor</p>
      <h1 class="text-3xl md:text-4xl font-black tracking-tight break-all">
        <code class="font-mono">{slug}.md</code>
      </h1>
    </div>
  </header>

  <section id="loading" class="rounded-2xl border border-border bg-card p-10 text-center text-muted-foreground">
    Načítám obsah z GitHub…
  </section>

  <section id="error" class="hidden rounded-2xl border border-red-400/40 bg-red-500/10 p-6">
    <p class="font-semibold text-red-200">Chyba</p>
    <p id="error-message" class="mt-1 text-sm text-red-100"></p>
  </section>

  <SpeciesForm slug={slug} />

  <script>
    import { mountSpeciesForm } from "../../../lib/admin/species-form-client";
    mountSpeciesForm();
  </script>
</AdminLayout>
