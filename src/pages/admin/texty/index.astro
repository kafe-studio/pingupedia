---
export const prerender = false;
import AdminLayout from "../../../layouts/AdminLayout.astro";
---

<AdminLayout title="Texty" section="texty">
  <header class="mb-8">
    <h1 class="text-3xl md:text-4xl font-black tracking-tight">Texty</h1>
    <p class="mt-2 text-muted-foreground">Homepage, /o-projektu/, hry a kvíz &mdash; plochá key-value editace.</p>
  </header>
  <div class="rounded-2xl border border-dashed border-border bg-card/50 p-10 text-center">
    <p class="text-lg font-semibold mb-2">Skafold připravený</p>
    <p class="text-sm text-muted-foreground max-w-md mx-auto">
      Přijde v Runu&nbsp;013 po refaktoru stránek na <code class="text-xs bg-muted px-1.5 py-0.5 rounded">t('klíč')</code> vzor.
    </p>
  </div>
</AdminLayout>
