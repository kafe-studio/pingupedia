---
export const prerender = false;
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { getSiteConfig } from "../../../lib/site";

const site = await getSiteConfig();

const entries: Array<{
  id: string;
  href: string;
  title: string;
  description: string;
  status: "ready" | "soon";
  badge?: string;
}> = [
  {
    id: "site/config",
    href: "/admin/texty/site/",
    title: "Site config",
    description: "Název, popis, navigace, social links — viditelné v hlavičce, patičce a SEO.",
    status: "ready",
    badge: site.name,
  },
  {
    id: "page/home",
    href: "/admin/texty/home/",
    title: "Homepage",
    description: "Hero text + bento karty na úvodní stránce.",
    status: "ready",
  },
  {
    id: "page/o-projektu",
    href: "#",
    title: "O projektu",
    description: "Sekce O projektu — záměr, zdroje, pravidla obrázků, statistiky.",
    status: "soon",
  },
  {
    id: "page/hry",
    href: "#",
    title: "Hry — rozcestník",
    description: "Popisky 4 mini-her.",
    status: "soon",
  },
  {
    id: "quiz",
    href: "#",
    title: "Kvíz",
    description: "5 kvízových otázek + odpovědi.",
    status: "soon",
  },
];
---

<AdminLayout title="Texty" section="texty">
  <header class="mb-8">
    <p class="text-xs uppercase tracking-widest text-primary font-semibold mb-2">Editace obsahu</p>
    <h1 class="text-3xl md:text-4xl font-black tracking-tight">Texty na webu</h1>
    <p class="mt-2 text-muted-foreground max-w-2xl">
      Obecné texty, které nejsou součástí stránek druhů. Každá editace vytvoří commit na <code class="text-xs bg-muted px-1 rounded">main</code>.
    </p>
  </header>

  <ul role="list" class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {entries.map((e) => (
      <li>
        <a
          href={e.href}
          aria-disabled={e.status === "soon"}
          class:list={[
            "group block rounded-2xl border p-5 transition-all",
            e.status === "ready"
              ? "border-border bg-card hover:border-border-interactive hover:-translate-y-0.5"
              : "border-dashed border-border bg-card/40 pointer-events-none opacity-60",
          ]}
        >
          <div class="flex items-start justify-between gap-3 mb-2">
            <h2 class="text-xl font-bold group-hover:text-primary transition-colors">{e.title}</h2>
            {e.badge && (
              <span class="shrink-0 rounded-full bg-primary/15 px-2.5 py-0.5 text-xs font-semibold text-primary">
                {e.badge}
              </span>
            )}
          </div>
          <p class="text-sm text-muted-foreground mb-3">{e.description}</p>
          <p class="text-[10px] uppercase tracking-widest text-muted-foreground/70 font-semibold">
            {e.status === "ready" ? "→ upravit" : "dostupné brzy"}
          </p>
        </a>
      </li>
    ))}
  </ul>
</AdminLayout>
