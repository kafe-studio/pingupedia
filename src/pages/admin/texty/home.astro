---
export const prerender = false;
import AdminLayout from "../../../layouts/AdminLayout.astro";

const inputCls =
  "w-full rounded-lg border border-border-interactive bg-background px-3 py-2 text-sm focus:outline-none focus:border-primary";
const labelCls = "block text-sm font-semibold mb-1.5";
const sectionCls = "rounded-2xl border border-border bg-card p-6 space-y-4";
const sectionTitleCls =
  "text-xs uppercase tracking-widest text-primary font-semibold mb-3";
const hintCls = "text-xs text-muted-foreground";
---

<AdminLayout title="Homepage" section="texty">
  <nav class="mb-4 text-sm" aria-label="Drobečková navigace">
    <a href="/admin/texty/" class="text-muted-foreground hover:text-primary transition-colors">← Všechny texty</a>
  </nav>

  <header class="mb-6">
    <p class="text-xs uppercase tracking-widest text-primary font-semibold mb-2">Strukturovaný editor</p>
    <h1 class="text-3xl md:text-4xl font-black tracking-tight">Homepage</h1>
    <p class="mt-2 text-muted-foreground max-w-2xl">
      Hero, bento karty a CTA na úvodní stránce <code class="text-xs bg-muted px-1 rounded">/</code>. Slug druhů a obrázky zůstávají pevné, edituje se jen text.
    </p>
  </header>

  <section id="loading" class="rounded-2xl border border-border bg-card p-10 text-center text-muted-foreground">
    Načítám obsah z GitHub…
  </section>

  <section id="error" class="hidden rounded-2xl border border-red-400/40 bg-red-500/10 p-6">
    <p class="font-semibold text-red-200">Chyba</p>
    <p id="error-message" class="mt-1 text-sm text-red-100"></p>
  </section>

  <form id="edit-form" class="hidden space-y-6" data-id="page/home">
    <input type="hidden" id="file-sha" />

    <section class={sectionCls}>
      <p class={sectionTitleCls}>Hero</p>
      <div>
        <label class={labelCls} for="heroEyebrow">Eyebrow</label>
        <input id="heroEyebrow" type="text" required class={inputCls} />
      </div>
      <div>
        <label class={labelCls} for="heroTitleHtml">Nadpis (HTML — <code>&lt;span&gt;</code>, <code>&lt;br /&gt;</code> povolené)</label>
        <textarea id="heroTitleHtml" required rows="3" class={`${inputCls} font-mono text-xs leading-relaxed`}></textarea>
        <p class={hintCls}>Příklad: <code>{`Pozná<span class="text-primary">š</span> všech<br />...`}</code></p>
      </div>
      <div>
        <label class={labelCls} for="heroSubtitle">Podnadpis</label>
        <textarea id="heroSubtitle" required rows="2" class={inputCls}></textarea>
      </div>
    </section>

    <section class={sectionCls}>
      <p class={sectionTitleCls}>Tučňák týdne (hlavní karta)</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class={labelCls} for="featuredBadge">Štítek</label>
          <input id="featuredBadge" type="text" required class={inputCls} />
        </div>
        <div>
          <label class={labelCls} for="featuredSlug">Slug druhu (readonly)</label>
          <input id="featuredSlug" type="text" readonly class={`${inputCls} font-mono opacity-70`} />
        </div>
      </div>
      <div>
        <label class={labelCls} for="featuredTitleHtml">Nadpis (HTML povolené)</label>
        <textarea id="featuredTitleHtml" required rows="2" class={`${inputCls} font-mono text-xs`}></textarea>
      </div>
      <div>
        <label class={labelCls} for="featuredDescription">Popis</label>
        <textarea id="featuredDescription" required rows="3" class={inputCls}></textarea>
      </div>
      <div>
        <label class={labelCls} for="featuredImageAlt">Alt text obrázku</label>
        <input id="featuredImageAlt" type="text" required class={inputCls} />
      </div>
    </section>

    <section class={sectionCls}>
      <p class={sectionTitleCls}>Statistiky (druhů celkem)</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class={labelCls} for="statsEyebrow">Eyebrow</label>
          <input id="statsEyebrow" type="text" required class={inputCls} />
        </div>
        <div>
          <label class={labelCls} for="statsSubtitle">Podnadpis</label>
          <input id="statsSubtitle" type="text" required class={inputCls} />
        </div>
      </div>
    </section>

    <section class={sectionCls}>
      <p class={sectionTitleCls}>Katalog CTA</p>
      <div>
        <label class={labelCls} for="catalogEyebrow">Eyebrow</label>
        <input id="catalogEyebrow" type="text" required class={inputCls} />
      </div>
      <div>
        <label class={labelCls} for="catalogTitleHtml">Nadpis (HTML povolené)</label>
        <textarea id="catalogTitleHtml" required rows="2" class={`${inputCls} font-mono text-xs`}></textarea>
      </div>
      <div>
        <label class={labelCls} for="catalogSubtitle">Podnadpis</label>
        <input id="catalogSubtitle" type="text" required class={inputCls} />
      </div>
    </section>

    <section class={sectionCls}>
      <p class={sectionTitleCls}>Karty druhů na homepage</p>
      <p class={hintCls}>Jedna karta na řádek, formát <code>slug | Rod Xxx | Název druhu | Alt text</code>. Slug musí odpovídat souboru <code>src/assets/penguins/&lt;slug&gt;/hero.jpg</code>.</p>
      <textarea
        id="speciesCards"
        required
        rows="4"
        class={`${inputCls} font-mono text-xs`}
      ></textarea>
    </section>

    <section class={sectionCls}>
      <p class={sectionTitleCls}>Sekce „Jak to děláme"</p>
      <div>
        <label class={labelCls} for="howEyebrow">Eyebrow</label>
        <input id="howEyebrow" type="text" required class={inputCls} />
      </div>
      <div>
        <label class={labelCls} for="howTitleHtml">Nadpis (HTML povolené)</label>
        <textarea id="howTitleHtml" required rows="2" class={`${inputCls} font-mono text-xs`}></textarea>
      </div>
      <div>
        <label class={labelCls} for="howItems">Bullet pointy (jeden na řádek)</label>
        <textarea id="howItems" required rows="4" class={inputCls}></textarea>
      </div>
    </section>

    <section class={sectionCls}>
      <p class={sectionTitleCls}>O projektu CTA</p>
      <div>
        <label class={labelCls} for="aboutEyebrow">Eyebrow</label>
        <input id="aboutEyebrow" type="text" required class={inputCls} />
      </div>
      <div>
        <label class={labelCls} for="aboutTitleHtml">Nadpis (HTML povolené)</label>
        <textarea id="aboutTitleHtml" required rows="2" class={`${inputCls} font-mono text-xs`}></textarea>
      </div>
      <div>
        <label class={labelCls} for="aboutDescription">Popis</label>
        <textarea id="aboutDescription" required rows="2" class={inputCls}></textarea>
      </div>
    </section>

    <section class={sectionCls}>
      <p class={sectionTitleCls}>Commit</p>
      <div>
        <label class={labelCls} for="message">Commit message</label>
        <input
          id="message"
          type="text"
          required
          minlength="5"
          maxlength="100"
          value="Edit homepage: "
          class={inputCls}
        />
      </div>
      <div class="flex items-center justify-between gap-4 pt-2">
        <a href="/admin/texty/" class="btn-outline px-4 py-2 text-sm">Zrušit</a>
        <button type="submit" id="submit-btn" class="btn-primary px-6 py-2.5">Uložit a commit</button>
      </div>
      <div
        id="commit-result"
        class="hidden rounded-lg border border-emerald-400/40 bg-emerald-500/10 p-4 text-sm"
      >
        <p class="font-semibold text-emerald-200">✓ Uloženo</p>
        <p class="mt-1 text-emerald-100">
          Commit: <a id="commit-link" href="#" rel="noopener noreferrer" target="_blank" class="underline"></a>
        </p>
        <p class="mt-1 text-xs text-emerald-100/70">Deploy na produkci proběhne po rebuildu CF Workers.</p>
      </div>
    </section>
  </form>

  <script>
    import { mountHomeForm } from "../../../lib/admin/home-form-client";
    mountHomeForm();
  </script>
</AdminLayout>
