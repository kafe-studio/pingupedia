---
export const prerender = true;
import type { ImageMetadata } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import NoCropImage from "../../components/media/NoCropImage.astro";
import Mascot from "../../components/mascot/Mascot.astro";
import { getChovyPage } from "../../lib/pages";

const page = await getChovyPage();

const heroImages = import.meta.glob("../../assets/penguins/*/hero.jpg", {
  eager: true,
  import: "default",
}) as Record<string, ImageMetadata>;

function heroBySlug(slug: string): ImageMetadata | undefined {
  return heroImages[`../../assets/penguins/${slug}/hero.jpg`];
}

type FacilityCard = (typeof page.facilities)[number] & {
  speciesImages: { slug: string; name: string; img: ImageMetadata }[];
};

const facilities: FacilityCard[] = page.facilities.map((f) => ({
  ...f,
  speciesImages: f.species
    .map((sp) => {
      const img = heroBySlug(sp.slug);
      return img ? { slug: sp.slug, name: sp.name, img } : null;
    })
    .filter((x): x is { slug: string; name: string; img: ImageMetadata } => x !== null),
}));

const totalFacilities = page.facilities.length;
const uniqueSpecies = new Set(page.facilities.flatMap((f) => f.species.map((sp) => sp.slug))).size;
const countries = new Set(page.facilities.map((f) => f.countryCode)).size;

const metadata = {
  title: page.meta.title,
  description: page.meta.description,
};
---

<BaseLayout {metadata}>
  <section class="px-4 sm:px-6 pt-28 pb-8">
    <div class="mx-auto max-w-7xl">
      <header class="mb-10 md:mb-14 flex flex-col md:flex-row md:items-end md:justify-between gap-6 reveal">
        <div class="max-w-2xl">
          <p class="text-sm uppercase tracking-[0.2em] text-primary/80 mb-4">{page.hero.eyebrow}</p>
          <h1 class="text-4xl md:text-6xl lg:text-7xl font-black tracking-tight leading-[0.95] mb-5">
            <Fragment set:html={page.hero.titleHtml} />
          </h1>
          <p class="text-lg md:text-xl text-muted-foreground">{page.hero.subtitle}</p>
        </div>
        <div class="shrink-0 self-center md:self-end anim-bob">
          <Mascot pose="ahoj" size={160} />
        </div>
      </header>

      <div class="grid grid-cols-3 gap-3 md:gap-4 mb-10 md:mb-14">
        <div class="bento-card p-4 md:p-6 text-center">
          <p class="text-3xl md:text-5xl font-black text-foreground leading-none">{totalFacilities}</p>
          <p class="mt-2 text-xs md:text-sm uppercase tracking-widest text-muted-foreground">chovů</p>
        </div>
        <div class="bento-card p-4 md:p-6 text-center">
          <p class="text-3xl md:text-5xl font-black text-foreground leading-none">{uniqueSpecies}</p>
          <p class="mt-2 text-xs md:text-sm uppercase tracking-widest text-muted-foreground">druhů</p>
        </div>
        <div class="bento-card p-4 md:p-6 text-center">
          <p class="text-3xl md:text-5xl font-black text-foreground leading-none">{countries}</p>
          <p class="mt-2 text-xs md:text-sm uppercase tracking-widest text-muted-foreground">zemí</p>
        </div>
      </div>
    </div>
  </section>

  <section class="px-4 sm:px-6 pb-20">
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
        {facilities.map((f) => (
          <article class="bento-card p-5 md:p-6 flex flex-col gap-4 reveal">
            <div class="aspect-[16/10] rounded-xl overflow-hidden bg-muted/40">
              {f.speciesImages.length === 1 && (
                <div class="w-full h-full">
                  <NoCropImage
                    src={f.speciesImages[0].img}
                    alt={f.speciesImages[0].name}
                    ratio="16/10"
                    sizes="(min-width: 1024px) 360px, (min-width: 640px) 440px, 90vw"
                    widths={[360, 720]}
                  />
                </div>
              )}
              {f.speciesImages.length === 2 && (
                <div class="grid grid-cols-2 gap-1 w-full h-full p-1">
                  {f.speciesImages.map((sp) => (
                    <div class="rounded-lg overflow-hidden bg-muted">
                      <NoCropImage
                        src={sp.img}
                        alt={sp.name}
                        ratio="1/1"
                        sizes="(min-width: 1024px) 180px, (min-width: 640px) 220px, 45vw"
                        widths={[180, 360]}
                      />
                    </div>
                  ))}
                </div>
              )}
              {f.speciesImages.length === 3 && (
                <div class="grid grid-cols-3 gap-1 w-full h-full p-1">
                  {f.speciesImages.map((sp) => (
                    <div class="rounded-lg overflow-hidden bg-muted">
                      <NoCropImage
                        src={sp.img}
                        alt={sp.name}
                        ratio="1/1"
                        sizes="(min-width: 1024px) 120px, (min-width: 640px) 145px, 30vw"
                        widths={[120, 240]}
                      />
                    </div>
                  ))}
                </div>
              )}
              {f.speciesImages.length >= 4 && (
                <div class="grid grid-cols-2 gap-1 w-full h-full p-1">
                  {f.speciesImages.slice(0, 4).map((sp) => (
                    <div class="rounded-lg overflow-hidden bg-muted">
                      <NoCropImage
                        src={sp.img}
                        alt={sp.name}
                        ratio="1/1"
                        sizes="(min-width: 1024px) 180px, (min-width: 640px) 220px, 45vw"
                        widths={[180, 360]}
                      />
                    </div>
                  ))}
                </div>
              )}
            </div>

            <div class="flex items-center gap-2 text-xs uppercase tracking-widest text-muted-foreground">
              <span class="inline-flex items-center justify-center min-w-[2rem] px-2 py-0.5 rounded-md bg-muted/60 font-bold text-foreground">
                {f.countryCode}
              </span>
              <span>{f.country} · {f.city}</span>
            </div>

            <div>
              <h2 class="text-xl md:text-2xl font-black leading-tight mb-2">{f.name}</h2>
              {f.highlight && (
                <p class="inline-flex items-center gap-1.5 text-xs font-semibold text-accent mb-2">
                  <span class="inline-block h-1.5 w-1.5 rounded-full bg-accent" aria-hidden="true"></span>
                  {f.highlight}
                </p>
              )}
              <p class="text-sm text-muted-foreground leading-relaxed">{f.description}</p>
            </div>

            <div class="flex flex-wrap gap-1.5 mt-auto">
              {f.species.map((sp) => (
                <a
                  href={`/druhy/${sp.slug}/`}
                  data-astro-prefetch
                  class="text-xs font-medium px-2.5 py-1 rounded-full bg-muted/60 text-foreground/80 hover:bg-primary/15 hover:text-primary transition-colors"
                >
                  {sp.name}
                </a>
              ))}
            </div>

            <a
              href={f.url}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary hover:underline"
            >
              Oficiální web ↗
            </a>
          </article>
        ))}
      </div>

      <p class="mt-12 text-xs text-muted-foreground text-center max-w-3xl mx-auto">
        Přehled není vyčerpávající — soustředí se na zařízení s dlouhodobým chovem a několika druhy. Údaje o druzích vychází z oficiálních webů jednotlivých zoologických zahrad. Pokud víš o dalším evropském chovu, který by tu měl být, dej vědět.
      </p>
    </div>
  </section>
</BaseLayout>
