---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import Mascot from "../components/mascot/Mascot.astro";
import { getOProjektuPage } from "../lib/pages";

const page = await getOProjektuPage();

const metadata = {
  title: page.meta.title,
  description: page.meta.description,
};
---

<BaseLayout {metadata}>
  <section class="px-4 sm:px-6 pt-28 pb-24">
    <div class="mx-auto max-w-3xl">
      <header class="mb-10 md:mb-14 text-center reveal">
        <h1 class="text-5xl md:text-7xl font-black tracking-tight leading-[0.95] mb-5">
          <Fragment set:html={page.hero.titleHtml} />
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto">{page.hero.subtitle}</p>
      </header>

      <div class="bento-card bento-surface-aurora p-6 md:p-8 text-white reveal mb-6 flex items-center gap-5">
        <div class="shrink-0 anim-float">
          <Mascot pose="srdce" size={72} />
        </div>
        <p class="text-base md:text-lg leading-relaxed italic text-white/90">
          {page.personalNote.body}
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-5 mb-6">
        <div class="bento-card bento-surface-ocean p-6 md:p-7 text-white reveal">
          <p class="text-xs uppercase tracking-widest text-accent font-semibold mb-3">{page.sources.eyebrow}</p>
          <ul class="space-y-2 text-sm">
            {page.sources.items.map((item) => (
              <li class="flex items-start gap-2"><span class="text-accent mt-0.5">✓</span><span>{item}</span></li>
            ))}
          </ul>
        </div>

        <article class="bento-card p-6 md:p-7 reveal">
          <p class="text-xs uppercase tracking-widest text-primary font-semibold mb-3">{page.purpose.eyebrow}</p>
          <h2 class="text-xl md:text-2xl font-black leading-tight mb-3">{page.purpose.title}</h2>
          <p class="text-sm text-muted-foreground leading-relaxed">{page.purpose.body}</p>
        </article>
      </div>

      <footer class="bento-card p-6 md:p-8 reveal flex flex-col sm:flex-row items-center sm:items-start gap-5 sm:gap-6">
        <div class="shrink-0 flex items-center gap-2.5">
          <span class="w-12 h-12 rounded-2xl bg-gradient-to-br from-amber-500 via-rose-500 to-fuchsia-500 text-white font-black text-xl flex items-center justify-center shadow-lg">K</span>
          <span class="text-xl font-black tracking-tight">{page.credits.studio}</span>
        </div>
        <div class="flex-1 text-center sm:text-left">
          <p class="text-sm text-muted-foreground mb-2">
            Vytvořeno <span class="font-semibold text-foreground">{page.credits.author}</span> ve studiu <span class="font-semibold text-foreground">{page.credits.studio}</span>.
          </p>
          <p class="text-sm flex flex-wrap gap-x-4 gap-y-1 justify-center sm:justify-start">
            <a href={`mailto:${page.credits.email}`} class="text-primary hover:underline">{page.credits.email}</a>
            <a href={page.credits.portfolioUrl} rel="noopener noreferrer" target="_blank" class="text-primary hover:underline">{page.credits.portfolioLabel}</a>
          </p>
        </div>
      </footer>
    </div>
  </section>
</BaseLayout>
