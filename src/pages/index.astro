---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config/site";
const metadata = {
  title: siteConfig.name,
  description: siteConfig.description,
  ignoreTitleTemplate: true,
};
---

<BaseLayout {metadata}>
  <section class="min-h-[80vh] flex items-center justify-center text-center px-6 pt-24">
    <div class="max-w-3xl">
      <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-6 reveal">
        pingupedia
      </h1>
      <p class="text-lg md:text-2xl text-muted-foreground mb-4 reveal">
        Encyklopedie tučňáků&nbsp;— všech <strong>18 druhů</strong>, česky, pro děti i dospělé.
      </p>
      <p class="text-base md:text-lg text-muted-foreground mb-10 reveal">
        Fotky, mapy, historie, ověřené zdroje. Žádné výmysly, žádné ořezané fotky.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 reveal">
        <a href="/druhy/" class="btn-primary">Prozkoumat druhy</a>
        <a href="/o-projektu/" class="btn-outline">O projektu</a>
      </div>
    </div>
  </section>
</BaseLayout>
