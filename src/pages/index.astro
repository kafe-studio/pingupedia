---
// Prerender:true — homepage je staticky vygenerovaná při buildu, takže obrázky
// jsou /_astro/<hash>.webp soubory (servírované přes ASSETS binding), ne přes
// runtime /_image/ endpoint, který opakovaně způsoboval cache-poisoning 500ek
// z flapping CF Images bindingu. „Tučňák dne" se vybírá při buildu (Date.now()
// při wrangler deploy) — každý deploy → nový druh dne.
export const prerender = true;
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import NoCropImage from "../components/media/NoCropImage.astro";
import Mascot from "../components/mascot/Mascot.astro";
import pinguHero from "../assets/mascot/pingu-hero.png";
import { getSiteConfig } from "../lib/site";
import { getHomePage } from "../lib/pages";
import { pickSpeciesOfDay } from "../lib/species-of-day";
import { getCollection } from "astro:content";

const siteConfig = await getSiteConfig();
const home = await getHomePage();
const species = await getCollection("species");
const total = species.length;

const heroImages = import.meta.glob("../assets/penguins/*/hero.jpg", {
  eager: true,
  import: "default",
}) as Record<string, ImageMetadata>;

function heroBySlug(slug: string): ImageMetadata | undefined {
  return heroImages[`../assets/penguins/${slug}/hero.jpg`];
}

// Druh, který reprezentuje sekci Chovy v homepage banneru — záměrně jiný,
// aby se na hlavní stránce nikdy neopakoval stejný hero photo.
const CHOVY_BANNER_SPECIES = "skalni-jizni";

// Druhy už zobrazené staticky v section cards (jeden hero photo na sekci)
// + v Chovy banneru. Tučňák dne se vybírá z pool BEZ těchto druhů, takže
// na homepage nejsou nikdy dva stejné obrázky najednou.
const usedSlugs = new Set<string>([
  CHOVY_BANNER_SPECIES,
  ...home.sections
    .filter((s): s is typeof s & { speciesSlug: string } =>
      s.preview === "species-photo" && typeof s.speciesSlug === "string",
    )
    .map((s) => s.speciesSlug),
]);

const speciesWithHero = species.filter((s) => heroBySlug(s.id) !== undefined);
const speciesPoolForDayPicker = speciesWithHero.filter((s) => !usedSlugs.has(s.id));
const speciesOfDay = pickSpeciesOfDay(
  speciesPoolForDayPicker.length ? speciesPoolForDayPicker : speciesWithHero,
);
const featuredImage = heroBySlug(speciesOfDay.id) ?? heroImages[Object.keys(heroImages)[0]];

const featured = {
  slug: speciesOfDay.id,
  name: speciesOfDay.data.nameCs,
  genus: speciesOfDay.data.genus,
  description: speciesOfDay.data.description,
  imageAlt: speciesOfDay.data.hero.alt,
};

const gameImages = import.meta.glob("../assets/games/*.png", {
  eager: true,
  import: "default",
}) as Record<string, ImageMetadata>;
function gameImageByName(name: string): ImageMetadata | undefined {
  return gameImages[`../assets/games/${name}.png`];
}

const timelineImages = import.meta.glob("../assets/timeline/*.{jpg,jpeg,png,webp}", {
  eager: true,
  import: "default",
}) as Record<string, ImageMetadata>;
function timelineImageByFile(file: string): ImageMetadata | undefined {
  return timelineImages[`../assets/timeline/${file}`];
}

type SectionCard = (typeof home.sections)[number] & {
  mosaicImages?: ImageMetadata[];
  speciesImg?: ImageMetadata;
  gameImg?: ImageMetadata;
  timelineImg?: ImageMetadata;
};

const sections: SectionCard[] = home.sections.map((s) => {
  if (s.preview === "species-mosaic" && s.speciesSlugs) {
    const imgs = s.speciesSlugs
      .map((slug) => heroBySlug(slug))
      .filter((img): img is ImageMetadata => img !== undefined);
    return { ...s, mosaicImages: imgs };
  }
  if (s.preview === "species-photo" && s.speciesSlug) {
    return { ...s, speciesImg: heroBySlug(s.speciesSlug) };
  }
  if (s.preview === "game-image" && s.gameImage) {
    return { ...s, gameImg: gameImageByName(s.gameImage) };
  }
  if (s.preview === "timeline-photo" && s.timelineFile) {
    return { ...s, timelineImg: timelineImageByFile(s.timelineFile) };
  }
  return s;
});

const surfaceClass: Record<string, string> = {
  aurora: "bento-surface-aurora",
  ocean: "bento-surface-ocean",
  sun: "bento-surface-sun",
  ice: "bento-surface-ice",
  candy: "bento-surface-candy",
};

const metadata = {
  title: siteConfig.name,
  description: siteConfig.description,
  ignoreTitleTemplate: true,
};
---

<BaseLayout {metadata}>
  <section class="px-4 sm:px-6 pt-28 pb-12 md:pb-16">
    <div class="mx-auto max-w-7xl">
      <header class="mb-10 md:mb-16 flex flex-col-reverse sm:flex-row sm:items-center gap-6 md:gap-12">
        <div class="flex-1 min-w-0 max-w-3xl">
          <p class="text-sm uppercase tracking-[0.2em] text-primary/80 mb-4">
            {home.hero.eyebrow}
          </p>
          <h1 class="text-4xl md:text-6xl lg:text-7xl font-black tracking-tight leading-[0.95] mb-5">
            <Fragment set:html={home.hero.titleHtml} />
          </h1>
          <p class="text-lg md:text-xl text-muted-foreground max-w-2xl">{home.hero.subtitle}</p>
        </div>
        <div class="shrink-0 self-center sm:self-auto">
          <Image
            src={pinguHero}
            alt="Tučňáci císařští s mládětem"
            widths={[200, 269, 346, 518]}
            sizes="(min-width: 1024px) 346px, (min-width: 640px) 269px, 200px"
            loading="eager"
            fetchpriority="high"
            class="h-auto w-[200px] sm:w-[269px] md:w-[346px] drop-shadow-2xl scale-x-[-1]"
          />
        </div>
      </header>

      <div class="grid grid-cols-12 gap-4 md:gap-5 mb-10 md:mb-14">
        <a
          href={`/druhy/${featured.slug}/`}
          class="bento-card is-link bento-surface-aurora col-span-12 md:col-span-8 p-6 md:p-8 flex flex-col md:flex-row md:items-stretch gap-6 min-h-[320px] reveal relative"
          data-astro-prefetch
        >
          <div class="md:w-1/2 flex flex-col justify-between">
            <div>
              <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1 text-xs font-semibold text-white/90 backdrop-blur-sm">
                Tučňák dne
              </span>
              <p class="mt-4 text-sm uppercase tracking-widest text-white/60 font-semibold">{featured.genus}</p>
              <h2 class="mt-1 text-3xl md:text-5xl font-black text-white leading-tight">
                {featured.name}
              </h2>
              <p class="mt-3 text-white/80 text-base md:text-lg">
                {featured.description}
              </p>
            </div>
          </div>
          <div class="md:w-1/2 md:flex md:items-end md:justify-end">
            <div class="w-full">
              <NoCropImage
                src={featuredImage}
                alt={featured.imageAlt}
                ratio="4/5"
                sizes="(min-width: 768px) 400px, 100vw"
                widths={[400, 600, 800]}
                class="rounded-2xl overflow-hidden"
                loading="eager"
              />
            </div>
          </div>
          <span class="absolute top-5 right-5 inline-flex h-11 w-11 items-center justify-center rounded-full bg-white/15 text-white backdrop-blur-sm">
            →
          </span>
        </a>

        <div class="bento-card bento-surface-ice col-span-12 md:col-span-4 p-6 md:p-8 flex items-center justify-between gap-4 min-h-[180px] md:min-h-[320px]">
          <div>
            <p class="text-xs uppercase tracking-widest text-accent/90 font-semibold">{home.stats.eyebrow}</p>
            <p class="mt-3 text-7xl md:text-8xl font-black text-white leading-none">{total}</p>
            <p class="mt-2 text-sm text-white/70">{home.stats.subtitle}</p>
          </div>
          <div class="shrink-0 anim-float">
            <Mascot pose="detektiv" size={140} />
          </div>
        </div>
      </div>

      {home.wowFacts && (
        <div class="mb-10 md:mb-14">
          <header class="mb-6 md:mb-8">
            <p class="text-xs uppercase tracking-[0.2em] text-accent font-bold mb-2">{home.wowFacts.eyebrow}</p>
            <h2 class="text-2xl md:text-3xl font-black tracking-tight">{home.wowFacts.title}</h2>
          </header>
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 md:gap-4">
            {home.wowFacts.items.map((f) => (
              <div class:list={[
                "bento-card p-5 md:p-6 flex flex-col gap-3 reveal relative overflow-hidden",
                f.surface ? surfaceClass[f.surface] : "",
              ]}>
                <div class="absolute -bottom-3 -right-3 opacity-25 pointer-events-none">
                  <Mascot pose={f.mascot} size={120} />
                </div>
                <p class:list={[
                  "text-3xl md:text-5xl font-black leading-none tabular-nums",
                  f.surface ? "text-white" : "text-foreground",
                ]}>{f.value}</p>
                <p class:list={[
                  "text-xs md:text-sm leading-snug relative z-10",
                  f.surface ? "text-white/85" : "text-muted-foreground",
                ]}>{f.label}</p>
              </div>
            ))}
          </div>
        </div>
      )}

      <div class="mb-10 md:mb-14">
        <h2 class="text-2xl md:text-3xl font-black tracking-tight mb-6 md:mb-8">
          Co tě tady čeká
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-5">
          {sections.map((s) => (
            <a
              href={s.href}
              data-astro-prefetch
              class:list={[
                "bento-card is-link p-6 flex flex-col gap-5 reveal",
                s.surface ? surfaceClass[s.surface] : "",
              ]}
            >
              <div class:list={[
                "rounded-xl overflow-hidden flex items-center justify-center bg-muted/40",
                s.preview === "species-mosaic" ? "aspect-square" : "aspect-[16/9]",
              ]}>
                {s.preview === "species-mosaic" && s.mosaicImages && s.mosaicImages.length === 4 && (
                  <div class="grid grid-cols-2 gap-1.5 w-full h-full p-1.5">
                    {s.mosaicImages.map((img) => (
                      <div class="rounded-lg overflow-hidden bg-muted">
                        <NoCropImage
                          src={img}
                          alt=""
                          ratio="1/1"
                          sizes="(min-width: 1024px) 160px, (min-width: 640px) 220px, 45vw"
                          widths={[160, 320]}
                        />
                      </div>
                    ))}
                  </div>
                )}
                {s.preview === "game-image" && s.gameImg && (
                  <div class="w-full h-full">
                    <NoCropImage
                      src={s.gameImg}
                      alt=""
                      ratio="16/9"
                      sizes="(min-width: 1024px) 360px, (min-width: 640px) 440px, 90vw"
                      widths={[360, 720]}
                    />
                  </div>
                )}
                {s.preview === "species-photo" && s.speciesImg && (
                  <div class="w-full h-full">
                    <NoCropImage
                      src={s.speciesImg}
                      alt=""
                      ratio="16/9"
                      sizes="(min-width: 1024px) 360px, (min-width: 640px) 440px, 90vw"
                      widths={[360, 720]}
                    />
                  </div>
                )}
                {s.preview === "timeline-photo" && s.timelineImg && (
                  <div class="w-full h-full">
                    <NoCropImage
                      src={s.timelineImg}
                      alt=""
                      ratio="16/9"
                      sizes="(min-width: 1024px) 360px, (min-width: 640px) 440px, 90vw"
                      widths={[360, 720]}
                    />
                  </div>
                )}
              </div>
              <div class="flex-1 flex flex-col">
                <p class:list={[
                  "text-xs uppercase tracking-widest font-semibold mb-1",
                  s.surface ? "text-white/70" : "text-primary/80",
                ]}>{s.eyebrow}</p>
                <h3 class:list={[
                  "text-xl md:text-2xl font-black leading-tight mb-2",
                  s.surface ? "text-white" : "text-foreground",
                ]}>{s.title}</h3>
                <p class:list={[
                  "text-sm leading-relaxed",
                  s.surface ? "text-white/80" : "text-muted-foreground",
                ]}>{s.description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>

      {home.quizCta && (
        <a
          href={home.quizCta.href}
          class="bento-card is-link bento-surface-candy p-6 md:p-10 flex flex-col-reverse md:flex-row md:items-center gap-6 md:gap-10 mb-6 md:mb-8 reveal relative overflow-hidden"
          data-astro-prefetch
        >
          <div class="md:flex-1 min-w-0">
            <p class="text-xs uppercase tracking-widest text-white/70 font-bold">{home.quizCta.eyebrow}</p>
            <h3 class="mt-2 text-3xl md:text-4xl font-black text-white leading-tight">
              <Fragment set:html={home.quizCta.titleHtml} />
            </h3>
            <p class="mt-3 text-white/85 text-base md:text-lg max-w-xl">{home.quizCta.description}</p>
            <span class="inline-flex items-center gap-2 mt-5 px-5 py-2.5 rounded-full bg-white text-foreground font-bold text-sm shadow-lg hover:scale-[1.03] transition-transform">
              {home.quizCta.buttonLabel} →
            </span>
          </div>
          <div class="shrink-0 anim-bob">
            <Mascot pose="otazka" size={180} />
          </div>
        </a>
      )}

      <a
        href="/chovy/"
        class="bento-card is-link bento-surface-ocean p-6 md:p-10 flex flex-col md:flex-row md:items-center gap-6 md:gap-10 mb-6 md:mb-8 reveal relative"
        data-astro-prefetch
      >
        <div class="md:w-2/5">
          {heroBySlug(CHOVY_BANNER_SPECIES) && (
            <div class="rounded-xl overflow-hidden bg-white/5">
              <NoCropImage
                src={heroBySlug(CHOVY_BANNER_SPECIES)!}
                alt=""
                ratio="4/3"
                sizes="(min-width: 768px) 400px, 90vw"
                widths={[400, 800]}
              />
            </div>
          )}
        </div>
        <div class="md:flex-1 min-w-0">
          <p class="text-xs uppercase tracking-widest text-accent font-semibold">Naživo</p>
          <h3 class="mt-2 text-3xl md:text-4xl font-black text-white leading-tight">
            Kam za živými tučňáky <span class="text-accent">v Evropě?</span>
          </h3>
          <p class="mt-3 text-white/80 text-base md:text-lg max-w-xl">
            Praha, Edinburgh, Vídeň, Tenerife. Desítky zoologických zahrad, kde tučňáky uvidíš na vlastní oči. Které druhy kde najdeš a co je na nich zajímavé.
          </p>
        </div>
        <span class="absolute top-5 right-5 inline-flex h-11 w-11 items-center justify-center rounded-full bg-white/15 text-white backdrop-blur-sm">
          →
        </span>
      </a>

      <a
        href="/o-projektu/"
        class="bento-card is-link p-6 md:p-8 flex items-center justify-between gap-6 min-h-[160px]"
        data-astro-prefetch
      >
        <div class="min-w-0">
          <p class="text-xs uppercase tracking-widest text-primary font-semibold">{home.aboutCta.eyebrow}</p>
          <h3 class="mt-2 text-2xl md:text-3xl font-black leading-tight">
            <Fragment set:html={home.aboutCta.titleHtml} />
          </h3>
          <p class="mt-2 text-sm text-muted-foreground max-w-xl">{home.aboutCta.description}</p>
        </div>
        <div class="shrink-0 anim-bob">
          <Mascot pose="srdce" size={140} />
        </div>
      </a>
    </div>
  </section>
</BaseLayout>
