---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config/site";
import NoCropImage from "../components/media/NoCropImage.astro";
import emperorPenguin from "../assets/penguins/emperor-penguin-snow-hill.jpg";
const metadata = {
  title: siteConfig.name,
  description: siteConfig.description,
  ignoreTitleTemplate: true,
};
---

<BaseLayout {metadata}>
  <section class="px-6 pt-32 pb-20">
    <div class="mx-auto max-w-5xl text-center">
      <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-6 reveal">
        pingupedia
      </h1>
      <p class="text-lg md:text-2xl text-muted-foreground mb-4 reveal">
        Encyklopedie tučňáků&nbsp;— všech <strong>18 druhů</strong>, česky, pro děti i dospělé.
      </p>
      <p class="text-base md:text-lg text-muted-foreground mb-10 reveal">
        Fotky, mapy, historie, ověřené zdroje. Žádné výmysly, žádné ořezané fotky.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16 reveal">
        <a href="/druhy/" class="btn-primary" data-astro-prefetch="false">Prozkoumat druhy</a>
        <a href="/o-projektu/" class="btn-outline" data-astro-prefetch="false">O projektu</a>
      </div>
      <figure class="reveal mx-auto max-w-2xl">
        <NoCropImage
          src={emperorPenguin}
          alt="Tučňáci císařští s mládětem na Snow Hill Islandu, Antarktida"
          ratio="872/1400"
          loading="eager"
          sizes="(min-width: 768px) 640px, 100vw"
        />
        <figcaption class="mt-3 text-xs text-muted-foreground">
          Tučňák císařský (<em>Aptenodytes forsteri</em>), Snow Hill Island, Antarktida. Foto&nbsp;Ian Duffy, CC&nbsp;BY&nbsp;2.0.
        </figcaption>
      </figure>
    </div>
  </section>
</BaseLayout>
