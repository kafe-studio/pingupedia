---
export const prerender = false;
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import NoCropImage from "../components/media/NoCropImage.astro";
import Mascot from "../components/mascot/Mascot.astro";
import pinguHero from "../assets/mascot/pingu-hero.png";
import { getSiteConfig } from "../lib/site";
import { getHomePage } from "../lib/pages";
import { pickSpeciesOfDay } from "../lib/species-of-day";
import { getCollection } from "astro:content";

Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=0, s-maxage=3600, stale-while-revalidate=86400",
);

const siteConfig = await getSiteConfig();
const home = await getHomePage();
const species = await getCollection("species");
const total = species.length;

// Eager glob pro hero obrázky druhů — podle slugu z JSON.
const heroImages = import.meta.glob("../assets/penguins/*/hero.jpg", {
  eager: true,
  import: "default",
}) as Record<string, ImageMetadata>;

function heroBySlug(slug: string): ImageMetadata | undefined {
  return heroImages[`../assets/penguins/${slug}/hero.jpg`];
}

// Tučňák dne — rotuje každý UTC den deterministicky přes všechny druhy.
// Pokud hero pro vybraný druh chybí, najdeme první druh, který hero má.
const speciesWithHero = species.filter((s) => heroBySlug(s.id) !== undefined);
const speciesOfDay = pickSpeciesOfDay(speciesWithHero.length ? speciesWithHero : species);
const featuredImage = heroBySlug(speciesOfDay.id) ?? heroImages[Object.keys(heroImages)[0]];

const speciesCards = home.speciesCards
  .map((card) => ({ card, img: heroBySlug(card.slug) }))
  .filter((entry): entry is { card: typeof entry.card; img: ImageMetadata } => entry.img !== undefined);
const featured = {
  slug: speciesOfDay.id,
  name: speciesOfDay.data.nameCs,
  genus: speciesOfDay.data.genus,
  description: speciesOfDay.data.description,
  imageAlt: speciesOfDay.data.hero.alt,
};

const metadata = {
  title: siteConfig.name,
  description: siteConfig.description,
  ignoreTitleTemplate: true,
};
---

<BaseLayout {metadata}>
  <section class="relative px-4 sm:px-6 pt-28 pb-16">
    <div class="mx-auto max-w-7xl">
      <header class="mb-8 md:mb-12 flex flex-col-reverse sm:flex-row sm:items-end gap-6 md:gap-10">
        <div class="flex-1 min-w-0 max-w-3xl">
          <p class="text-sm uppercase tracking-[0.2em] text-primary/80 mb-4">
            {home.hero.eyebrow}
          </p>
          <h1 class="text-5xl md:text-7xl font-black tracking-tight leading-[0.95] mb-4">
            <Fragment set:html={home.hero.titleHtml} />
          </h1>
          <p class="text-lg md:text-xl text-muted-foreground max-w-2xl">{home.hero.subtitle}</p>
        </div>
        <div class="shrink-0 self-center sm:self-auto">
          <Image
            src={pinguHero}
            alt="Tučňáci císařští s mládětem"
            widths={[200, 269, 346, 518]}
            sizes="(min-width: 1024px) 346px, (min-width: 640px) 269px, 200px"
            loading="eager"
            fetchpriority="high"
            class="h-auto w-[200px] sm:w-[269px] md:w-[346px] drop-shadow-2xl scale-x-[-1]"
          />
        </div>
      </header>

      <div class="grid grid-cols-12 auto-rows-[minmax(160px,auto)] gap-4 md:gap-5">
        <a
          href={`/druhy/${featured.slug}/`}
          class="bento-card is-link bento-surface-aurora col-span-12 md:col-span-8 md:row-span-2 p-6 md:p-8 flex flex-col md:flex-row md:items-stretch gap-6 min-h-[360px] reveal"
          data-astro-prefetch
        >
          <div class="md:w-1/2 flex flex-col justify-between">
            <div>
              <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1 text-xs font-semibold text-white/90 backdrop-blur-sm">
                Tučňák dne
              </span>
              <p class="mt-4 text-sm uppercase tracking-widest text-white/60 font-semibold">{featured.genus}</p>
              <h2 class="mt-1 text-3xl md:text-5xl font-black text-white leading-tight">
                {featured.name}
              </h2>
              <p class="mt-3 text-white/80 text-base md:text-lg">
                {featured.description}
              </p>
            </div>
          </div>
          <div class="md:w-1/2 md:flex md:items-end md:justify-end">
            <div class="w-full">
              <NoCropImage
                src={featuredImage}
                alt={featured.imageAlt}
                ratio="4/5"
                sizes="(min-width: 768px) 400px, 100vw"
                widths={[400, 600, 800]}
                class="rounded-2xl overflow-hidden"
                loading="eager"
              />
            </div>
          </div>
          <span class="absolute top-5 right-5 inline-flex h-11 w-11 items-center justify-center rounded-full bg-white/15 text-white backdrop-blur-sm transition group-hover:bg-white">
            →
          </span>
        </a>

        <div class="bento-card bento-surface-ice col-span-6 md:col-span-4 p-6 flex flex-col justify-between min-h-[200px]">
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="text-xs uppercase tracking-widest text-accent/90 font-semibold">{home.stats.eyebrow}</p>
              <p class="mt-2 text-6xl md:text-7xl font-black text-white leading-none">{total}</p>
              <p class="mt-1 text-sm text-white/70">{home.stats.subtitle}</p>
            </div>
            <div class="shrink-0 anim-float">
              <Mascot pose="detektiv" size={140} />
            </div>
          </div>
        </div>

        <a
          href="/druhy/"
          class="bento-card is-link bento-surface-sun col-span-6 md:col-span-4 p-6 flex flex-col justify-between min-h-[200px] reveal"
          data-astro-prefetch
        >
          <div>
            <p class="text-xs uppercase tracking-widest font-bold opacity-80">{home.catalogCta.eyebrow}</p>
            <h3 class="mt-2 text-3xl md:text-4xl font-black leading-tight">
              <Fragment set:html={home.catalogCta.titleHtml} />
            </h3>
          </div>
          <p class="text-sm font-medium opacity-85">{home.catalogCta.subtitle}</p>
        </a>

        {speciesCards.map(({ card, img }) => (
          <a
            href={`/druhy/${card.slug}/`}
            class="bento-card is-link col-span-6 md:col-span-3 p-5 reveal overflow-hidden"
            data-astro-prefetch
          >
            <div class="mb-3 aspect-[4/3] rounded-xl overflow-hidden bg-muted hover-wiggle">
              <NoCropImage
                src={img}
                alt={card.alt}
                ratio="4/3"
                sizes="(min-width: 768px) 280px, 45vw"
                widths={[280, 560]}
              />
            </div>
            <p class="text-xs text-muted-foreground">{card.genus}</p>
            <h3 class="text-lg font-bold mt-0.5">{card.name}</h3>
          </a>
        ))}

        <div class="bento-card bento-surface-ocean col-span-12 md:col-span-6 p-6 md:p-8 flex flex-col justify-between min-h-[220px] reveal">
          <div>
            <p class="text-xs uppercase tracking-widest text-accent font-semibold">{home.howSection.eyebrow}</p>
            <h3 class="mt-3 text-2xl md:text-3xl font-black text-white leading-tight">
              <Fragment set:html={home.howSection.titleHtml} />
            </h3>
          </div>
          <ul class="mt-4 grid grid-cols-2 gap-3 text-sm text-white/85">
            {home.howSection.items.map((item) => (
              <li class="flex items-start gap-2"><span class="text-accent">✓</span> {item}</li>
            ))}
          </ul>
        </div>

        <a
          href="/o-projektu/"
          class="bento-card is-link col-span-12 md:col-span-6 p-6 md:p-8 flex items-center justify-between gap-4 min-h-[180px]"
          data-astro-prefetch
        >
          <div>
            <p class="text-xs uppercase tracking-widest text-primary font-semibold">{home.aboutCta.eyebrow}</p>
            <h3 class="mt-2 text-2xl md:text-3xl font-black leading-tight">
              <Fragment set:html={home.aboutCta.titleHtml} />
            </h3>
            <p class="mt-2 text-sm text-muted-foreground">{home.aboutCta.description}</p>
          </div>
          <div class="shrink-0 anim-bob">
            <Mascot pose="srdce" size={140} />
          </div>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
