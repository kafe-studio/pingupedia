---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import NoCropImage from "../components/media/NoCropImage.astro";
import PenguinMascot from "../components/theme/PenguinMascot.astro";
import { siteConfig } from "../config/site";
import { getCollection } from "astro:content";
import emperorPenguin from "../assets/penguins/cisarsky/hero.jpg";
import adeliePenguin from "../assets/penguins/krouzkovy/hero.jpg";
import rockhopper from "../assets/penguins/skalni-jizni/hero.jpg";

const species = await getCollection("species");
const total = species.length;

const metadata = {
  title: siteConfig.name,
  description: siteConfig.description,
  ignoreTitleTemplate: true,
};
---

<BaseLayout {metadata}>
  <section class="relative px-4 sm:px-6 pt-28 pb-16">
    <div class="mx-auto max-w-7xl">
      <header class="mb-8 md:mb-12 max-w-3xl reveal">
        <p class="text-sm uppercase tracking-[0.2em] text-primary/80 mb-4">
          Česká encyklopedie tučňáků
        </p>
        <h1 class="text-5xl md:text-7xl font-black tracking-tight leading-[0.95] mb-4">
          Pozná<span class="text-primary">š</span> všech<br />
          <span class="text-accent">18 druhů</span> tučňáků?
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground">
          Fotky bez ořezu, mapy, historie a ověřené zdroje&nbsp;— pro děti i dospělé.
        </p>
      </header>

      <div class="grid grid-cols-12 auto-rows-[minmax(160px,auto)] gap-4 md:gap-5">
        <a
          href="/druhy/cisarsky/"
          class="bento-card is-link bento-surface-aurora col-span-12 md:col-span-8 md:row-span-2 p-6 md:p-8 flex flex-col justify-between min-h-[360px] reveal"
          data-astro-prefetch
        >
          <div>
            <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1 text-xs font-semibold text-white/90 backdrop-blur-sm">
              Tučňák týdne
            </span>
            <h2 class="mt-4 text-3xl md:text-5xl font-black text-white leading-tight">
              Tučňák<br />císařský
            </h2>
            <p class="mt-3 text-white/80 text-base md:text-lg max-w-md">
              Největší a nejpozoruhodnější. Hnízdí v antarktické zimě na mořském ledě a samec dva měsíce inkubuje vejce na nohou.
            </p>
          </div>
          <div class="mt-6 md:absolute md:inset-y-0 md:right-0 md:w-1/2 md:flex md:items-end md:pr-0">
            <div class="w-full md:h-[85%] relative">
              <NoCropImage
                src={emperorPenguin}
                alt="Tučňák císařský s mládětem na Snow Hill Islandu"
                ratio="4/5"
                sizes="(min-width: 768px) 400px, 100vw"
                class="rounded-2xl overflow-hidden"
                loading="eager"
              />
            </div>
          </div>
          <span class="absolute top-5 right-5 inline-flex h-11 w-11 items-center justify-center rounded-full bg-white/15 text-white backdrop-blur-sm transition group-hover:bg-white">
            →
          </span>
        </a>

        <div class="bento-card bento-surface-ice col-span-6 md:col-span-4 p-6 flex flex-col justify-between min-h-[200px] reveal">
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="text-xs uppercase tracking-widest text-accent/90 font-semibold">Druhů celkem</p>
              <p class="mt-2 text-6xl md:text-7xl font-black text-white leading-none">{total}</p>
              <p class="mt-1 text-sm text-white/70">kompletní taxonomie</p>
            </div>
            <div class="shrink-0 anim-float">
              <PenguinMascot size={96} />
            </div>
          </div>
        </div>

        <a
          href="/druhy/"
          class="bento-card is-link bento-surface-sun col-span-6 md:col-span-4 p-6 flex flex-col justify-between min-h-[200px] reveal"
          data-astro-prefetch
        >
          <div>
            <p class="text-xs uppercase tracking-widest font-bold opacity-80">Katalog</p>
            <h3 class="mt-2 text-3xl md:text-4xl font-black leading-tight">
              Všechny<br />druhy →
            </h3>
          </div>
          <p class="text-sm font-medium opacity-85">Hero fotky · fakta · zdroje · galerie</p>
        </a>

        <a
          href="/druhy/krouzkovy/"
          class="bento-card is-link col-span-6 md:col-span-3 p-5 reveal overflow-hidden"
          data-astro-prefetch
        >
          <div class="mb-3 aspect-[4/3] rounded-xl overflow-hidden bg-muted hover-wiggle">
            <NoCropImage
              src={adeliePenguin}
              alt="Tučňák kroužkový"
              ratio="4/3"
              sizes="(min-width: 768px) 280px, 45vw"
            />
          </div>
          <p class="text-xs text-muted-foreground">Rod Pygoscelis</p>
          <h3 class="text-lg font-bold mt-0.5">Tučňák kroužkový</h3>
        </a>

        <a
          href="/druhy/skalni-jizni/"
          class="bento-card is-link col-span-6 md:col-span-3 p-5 reveal overflow-hidden"
          data-astro-prefetch
        >
          <div class="mb-3 aspect-[4/3] rounded-xl overflow-hidden bg-muted hover-wiggle">
            <NoCropImage
              src={rockhopper}
              alt="Tučňák skalní jižní"
              ratio="4/3"
              sizes="(min-width: 768px) 280px, 45vw"
            />
          </div>
          <p class="text-xs text-muted-foreground">Rod Eudyptes</p>
          <h3 class="text-lg font-bold mt-0.5">Rockhopper</h3>
        </a>

        <div class="bento-card bento-surface-ocean col-span-12 md:col-span-6 p-6 md:p-8 flex flex-col justify-between min-h-[220px] reveal">
          <div>
            <p class="text-xs uppercase tracking-widest text-accent font-semibold">Jak to děláme</p>
            <h3 class="mt-3 text-2xl md:text-3xl font-black text-white leading-tight">
              Žádné výmysly.<br />Jen ověřená fakta.
            </h3>
          </div>
          <ul class="mt-4 grid grid-cols-2 gap-3 text-sm text-white/85">
            <li class="flex items-start gap-2"><span class="text-accent">✓</span> Wikipedia CS + EN</li>
            <li class="flex items-start gap-2"><span class="text-accent">✓</span> IUCN Red List</li>
            <li class="flex items-start gap-2"><span class="text-accent">✓</span> BirdLife</li>
            <li class="flex items-start gap-2"><span class="text-accent">✓</span> Fotky s licencí</li>
          </ul>
        </div>

        <a
          href="/o-projektu/"
          class="bento-card is-link col-span-12 md:col-span-6 p-6 md:p-8 flex items-center justify-between gap-4 min-h-[180px] reveal"
          data-astro-prefetch
        >
          <div>
            <p class="text-xs uppercase tracking-widest text-primary font-semibold">O projektu</p>
            <h3 class="mt-2 text-2xl md:text-3xl font-black leading-tight">
              Proč<br />pingupedia?
            </h3>
            <p class="mt-2 text-sm text-muted-foreground">Populárně-naučně, ale věcně. Pro zvědavé malé i velké.</p>
          </div>
          <div class="shrink-0 anim-bob">
            <PenguinMascot size={110} />
          </div>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
