---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config/site";
const metadata = { title: siteConfig.name, description: siteConfig.description, ignoreTitleTemplate: true };
---

<BaseLayout {metadata}>
  <section class="min-h-[80vh] flex items-center justify-center text-center px-6 pt-24">
    <div class="max-w-3xl">
      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight mb-6 reveal">
        {siteConfig.name}
      </h1>
      <p class="text-lg md:text-xl text-muted-foreground mb-10 reveal">
        {siteConfig.description}
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 reveal">
        <a href="/blog/" class="btn-primary">Blog</a>
        <a href="#content" class="btn-outline">Zjistit vice</a>
      </div>
    </div>
  </section>

  <section id="content" class="py-24 px-6">
    <div class="mx-auto max-w-5xl text-center reveal">
      <h2 class="text-3xl font-bold mb-6">Obsah</h2>
      <p class="text-muted-foreground max-w-2xl mx-auto">
        Zde bude obsah webu.
      </p>
    </div>
  </section>
</BaseLayout>
