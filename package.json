{
  "name": "pingupedia",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "wrangler types && astro dev",
    "start": "wrangler types && astro dev",
    "build": "wrangler types && astro check && astro build",
    "preview": "wrangler types && astro preview",
    "ship": "pnpm build && pnpm pagefind:index && wrangler deploy",
    "pagefind:index": "pagefind --site dist/client --output-subdir _pagefind",
    "astro": "astro",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write .",
    "fix": "pnpm format && pnpm lint",
    "test": "vitest",
    "check": "astro check",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@astrojs/check": "0.9.8",
    "@astrojs/cloudflare": "^13.3.0",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@eslint/js": "^9.39.4",
    "@iconify-json/lucide": "^1.2.105",
    "@iconify-json/tabler": "^1.2.33",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^6.2.1",
    "astro-icon": "^1.1.5",
    "remark-reading-time": "^2.1.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "yaml": "^2.8.4"
  },
  "packageManager": "pnpm@10.12.1",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260504.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.6.0",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^17.6.0",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5",
    "wrangler": "^4.87.0"
  }
}
