# Admin secrets — copy to .dev.vars (git-ignored) for local dev.
# In production: wrangler secret put ADMIN_PASSWORD / SESSION_SECRET / GITHUB_TOKEN

ADMIN_PASSWORD=change-me-locally
SESSION_SECRET=at-least-32-char-random-string-please

# GitHub API — fine-grained PAT with Contents: Read and write on this repo
GITHUB_TOKEN=github_pat_placeholder
GITHUB_OWNER=kafe-studio
GITHUB_REPO=pingupedia
GITHUB_BRANCH=main
