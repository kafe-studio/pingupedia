{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pingupedia",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "compatibility_date": "2026-03-05",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "observability": {
    "enabled": true
  },
  "workers_dev": true,
  "preview_urls": false
}
